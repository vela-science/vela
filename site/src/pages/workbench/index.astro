---
import Page from "../../layouts/Page.astro";
import { WORKBENCH_URL } from "../../config";

// API proxied through the site's nginx (`/api/*` → vela-workbench).
// At build time the URL the page references is `/api/frontier`; at
// runtime the proxy forwards to the workbench API. Same origin,
// no CORS, single domain.
const API_PATH = "/api/frontier";
---
<Page
  title="Workbench · Vela"
  description="Live read-only view of the BBB Flagship frontier — claims, conditions, evidence, state."
  active="workbench"
  eyebrow="Workbench · Frontier"
  pageTitle="Loading frontier…"
  subtitle="Live read-only view of the active frontier. Click any row to inspect a finding end-to-end."
>
  <div slot="aside">
    <span class="wb-chip wb-chip--live" id="lf-live"
          style="--chip:var(--state-live);">
      <span class="wb-chip__dot"></span>connecting
    </span>
  </div>

  <section class="lf-picker" aria-label="Frontier picker">
    <span class="lf-picker__eyebrow">Frontier</span>
    <div class="lf-picker__list" id="lf-picker">
      <button class="lf-picker__btn lf-picker__btn--on" data-vfr="">BBB Flagship · default</button>
    </div>
    <a class="lf-picker__source" id="lf-picker-source" href="https://vela-hub.fly.dev/entries">hub list →</a>
  </section>

  <section class="lf-meta">
    <div class="lf-meta__cell">
      <div class="lf-meta__k">findings</div>
      <div class="lf-meta__v" id="lf-m-findings">—</div>
    </div>
    <div class="lf-meta__cell">
      <div class="lf-meta__k">events</div>
      <div class="lf-meta__v" id="lf-m-events">—</div>
    </div>
    <div class="lf-meta__cell">
      <div class="lf-meta__k">pending proposals</div>
      <div class="lf-meta__v" id="lf-m-proposals">—</div>
    </div>
    <div class="lf-meta__cell">
      <div class="lf-meta__k">snapshot</div>
      <div class="lf-meta__v mono" id="lf-m-snapshot">—</div>
    </div>
  </section>

  <section class="lf-rete-section">
    <header class="lf-rete-head">
      <span class="lf-rete-eyebrow">Rete</span>
      <span class="lf-rete-meta" id="lf-rete-meta">—</span>
      <span class="lf-rete-legend" id="lf-rete-legend"></span>
    </header>
    <div class="lf-rete-stage">
      <svg id="lf-rete" viewBox="0 0 800 320" preserveAspectRatio="xMidYMid meet" aria-label="Finding link graph"></svg>
      <div class="lf-rete-tooltip" id="lf-rete-tt" hidden></div>
    </div>
  </section>

  <div class="lf-toolbar">
    <label class="lf-search">
      <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" aria-hidden="true">
        <circle cx="7" cy="7" r="5" stroke-width="1" />
        <line x1="11" y1="11" x2="15" y2="15" stroke-width="1" />
      </svg>
      <input type="search" id="lf-search" placeholder="filter by claim, class, vf_id…" />
      <span class="lf-search__count" id="lf-count">— / —</span>
    </label>
    <div class="lf-chips" id="lf-chips">
      <button class="lf-chip-btn lf-chip-btn--on" data-state="all">all</button>
    </div>
  </div>

  <table class="lf-table">
    <thead>
      <tr>
        <th>vf_id</th>
        <th>class</th>
        <th>claim</th>
        <th>state</th>
        <th class="num">conf</th>
      </tr>
    </thead>
    <tbody id="lf-body">
      <tr><td colspan="5" class="lf-empty">connecting…</td></tr>
    </tbody>
  </table>

  <section class="lf-sources" id="lf-sources" hidden>
    <header class="lf-sources-head">
      <span class="lf-sources-eyebrow">Source registry</span>
      <span class="lf-sources-meta" id="lf-sources-meta">—</span>
    </header>
    <ul class="lf-sources-list" id="lf-sources-list"></ul>
  </section>

  <section class="lf-refby" id="lf-refby" hidden>
    <header class="lf-sources-head">
      <span class="lf-sources-eyebrow">Referenced by</span>
      <span class="lf-sources-meta" id="lf-refby-meta">—</span>
    </header>
    <ul class="lf-sources-list" id="lf-refby-list"></ul>
  </section>

  <p class="lf-tip">
    The Workbench fetches from <code>/api/frontier</code>, served by <a href={WORKBENCH_URL} class="ext">vela-workbench</a> behind a same-origin proxy. Click any finding to read its evidence, conditions, links, and history.
  </p>
</Page>

<script>
  // Workbench frontier-table: live-fetch /api/frontier and render
  // workbench frontier-pattern. Self-contained, no framework.

  type RawFinding = {
    id: string;
    assertion?: { text?: string; type?: string };
    confidence?: { score?: number };
    flags?: {
      retracted?: boolean;
      gap?: boolean;
      negative_space?: boolean;
      contested?: boolean;
      review_state?: string;
    };
    evidence?: { replicated?: boolean };
    links?: Array<{ target: string; type?: string }>;
  };
  type Frontier = {
    frontier_id?: string;
    frontier?: { name?: string; description?: string };
    project?: { name?: string; description?: string };
    findings?: RawFinding[];
    events?: unknown[];
    proposals?: Array<{ status?: string; target?: { id?: string } }>;
    snapshot_hash?: string;
    sources?: Array<{
      id: string;
      source_type: string;
      title?: string;
      doi?: string | null;
      pmid?: string | null;
      year?: number | null;
      journal?: string | null;
    }>;
    evidence_atoms?: unknown[];
    condition_records?: unknown[];
  };

  const STATE_TO_CLASS: Record<string, string> = {
    retracted: "lost",
    gap: "stale",
    contested: "warn",
    replicated: "ok",
    supported: "ok",
  };

  function deriveState(f: RawFinding): string {
    const flags = f.flags || {};
    const ev = f.evidence || {};
    if (flags.retracted) return "retracted";
    if (flags.gap || flags.negative_space) return "gap";
    const rs = flags.review_state;
    if (rs === "contested" || rs === "needs_revision") return "contested";
    if (rs === "rejected") return "retracted";
    if (rs === "accepted") return ev.replicated ? "replicated" : "supported";
    if (flags.contested) return "contested";
    return ev.replicated ? "replicated" : "supported";
  }

  function escapeHtml(s: string): string {
    const div = document.createElement("div");
    div.textContent = s == null ? "" : String(s);
    return div.innerHTML;
  }

  type State = {
    findings: RawFinding[];
    search: string;
    activeState: string;
  };
  const state: State = { findings: [], search: "", activeState: "all" };

  function rowHtml(f: RawFinding): string {
    const stateLabel = deriveState(f);
    const stateClass = STATE_TO_CLASS[stateLabel] || "muted";
    const liveClass = stateLabel === "replicated" ? " wb-chip--live" : "";
    const conf = f.confidence?.score ?? 0;
    const pct = Math.round(Math.max(0, Math.min(1, conf)) * 100);
    const cls = (f.assertion?.type || "").split(/\s+/)[0] || "";
    return `
      <tr data-vfid="${escapeHtml(f.id)}">
        <td class="idx">${escapeHtml(f.id)}</td>
        <td class="cls">${escapeHtml(cls)}</td>
        <td class="claim">${escapeHtml(f.assertion?.text || "")}</td>
        <td class="state"><span class="wb-chip${liveClass}" style="--chip:var(--state-${stateClass});"><span class="wb-chip__dot"></span>${stateLabel}</span></td>
        <td class="conf"><span class="lf-bar"><i style="width:${pct}%"></i></span><span class="lf-num">${conf.toFixed(2)}</span></td>
      </tr>`;
  }

  function rowMatches(f: RawFinding): boolean {
    if (state.activeState !== "all" && deriveState(f) !== state.activeState) return false;
    if (!state.search) return true;
    const q = state.search.toLowerCase();
    return (
      (f.assertion?.text || "").toLowerCase().includes(q) ||
      (f.assertion?.type || "").toLowerCase().includes(q) ||
      (f.id || "").toLowerCase().includes(q)
    );
  }

  function render(): void {
    const body = document.getElementById("lf-body")!;
    const filtered = state.findings.filter(rowMatches);
    document.getElementById("lf-count")!.textContent =
      `${filtered.length} / ${state.findings.length}`;
    if (filtered.length === 0) {
      body.innerHTML = '<tr><td colspan="5" class="lf-empty">No findings match the current filter.</td></tr>';
      return;
    }
    body.innerHTML = filtered.map(rowHtml).join("");
    body.querySelectorAll<HTMLTableRowElement>("tr[data-vfid]").forEach((tr) => {
      tr.addEventListener("click", () => {
        const id = tr.getAttribute("data-vfid")!;
        {
          const vfr = new URLSearchParams(window.location.search).get("vfr");
          const suffix = vfr ? `&vfr=${encodeURIComponent(vfr)}` : "";
          window.location.href = `/workbench/finding?id=${encodeURIComponent(id)}${suffix}`;
        }
      });
    });
  }

  function buildChips(stateCounts: Map<string, number>): void {
    const order = ["replicated", "supported", "contested", "gap", "retracted"];
    const wrap = document.getElementById("lf-chips")!;
    wrap.innerHTML = '<button class="lf-chip-btn lf-chip-btn--on" data-state="all">all</button>';
    for (const k of order) {
      const n = stateCounts.get(k) || 0;
      if (!n) continue;
      const b = document.createElement("button");
      b.className = "lf-chip-btn";
      b.dataset.state = k;
      b.innerHTML = `${k} <span>${n}</span>`;
      wrap.appendChild(b);
    }
    wrap.querySelectorAll<HTMLButtonElement>("button").forEach((btn) => {
      btn.addEventListener("click", () => {
        state.activeState = btn.dataset.state || "all";
        wrap.querySelectorAll<HTMLButtonElement>("button").forEach((x) =>
          x.classList.remove("lf-chip-btn--on"),
        );
        btn.classList.add("lf-chip-btn--on");
        render();
      });
    });
  }

  // ─── Rete: link-graph view ────────────────────────────────────────
  //
  // Vanilla force simulation over (findings, links). 48 nodes ×
  // 215 edges in BBB is small enough that O(n²) repulsion is fine.
  // Settles for ~250 ticks then renders statically; hover/click on
  // nodes update the highlight state without re-running physics.
  // Honours prefers-reduced-motion by skipping the animation phase
  // and rendering the settled layout directly.

  type GraphNode = {
    id: string;
    state: string;
    text: string;
    type: string;
    /// "local" = a finding in this frontier; "ghost" = an external
    /// vfr_id surfaced because a cross-frontier link points at it.
    kind: "local" | "ghost";
    x: number;
    y: number;
    vx: number;
    vy: number;
    deg: number;
  };
  type GraphEdge = {
    s: number;
    t: number;
    type: string;
    /// True for cross-frontier (ghost-target) edges — render dashed.
    cross: boolean;
  };

  function renderRete(findings: RawFinding[]): void {
    const svg = document.getElementById("lf-rete") as SVGSVGElement | null;
    const meta = document.getElementById("lf-rete-meta");
    const legend = document.getElementById("lf-rete-legend");
    const tt = document.getElementById("lf-rete-tt") as HTMLDivElement | null;
    if (!svg || !meta || !legend || !tt) return;

    const W = 800;
    const H = 320;

    // Build nodes + edge list. v0.8: cross-frontier link targets
    // (`vf_…@vfr_…`) become "ghost" nodes pinned to the rim of the
    // canvas — one per distinct external `vfr_id`. Edges to ghost
    // nodes render dashed and clicking jumps to the hub's entry page
    // for that frontier.
    const idIndex = new Map<string, number>();
    findings.forEach((f, i) => idIndex.set(f.id, i));

    const nodes: GraphNode[] = findings.map((f, i) => {
      const angle = (i / Math.max(1, findings.length)) * Math.PI * 2;
      const r = 90 + (i % 3) * 18;
      return {
        id: f.id,
        state: deriveState(f),
        text: f.assertion?.text || "",
        type: (f.assertion?.type || "").split(/\s+/)[0] || "",
        kind: "local",
        x: W / 2 + r * Math.cos(angle),
        y: H / 2 + r * Math.sin(angle),
        vx: 0,
        vy: 0,
        deg: 0,
      };
    });

    // Ghost node index: external vfr_id → node index (added on demand).
    const ghostIndex = new Map<string, number>();
    function ensureGhost(vfrId: string): number {
      const hit = ghostIndex.get(vfrId);
      if (hit !== undefined) return hit;
      const i = nodes.length;
      // Pin ghosts on a wider ring so they sit at the rim.
      const angle = (i / 8) * Math.PI * 2;
      const r = 130;
      nodes.push({
        id: vfrId,
        state: "external",
        text: `external frontier · ${vfrId}`,
        type: "frontier",
        kind: "ghost",
        x: W / 2 + r * Math.cos(angle),
        y: H / 2 + r * Math.sin(angle),
        vx: 0,
        vy: 0,
        deg: 0,
      });
      ghostIndex.set(vfrId, i);
      return i;
    }

    const edges: GraphEdge[] = [];
    for (const f of findings) {
      const s = idIndex.get(f.id);
      if (s === undefined) continue;
      for (const l of f.links || []) {
        // Parse target: `vf_…` (local) | `vf_…@vfr_…` (cross).
        const at = l.target.indexOf("@");
        if (at === -1) {
          const t = idIndex.get(l.target);
          if (t === undefined) continue; // dangling local target
          edges.push({ s, t, type: l.type || "link", cross: false });
          nodes[s].deg++;
          nodes[t].deg++;
        } else {
          const vfrId = l.target.slice(at + 1);
          const t = ensureGhost(vfrId);
          edges.push({ s, t, type: l.type || "link", cross: true });
          nodes[s].deg++;
          nodes[t].deg++;
        }
      }
    }

    meta.textContent = `${nodes.length} findings · ${edges.length} links`;

    const stateOrder = ["replicated", "supported", "contested", "gap", "retracted"] as const;
    const stateCounts = new Map<string, number>();
    for (const n of nodes) stateCounts.set(n.state, (stateCounts.get(n.state) || 0) + 1);
    const stateLegend = stateOrder
      .filter((k) => (stateCounts.get(k) || 0) > 0)
      .map(
        (k) =>
          `<span><span class="swatch" style="background:var(--state-${STATE_TO_CLASS[k]});"></span>${k}</span>`,
      )
      .join("");
    // v0.10: shape legend if the frontier has any quantitative findings.
    const hasQuant = nodes.some(
      (n) => n.kind !== "ghost" && (n.type === "measurement" || n.type === "exclusion"),
    );
    const shapeLegend = hasQuant
      ? `<span class="legend-shape" title="Diamond = measurement or exclusion (v0.10 quantitative assertion types)"><span class="swatch swatch--diamond"></span>quantitative</span>`
      : "";
    legend.innerHTML = stateLegend + shapeLegend;

    // Force simulation. Coulomb repulsion + Hooke springs along edges
    // + soft pull toward center. No frameworks; ~80 lines of physics.
    const REPULSION = 1200;
    const SPRING_K = 0.04;
    const SPRING_LEN = 60;
    const CENTER_K = 0.012;
    const DAMPING = 0.86;
    const MAX_VEL = 6;

    function step(): number {
      let totalKE = 0;
      // Repulsion (n²).
      for (let i = 0; i < nodes.length; i++) {
        const a = nodes[i];
        for (let j = i + 1; j < nodes.length; j++) {
          const b = nodes[j];
          let dx = a.x - b.x;
          let dy = a.y - b.y;
          let d2 = dx * dx + dy * dy;
          if (d2 < 1) {
            d2 = 1;
            dx = Math.random() - 0.5;
            dy = Math.random() - 0.5;
          }
          const f = REPULSION / d2;
          const d = Math.sqrt(d2);
          const fx = (f * dx) / d;
          const fy = (f * dy) / d;
          a.vx += fx;
          a.vy += fy;
          b.vx -= fx;
          b.vy -= fy;
        }
      }
      // Springs along edges.
      for (const e of edges) {
        const a = nodes[e.s];
        const b = nodes[e.t];
        const dx = b.x - a.x;
        const dy = b.y - a.y;
        const d = Math.sqrt(dx * dx + dy * dy) || 1;
        const f = (d - SPRING_LEN) * SPRING_K;
        const fx = (f * dx) / d;
        const fy = (f * dy) / d;
        a.vx += fx;
        a.vy += fy;
        b.vx -= fx;
        b.vy -= fy;
      }
      // Center pull + integrate. Ghost nodes stay pinned where they
      // were placed (rim positions); they receive no forces and don't
      // count against the kinetic-energy convergence test.
      for (const n of nodes) {
        if (n.kind === "ghost") {
          n.vx = 0;
          n.vy = 0;
          continue;
        }
        n.vx += (W / 2 - n.x) * CENTER_K;
        n.vy += (H / 2 - n.y) * CENTER_K;
        n.vx *= DAMPING;
        n.vy *= DAMPING;
        // Velocity clamp.
        const v = Math.hypot(n.vx, n.vy);
        if (v > MAX_VEL) {
          n.vx *= MAX_VEL / v;
          n.vy *= MAX_VEL / v;
        }
        n.x += n.vx;
        n.y += n.vy;
        // Bounds.
        const margin = 14;
        if (n.x < margin) { n.x = margin; n.vx = 0; }
        if (n.x > W - margin) { n.x = W - margin; n.vx = 0; }
        if (n.y < margin) { n.y = margin; n.vy = 0; }
        if (n.y > H - margin) { n.y = H - margin; n.vy = 0; }
        totalKE += n.vx * n.vx + n.vy * n.vy;
      }
      return totalKE;
    }

    // Run to steady state.
    for (let i = 0; i < 280; i++) {
      const ke = step();
      if (ke < 0.05 && i > 60) break;
    }

    // Build SVG.
    const SVGNS = "http://www.w3.org/2000/svg";
    while (svg.firstChild) svg.removeChild(svg.firstChild);

    const edgesGroup = document.createElementNS(SVGNS, "g");
    edgesGroup.setAttribute("class", "edges");
    const nodesGroup = document.createElementNS(SVGNS, "g");
    nodesGroup.setAttribute("class", "nodes");

    const edgeEls: SVGLineElement[] = [];
    for (const e of edges) {
      const a = nodes[e.s];
      const b = nodes[e.t];
      const line = document.createElementNS(SVGNS, "line");
      line.setAttribute("x1", a.x.toFixed(1));
      line.setAttribute("y1", a.y.toFixed(1));
      line.setAttribute("x2", b.x.toFixed(1));
      line.setAttribute("y2", b.y.toFixed(1));
      line.setAttribute("class", e.cross ? "edge edge--cross" : "edge");
      line.dataset.s = String(e.s);
      line.dataset.t = String(e.t);
      edgesGroup.appendChild(line);
      edgeEls.push(line);
    }

    const nodeEls: SVGGElement[] = [];
    for (let i = 0; i < nodes.length; i++) {
      const n = nodes[i];
      const cls = STATE_TO_CLASS[n.state] || "muted";
      const r = n.kind === "ghost" ? 7 : 4 + Math.min(6, n.deg * 0.5);
      const g = document.createElementNS(SVGNS, "g");
      g.setAttribute("class", n.kind === "ghost" ? "node node--ghost" : "node");
      g.setAttribute("transform", `translate(${n.x.toFixed(1)},${n.y.toFixed(1)})`);
      g.dataset.idx = String(i);
      g.dataset.vfid = n.id;
      g.dataset.kind = n.kind;

      if (n.kind === "ghost") {
        // Ghost: a small open square (different shape from dots)
        // pinned at the rim, stroked in signal blue.
        const rect = document.createElementNS(SVGNS, "rect");
        const sz = r * 1.6;
        rect.setAttribute("x", (-sz / 2).toFixed(1));
        rect.setAttribute("y", (-sz / 2).toFixed(1));
        rect.setAttribute("width", sz.toFixed(1));
        rect.setAttribute("height", sz.toFixed(1));
        rect.setAttribute("fill", "var(--paper-0)");
        rect.setAttribute("stroke", "var(--signal)");
        rect.setAttribute("stroke-width", "1.2");
        g.appendChild(rect);
      } else {
        // v0.10: assertion type drives the node shape so cross-domain
        // frontiers are visually distinct in the rete. Measurement and
        // exclusion findings (physics-shaped: report a value or bound a
        // parameter) render as diamonds; everything else (mechanism,
        // therapeutic, observational, …) stays as circles.
        const isQuantitative = n.type === "measurement" || n.type === "exclusion";
        if (isQuantitative) {
          const sz = (r + 1) * 1.4;
          const diamond = document.createElementNS(SVGNS, "polygon");
          diamond.setAttribute(
            "points",
            `0,${(-sz).toFixed(1)} ${sz.toFixed(1)},0 0,${sz.toFixed(1)} ${(-sz).toFixed(1)},0`,
          );
          diamond.setAttribute("fill", `var(--state-${cls})`);
          const stroke = document.createElementNS(SVGNS, "polygon");
          const sz2 = sz + 2;
          stroke.setAttribute(
            "points",
            `0,${(-sz2).toFixed(1)} ${sz2.toFixed(1)},0 0,${sz2.toFixed(1)} ${(-sz2).toFixed(1)},0`,
          );
          stroke.setAttribute("class", "node-stroke");
          g.appendChild(diamond);
          g.appendChild(stroke);
        } else {
          const dot = document.createElementNS(SVGNS, "circle");
          dot.setAttribute("r", r.toFixed(1));
          dot.setAttribute("fill", `var(--state-${cls})`);
          const stroke = document.createElementNS(SVGNS, "circle");
          stroke.setAttribute("r", (r + 2).toFixed(1));
          stroke.setAttribute("class", "node-stroke");
          g.appendChild(dot);
          g.appendChild(stroke);
        }
      }
      nodesGroup.appendChild(g);
      nodeEls.push(g);
    }

    svg.appendChild(edgesGroup);
    svg.appendChild(nodesGroup);

    // Adjacency for hover-highlight.
    const adj = new Map<number, Set<number>>();
    edges.forEach((e) => {
      if (!adj.has(e.s)) adj.set(e.s, new Set());
      if (!adj.has(e.t)) adj.set(e.t, new Set());
      adj.get(e.s)!.add(e.t);
      adj.get(e.t)!.add(e.s);
    });

    function highlight(idx: number | null): void {
      if (idx === null) {
        edgeEls.forEach((el) => el.classList.remove("muted", "hot"));
        nodeEls.forEach((el) => el.classList.remove("hot"));
        tt!.hidden = true;
        return;
      }
      const neighbors = adj.get(idx) || new Set();
      edgeEls.forEach((el) => {
        const s = Number(el.dataset.s);
        const t = Number(el.dataset.t);
        if (s === idx || t === idx) {
          el.classList.add("hot");
          el.classList.remove("muted");
        } else {
          el.classList.add("muted");
          el.classList.remove("hot");
        }
      });
      nodeEls.forEach((el, i) => {
        if (i === idx || neighbors.has(i)) el.classList.add("hot");
        else el.classList.remove("hot");
      });
    }

    function showTooltip(idx: number, ev: MouseEvent): void {
      const n = nodes[idx];
      const claim = n.text.length > 220 ? n.text.slice(0, 220) + "…" : n.text;
      tt!.innerHTML =
        `<span class="tt-id">${escapeHtml(n.id)} · ${escapeHtml(n.state)}${n.type ? " · " + escapeHtml(n.type) : ""}</span>` +
        escapeHtml(claim);
      tt!.hidden = false;
      // Position relative to stage.
      const stage = svg.parentElement!;
      const rect = stage.getBoundingClientRect();
      const x = ev.clientX - rect.left + 12;
      const y = ev.clientY - rect.top + 12;
      tt!.style.transform = `translate(${x}px, ${y}px)`;
    }

    nodeEls.forEach((el) => {
      const idx = Number(el.dataset.idx);
      el.addEventListener("mouseenter", (ev) => {
        highlight(idx);
        showTooltip(idx, ev as MouseEvent);
      });
      el.addEventListener("mousemove", (ev) => {
        showTooltip(idx, ev as MouseEvent);
      });
      el.addEventListener("mouseleave", () => highlight(null));
      el.addEventListener("click", () => {
        const id = el.dataset.vfid!;
        const kind = el.dataset.kind || "local";
        if (kind === "ghost") {
          // External vfr_id — jump to the hub's entry page for that frontier.
          window.location.href = `https://vela-hub.fly.dev/entries/${encodeURIComponent(id)}`;
        } else {
          {
          const vfr = new URLSearchParams(window.location.search).get("vfr");
          const suffix = vfr ? `&vfr=${encodeURIComponent(vfr)}` : "";
          window.location.href = `/workbench/finding?id=${encodeURIComponent(id)}${suffix}`;
        }
        }
      });
    });
  }

  type HubEntry = {
    vfr_id: string;
    name: string;
    network_locator: string;
    latest_snapshot_hash: string;
    owner_actor_id: string;
    signed_publish_at: string;
  };

  // Source-of-truth selector. Default path stays the same — fetch the
  // BBB frontier through /api/frontier (vela-workbench API). When the
  // page is loaded with `?vfr=<id>`, fetch that frontier directly from
  // the public hub: hub entry → network_locator → frontier JSON. The
  // hub is dumb signed transport (CORS open); github raw also serves
  // CORS *. No proxy required.
  const HUB_BASE = "https://vela-hub.fly.dev";

  async function loadFrontier(): Promise<{ data: Frontier; sourceLabel: string }> {
    const params = new URLSearchParams(window.location.search);
    const vfr = params.get("vfr");
    if (!vfr) {
      const r = await fetch("/api/frontier", { headers: { accept: "application/json" } });
      if (!r.ok) throw new Error(`/api/frontier ${r.status}`);
      const data = (await r.json()) as Frontier;
      return { data, sourceLabel: "/api/frontier (BBB Flagship)" };
    }
    const er = await fetch(`${HUB_BASE}/entries/${encodeURIComponent(vfr)}`, {
      headers: { accept: "application/json" },
    });
    if (!er.ok) throw new Error(`hub entry ${vfr}: ${er.status}`);
    const entry = (await er.json()) as HubEntry;
    const fr = await fetch(entry.network_locator, { headers: { accept: "application/json" } });
    if (!fr.ok) throw new Error(`locator ${entry.network_locator}: ${fr.status}`);
    const data = (await fr.json()) as Frontier;
    return { data, sourceLabel: `${entry.vfr_id} · ${entry.owner_actor_id}` };
  }

  async function buildPicker(): Promise<void> {
    const picker = document.getElementById("lf-picker");
    if (!picker) return;
    try {
      const r = await fetch(`${HUB_BASE}/entries`, { headers: { accept: "application/json" } });
      if (!r.ok) return;
      const list = ((await r.json()) as { entries: HubEntry[] }).entries || [];
      const params = new URLSearchParams(window.location.search);
      const activeVfr = params.get("vfr") || "";
      // Render: one button per hub entry, plus the BBB-default button (no vfr param).
      picker.innerHTML = "";
      const defaultBtn = document.createElement("a");
      defaultBtn.className =
        "lf-picker__btn" + (activeVfr === "" ? " lf-picker__btn--on" : "");
      defaultBtn.href = "/workbench";
      defaultBtn.textContent = "BBB · default";
      picker.appendChild(defaultBtn);
      for (const e of list) {
        const a = document.createElement("a");
        a.className =
          "lf-picker__btn" + (activeVfr === e.vfr_id ? " lf-picker__btn--on" : "");
        a.href = `/workbench?vfr=${encodeURIComponent(e.vfr_id)}`;
        const shortName = e.name.length > 40 ? e.name.slice(0, 38) + "…" : e.name;
        a.textContent = `${shortName} · ${e.owner_actor_id}`;
        a.title = `${e.vfr_id}\n${e.network_locator}`;
        picker.appendChild(a);
      }
    } catch {
      // Picker is best-effort; if hub is unreachable, fall back to the
      // default-only button already in the DOM.
    }
  }

  // v0.14: render the materialized source registry below the table.
  // The v0.13 substrate change made `sources[]` populate inline at
  // proposal-apply time, so any v0.13+ frontier from the CLI has it.
  // Pre-v0.13 frontiers (BBB) may still be empty — we hide the panel.
  function renderSources(data: Frontier): void {
    const section = document.getElementById("lf-sources");
    const meta = document.getElementById("lf-sources-meta");
    const list = document.getElementById("lf-sources-list");
    if (!section || !meta || !list) return;
    const sources = data.sources || [];
    const evCount = (data.evidence_atoms || []).length;
    const condCount = (data.condition_records || []).length;
    if (sources.length === 0) {
      section.setAttribute("hidden", "");
      return;
    }
    section.removeAttribute("hidden");
    meta.textContent = `${sources.length} source${sources.length === 1 ? "" : "s"} · ${evCount} evidence atom${evCount === 1 ? "" : "s"} · ${condCount} condition record${condCount === 1 ? "" : "s"}`;
    list.innerHTML = sources
      .map((s) => {
        const title = escapeHtml(s.title || s.id);
        const id = escapeHtml(s.id);
        const stype = escapeHtml(s.source_type || "—");
        const doi = s.doi
          ? `<a class="src-doi" href="https://doi.org/${encodeURIComponent(s.doi)}" rel="noopener" target="_blank">doi:${escapeHtml(s.doi)}</a>`
          : "";
        const pmid = s.pmid
          ? `<a class="src-doi" href="https://pubmed.ncbi.nlm.nih.gov/${encodeURIComponent(s.pmid)}/" rel="noopener" target="_blank">pmid:${escapeHtml(s.pmid)}</a>`
          : "";
        const journal = s.journal ? escapeHtml(s.journal) : "";
        const year = s.year ? String(s.year) : "";
        const meta_bits = [stype, journal, year].filter(Boolean).join(" · ");
        return `<li class="src-item">
  <div class="src-title">${title}</div>
  <div class="src-meta">
    <span class="src-id">${id}</span>
    <span class="src-meta-bits">${escapeHtml(meta_bits)}</span>
    ${doi}${pmid}
  </div>
</li>`;
      })
      .join("");
  }

  // v0.16: render the "Referenced by" panel using the hub's
  // /entries/{vfr}/depends-on endpoint. Surfaces "who in the world is
  // referencing this frontier" — the bidirectional view of cross-frontier
  // composition. Hidden when there are zero dependents or when the hub
  // is unreachable.
  type DependsOnEntry = {
    vfr_id: string;
    name: string;
    owner_actor_id: string;
    signed_publish_at: string;
  };

  async function renderReferencedBy(vfr: string): Promise<void> {
    const section = document.getElementById("lf-refby");
    const meta = document.getElementById("lf-refby-meta");
    const list = document.getElementById("lf-refby-list");
    if (!section || !meta || !list) return;
    try {
      const r = await fetch(`${HUB_BASE}/entries/${encodeURIComponent(vfr)}/depends-on`, {
        headers: { accept: "application/json" },
      });
      if (!r.ok) return; // fail-quiet
      const body = (await r.json()) as { dependents?: DependsOnEntry[] };
      const dependents = body.dependents || [];
      if (dependents.length === 0) return; // nothing to show; stay hidden
      section.removeAttribute("hidden");
      meta.textContent = `${dependents.length} ${dependents.length === 1 ? "frontier" : "frontiers"} reference this one`;
      list.innerHTML = dependents
        .map((e) => {
          const href = `/workbench?vfr=${encodeURIComponent(e.vfr_id)}`;
          const title = escapeHtml(e.name);
          const id = escapeHtml(e.vfr_id);
          const owner = escapeHtml(e.owner_actor_id);
          const when = e.signed_publish_at
            ? escapeHtml(e.signed_publish_at.slice(0, 10))
            : "—";
          return `<li class="src-item">
  <a class="src-title" href="${href}">${title}</a>
  <div class="src-meta">
    <span class="src-id">${id}</span>
    <span class="src-meta-bits">${owner}</span>
    <span class="src-meta-bits">${when}</span>
  </div>
</li>`;
        })
        .join("");
    } catch {
      // Hub unreachable — leave hidden silently.
    }
  }

  async function bootstrap(): Promise<void> {
    buildPicker(); // fire-and-forget; doesn't block frontier load
    try {
      const { data } = await loadFrontier();
      state.findings = data.findings || [];

      // Header.
      const name = data.frontier?.name || data.project?.name || "Frontier";
      const desc = data.frontier?.description || data.project?.description || "";
      const titleEl = document.querySelector<HTMLHeadingElement>(".wb-head__title");
      if (titleEl) titleEl.textContent = name;
      const subEl = document.querySelector<HTMLParagraphElement>(".wb-head__sub");
      if (subEl) subEl.textContent = desc;

      const live = document.getElementById("lf-live")!;
      const lastNode = live.lastChild;
      if (lastNode && lastNode.nodeType === Node.TEXT_NODE) {
        lastNode.textContent = "live";
      }

      // Metrics.
      document.getElementById("lf-m-findings")!.textContent = String(state.findings.length);
      document.getElementById("lf-m-events")!.textContent = String((data.events || []).length);
      const proposalsByTarget = new Map<string, number>();
      for (const p of data.proposals || []) {
        if (p.status === "pending_review" && p.target?.id) {
          proposalsByTarget.set(p.target.id, (proposalsByTarget.get(p.target.id) || 0) + 1);
        }
      }
      const pending = Array.from(proposalsByTarget.values()).reduce((a, b) => a + b, 0);
      document.getElementById("lf-m-proposals")!.textContent = String(pending);
      const snapshot = data.snapshot_hash || "";
      document.getElementById("lf-m-snapshot")!.textContent =
        snapshot ? `${snapshot.slice(0, 12)}…` : "—";

      // Chips + state counts.
      const stateCounts = new Map<string, number>();
      for (const f of state.findings) {
        const k = deriveState(f);
        stateCounts.set(k, (stateCounts.get(k) || 0) + 1);
      }
      buildChips(stateCounts);

      // Search.
      const searchInput = document.getElementById("lf-search") as HTMLInputElement | null;
      if (searchInput) {
        searchInput.addEventListener("input", (e) => {
          state.search = (e.target as HTMLInputElement).value || "";
          render();
        });
      }
      render();

      // Run the rete after the table — the simulation can hang the
      // main thread for ~50–150ms; defer so the table paints first.
      requestAnimationFrame(() => renderRete(state.findings));

      // v0.14: render the materialized source registry (v0.13 made these
      // populate inline at proposal-apply time). Fail-quiet if `sources`
      // is empty for legacy frontiers.
      renderSources(data);

      // v0.16: render the "Referenced by" panel from the hub's
      // /entries/{vfr}/depends-on endpoint. Only meaningful for
      // hub-loaded frontiers (via ?vfr=…); skipped for the default
      // BBB-via-/api/frontier path which doesn't know its own vfr_id.
      const params = new URLSearchParams(window.location.search);
      const activeVfr = params.get("vfr");
      if (activeVfr) {
        renderReferencedBy(activeVfr);
      }
    } catch (err) {
      const live = document.getElementById("lf-live");
      if (live) {
        live.style.setProperty("--chip", "var(--state-lost)");
        const lastNode = live.lastChild;
        if (lastNode && lastNode.nodeType === Node.TEXT_NODE) {
          lastNode.textContent = "unreachable";
        }
      }
      const body = document.getElementById("lf-body");
      if (body) {
        const message = err instanceof Error ? err.message : String(err);
        const params = new URLSearchParams(window.location.search);
        const vfr = params.get("vfr");
        const where = vfr ? `hub frontier <code>${escapeHtml(vfr)}</code>` : "<code>/api/frontier</code>";
        body.innerHTML = `<tr><td colspan="5" class="lf-empty">Failed to load ${where}: ${escapeHtml(message)}</td></tr>`;
      }
    }
  }
  bootstrap();
</script>

