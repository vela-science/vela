    background: color-mix(in oklab, var(--paper-1) 70%, var(--paper-deep));
    border-radius: 3px;
    color: var(--ink-0);
  }
  .spec__pair dt code { background: transparent; padding: 0; }
  .inline-link {
    color: var(--ink-1);
    text-decoration: underline;
    text-decoration-color: color-mix(in oklab, var(--gold) 56%, transparent);
    text-underline-offset: 3px;
