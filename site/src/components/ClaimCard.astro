---
import type { ClaimView } from "../lib/frontier";
import { TARGETS, shortCitation, doiUrl } from "../lib/frontier";

interface Props {
  claim: ClaimView;
  compact?: boolean;
}

const { claim, compact = false } = Astro.props;
const f = claim.finding;

const cite = shortCitation(f.provenance);
const targetDefs = TARGETS.filter((t) => claim.targets.includes(t.slug));

const isContradiction =
  f.flags.contested || f.assertion.type === "tension";

const confidenceDotColor =
  claim.confidenceBucket === "high"
    ? "var(--moss)"
    : claim.confidenceBucket === "mid"
      ? "var(--brass)"
      : "var(--stone)";
---

<a
  class={`claim-card${compact ? " claim-card--compact" : ""}`}
  href={`/claims/${claim.slug}`}
  aria-label={f.assertion.text}
>
  <div class="claim-card__top">
    <div class="claim-card__chips">
      {targetDefs.map((t) => (
        <span class="claim-card__chip">{t.short}</span>
      ))}
      {isContradiction && (
        <span class="claim-card__chip claim-card__chip--contested">contested</span>
      )}
    </div>
    <span
      class="claim-card__conf"
      style={`--dot:${confidenceDotColor}`}
      title={`Confidence ${f.confidence.score.toFixed(2)}`}
    >
      <span class="claim-card__conf-dot"></span>
      <span class="claim-card__conf-num">{f.confidence.score.toFixed(2)}</span>
    </span>
  </div>

  <p class="claim-card__claim">{f.assertion.text}</p>

  <div class="claim-card__foot">
    <span class="claim-card__cite">{cite}</span>
    <span class="claim-card__evidence">{claim.evidenceLabel}</span>
  </div>
</a>

<style>
  .claim-card {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    padding: 1.25rem 1.35rem 1.2rem;
    background: var(--paper-1);
    border: 1px solid var(--rule-2);
    border-radius: 8px;
    text-decoration: none;
    color: inherit;
    transition:
      border-color 180ms var(--ease),
      transform 180ms var(--ease),
      box-shadow 180ms var(--ease),
      background 180ms var(--ease);
  }
  .claim-card:hover {
    border-color: color-mix(in oklab, var(--gold) 48%, var(--rule-3));
    transform: translateY(-2px);
    box-shadow: 0 6px 18px rgba(35, 43, 58, 0.06), 0 0 0 1px color-mix(in oklab, var(--gold) 20%, transparent);
  }
  .claim-card:focus-visible {
    outline: 2px solid var(--gold);
    outline-offset: 2px;
  }

  .claim-card__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }
  .claim-card__chips {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex-wrap: wrap;
    min-width: 0;
  }
  .claim-card__chip {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-2);
    padding: 3px 7px;
    border: 1px solid var(--rule-2);
    border-radius: 4px;
    background: var(--paper-0);
  }
  .claim-card__chip--contested {
    color: var(--cinnabar);
    border-color: color-mix(in oklab, var(--cinnabar) 32%, transparent);
    background: color-mix(in oklab, var(--cinnabar) 6%, var(--paper-0));
  }
  .claim-card__conf {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--ink-3);
    font-variant-numeric: tabular-nums;
    flex-shrink: 0;
  }
  .claim-card__conf-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--dot);
  }

  .claim-card__claim {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 1rem;
    line-height: 1.45;
    letter-spacing: -0.01em;
    color: var(--ink-0);
    margin: 0;
    text-wrap: pretty;
    flex: 1;
  }

  .claim-card__foot {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem;
    padding-top: 0.85rem;
    border-top: 1px solid var(--rule-1);
  }
  .claim-card__cite {
    font-family: var(--font-body);
    font-size: 0.78rem;
    color: var(--ink-3);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    min-width: 0;
  }
  .claim-card__evidence {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: color-mix(in oklab, var(--gold) 65%, var(--ink-3));
    flex-shrink: 0;
  }

  .claim-card--compact {
    padding: 1rem 1.1rem;
    gap: 0.7rem;
  }
  .claim-card--compact .claim-card__claim {
    font-size: 0.95rem;
  }
</style>
