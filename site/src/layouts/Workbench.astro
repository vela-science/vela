---
/*
  Workbench.astro — utility layout for tool surfaces (/workbench, etc.).

  Same masthead as the rest of the site (SiteNav with serif Vela
  wordmark + sail glyph) but body uses Inter for dense data UI.
  No watercolor, no rim, no signature line — just a tightened head
  with eyebrow + title + subtitle + aside slot, then a wide main
  area for tables, filters, viz.
*/

import "../styles/global.css";
import "../styles/reading.css";
import "../styles/workbench.css";
import SiteNav from "../components/SiteNav.astro";
import { VERSION } from "../config";

interface Props {
  title: string;
  description?: string;
  active?: string;
  eyebrow?: string;
  pageTitle: string;
  subtitle?: string;
  ogImage?: string;
}

const {
  title,
  description = "Vela workbench — live read-only view of the active frontier.",
  active,
  eyebrow,
  pageTitle,
  subtitle,
  ogImage = "/brand/og-image.png",
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const fullTitle = title.includes("Vela") ? title : `${title} · Vela`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="version" content={VERSION} />
    <link rel="canonical" href={canonical} />

    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />

    <link rel="icon" type="image/svg+xml" href="/brand/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
    />
  </head>
  <body class="vw-body">
    <a href="#main" class="skip-link">Skip to content</a>
    <SiteNav active={active} />

    <div class="vw-shell">
      <header class="vw-head">
        <div class="vw-head__text">
          {eyebrow && <p class="vw-head__eyebrow">{eyebrow}</p>}
          <h1 class="vw-head__title">{pageTitle}</h1>
          {subtitle && <p class="vw-head__sub">{subtitle}</p>}
        </div>
        <div class="vw-head__aside">
          <slot name="aside" />
        </div>
      </header>

      <main id="main" class="vw-main">
        <slot />
      </main>
    </div>

    <style>
      .vw-body { min-height: 100vh; font-family: var(--font-sans); }
      .skip-link {
        position: absolute; left: 1rem; top: 1rem; z-index: 60;
        padding: 0.5rem 0.75rem; border-radius: 9999px;
        background: var(--paper-1); border: 1px solid var(--ink-4);
        color: var(--ink-1);
        transform: translateY(-200%); transition: transform 0.15s ease;
      }
      .skip-link:focus { transform: translateY(0); outline: 2px solid var(--gold); outline-offset: 2px; }

      .vw-shell {
        max-width: calc(var(--measure-page) + (var(--container-px) * 2));
        margin: 0 auto;
        padding: clamp(1.5rem, 4vh, 2.5rem) var(--container-px) clamp(2.5rem, 6vh, 4rem);
      }

      .vw-head {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        gap: 1.5rem;
        margin-bottom: clamp(1.5rem, 3vh, 2.4rem);
        padding-bottom: 1rem;
        border-bottom: 1px solid color-mix(in oklab, var(--gold) 32%, transparent);
        flex-wrap: wrap;
      }
      .vw-head__text { flex: 1; min-width: 0; }
      .vw-head__eyebrow {
        margin: 0 0 0.55rem;
        font-family: var(--font-mono);
        font-size: 0.7rem;
        font-weight: 500;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: color-mix(in oklab, var(--gold) 78%, var(--ink-2));
      }
      .vw-head__title {
        margin: 0;
        font-family: var(--font-display);
        font-weight: 450;
        font-size: clamp(1.7rem, 3vw, 2.4rem);
        line-height: 1.06;
        letter-spacing: -0.018em;
        color: var(--ink-0);
        text-wrap: balance;
        font-variation-settings: "opsz" 96, "SOFT" 30;
      }
      .vw-head__sub {
        margin: 0.6rem 0 0;
        font-family: var(--font-sans);
        font-size: 0.95rem;
        line-height: 1.5;
        color: var(--ink-2);
        max-width: 64ch;
        text-wrap: pretty;
      }
      .vw-head__aside {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        flex-shrink: 0;
      }

      .vw-main { font-family: var(--font-sans); }
    </style>
  </body>
</html>
