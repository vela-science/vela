---
/*
  Topic-first homepage — the live state of the Alzheimer's
  Therapeutics frontier.

  Doctrine: a researcher who has never heard of Vela should land here
  and within 5 seconds say "this is the live state of Alzheimer's
  research, signed and updated weekly." The protocol underneath is a
  second-class citizen; the body of knowledge is the front.

  This page renders against the canonical frontier read from disk at
  build time (see lib/frontier.ts). When the frontier grows, this
  page grows with it; no template changes needed.
*/

import Page from "../layouts/Page.astro";
import ClaimCard from "../components/ClaimCard.astro";
import ImagePlate from "../components/ImagePlate.astro";
import HeroConstellation from "../components/HeroConstellation.astro";
import {
  loadFrontier,
  frontierStats,
  contradictions,
  activeWeeks,
  replicationStats,
  loadDatasets,
  loadCodeArtifacts,
  loadPredictions,
  loadResolutions,
  TARGETS,
  type ClaimView,
} from "../lib/frontier";
import { FRONTIER, REPO_URL, HUB_URL, VERSION } from "../config";

const claims = loadFrontier();
const stats = frontierStats();
const tensionList = contradictions();
const repStats = replicationStats();
const datasets = loadDatasets();
const codeArtifacts = loadCodeArtifacts();
const predictions = loadPredictions();
const resolutions = loadResolutions();

/* Above-the-fold: featured claims, sorted by confidence so the
   strongest signals lead. Cap at 12 so the page stays scannable. */
const featured: ClaimView[] = claims
  .slice() // don't mutate cache
  .sort((a, b) => b.finding.confidence.score - a.finding.confidence.score)
  .slice(0, 12);

/* Recent activity — the most recently created findings. Will become
   "this week" once weekly diff machinery lands in v0.32. */
const recent: ClaimView[] = claims.slice(0, 5);

/* Mini-constellation source — the top-confidence claims feed the
   build-time star chart rendered by <HeroConstellation />. */
const constellationClaims = claims
  .slice()
  .sort((a, b) => b.finding.confidence.score - a.finding.confidence.score)
  .slice(0, 28);

/* Latest weekly diff (link target for the recent panel). */
const weeks = activeWeeks();
const latestWeek = weeks[0];

/* Target → count map for the filter rail and topic links. */
const targetsWithCounts = TARGETS.map((t) => ({
  ...t,
  count: claims.filter((c) => c.targets.includes(t.slug)).length,
})).filter((t) => t.count > 0);

const lastUpdated = stats.lastUpdated
  ? new Date(stats.lastUpdated).toISOString().slice(0, 10)
  : "—";
---

<Page
  title={`${FRONTIER.name} · live frontier`}
  description={FRONTIER.description}
  active="home"
  eyebrow="Live frontier · Alzheimer's"
  pageTitle={FRONTIER.name}
  subtitle={FRONTIER.description}
>
  <div slot="aside">
    <a href="/protocol" class="aside-link">protocol</a>
    <span>·</span>
    <a href={REPO_URL} class="aside-link">github</a>
    <span>·</span>
    <a href={HUB_URL} class="aside-link">hub</a>
    <span class="aside-version" title={`Vela ${VERSION}`}>v{VERSION}</span>
  </div>

  <!-- ── Hero: one painted plate + one italic hook ── -->
  <section class="hero" aria-label="What this is">
    <ImagePlate
      fallback="/images/plates/frontier.png"
      width={1916}
      height={821}
      alt="A quiet watercolor cross-section beneath a horizon, with faint navy and gold stars forming above structured records below."
    />
    <p class="hero__hook">
      <em>The live state of one scientific question, signed and replayable.</em>
    </p>
    <p class="hero__sub">
      Every claim below is a content-addressed object. Every correction is an event.
      Two machines compute the same hash from the same frontier, or one of them is wrong.
    </p>

    <figure class="hero__constellation">
      <HeroConstellation claims={constellationClaims} />
      <p class="hero__constellation-caption" data-hero-tip>
        {constellationClaims.length} claims, top-confidence first. Hover any node — click to read the evidence.
        <a class="hero__constellation-link" href="/workbench">Open the workbench →</a>
      </p>
    </figure>

    <nav class="hero__paths" aria-label="See the substrate work">
      <a class="hero__path" href="/proof/pericyte-correction">
        <span class="hero__path-kicker">Watch one</span>
        <span class="hero__path-label">Correction event land →</span>
      </a>
      <a class="hero__path" href="/replay">
        <span class="hero__path-kicker">Drag through</span>
        <span class="hero__path-label">14 signed events →</span>
      </a>
      <a class="hero__path" href="/protocol">
        <span class="hero__path-kicker">Read</span>
        <span class="hero__path-label">the four-noun protocol →</span>
      </a>
    </nav>
  </section>

  <!-- ── Frontier readout — the masthead's instrument bar ── -->
  <div class="frontier-readout" aria-label="Frontier statistics">
    <div class="frontier-readout__stat">
      <span class="frontier-readout__num">{stats.claims}</span>
      <span class="frontier-readout__label">claims</span>
    </div>
    <div class="frontier-readout__stat">
      <span class="frontier-readout__num">{stats.papers}</span>
      <span class="frontier-readout__label">papers</span>
    </div>
    <div class="frontier-readout__stat">
      <span class="frontier-readout__num">{stats.contradictions}</span>
      <span class="frontier-readout__label">contradictions</span>
    </div>
    <div class="frontier-readout__stat">
      <span class="frontier-readout__num">{repStats.total}</span>
      <span class="frontier-readout__label">replications</span>
    </div>
    <div class="frontier-readout__stat">
      <a class="frontier-readout__link" href="/datasets">
        <span class="frontier-readout__num">{datasets.length}</span>
        <span class="frontier-readout__label">datasets</span>
      </a>
    </div>
    <div class="frontier-readout__stat">
      <a class="frontier-readout__link" href="/code">
        <span class="frontier-readout__num">{codeArtifacts.length}</span>
        <span class="frontier-readout__label">code</span>
      </a>
    </div>
    <div class="frontier-readout__stat">
      <a class="frontier-readout__link" href="/predictions">
        <span class="frontier-readout__num">{predictions.length}</span>
        <span class="frontier-readout__label">predictions</span>
      </a>
    </div>
    <div class="frontier-readout__stat">
      <span class="frontier-readout__num frontier-readout__num--small">{lastUpdated}</span>
      <span class="frontier-readout__label">last signed</span>
    </div>
  </div>

  <!-- ── Filter rail — drug targets, with counts ── -->
  <nav class="target-rail" aria-label="Browse by target">
    <span class="target-rail__label">Targets</span>
    {targetsWithCounts.map((t) => (
      <a class="target-rail__chip" href={`/targets/${t.slug}`}>
        {t.short}
        <span class="target-rail__count">{t.count}</span>
      </a>
    ))}
  </nav>

  <!-- ── Above the fold: the claims themselves ── -->
  <section class="frontier-claims" aria-label="Featured claims">
    <header class="frontier-claims__head">
      <h2 class="frontier-claims__title">Strongest claims, by confidence</h2>
      <p class="frontier-claims__sub">
        Each card is a content-addressed finding signed into the frontier. Click any to read the evidence.
      </p>
    </header>
    <div class="frontier-claims__list">
      {featured.map((c) => <ClaimCard claim={c} />)}
    </div>
    {claims.length > featured.length && (
      <p class="frontier-claims__more">
        <a class="inline-link" href="/protocol#full">{claims.length - featured.length} more — see the workbench</a>
      </p>
    )}
  </section>

  <!-- ── Sidebar pieces — recent + contradictions + how-it-stays-honest ── -->
  <div class="frontier-secondary">
    <aside class="frontier-recent">
      <h2 class="frontier-recent__title">Most recently added</h2>
      <ol class="frontier-recent__list">
        {recent.map((c) => (
          <li class="frontier-recent__item">
            <a class="frontier-recent__link" href={`/claims/${c.slug}`}>
              <span class="frontier-recent__claim">{c.finding.assertion.text}</span>
              <span class="frontier-recent__meta">
                {new Date(c.finding.created).toISOString().slice(0, 10)} · {c.evidenceLabel}
              </span>
            </a>
          </li>
        ))}
      </ol>
      <p class="frontier-recent__note">
        {latestWeek ? (
          <>
            <a class="inline-link" href={`/frontier/${latestWeek.key}`}>
              See the {latestWeek.key} diff →
            </a>
          </>
        ) : (
          <>Weekly diffs ship soon. <a class="inline-link" href="/protocol">How the frontier stays honest →</a></>
        )}
      </p>
    </aside>

    {tensionList.length > 0 && (
      <aside class="frontier-tensions">
        <h2 class="frontier-tensions__title">Open contradictions</h2>
        <ol class="frontier-tensions__list">
          {tensionList.slice(0, 5).map((c) => (
            <li class="frontier-tensions__item">
              <a class="frontier-tensions__link" href={`/claims/${c.slug}`}>
                {c.finding.assertion.text}
              </a>
            </li>
          ))}
        </ol>
      </aside>
    )}
  </div>

  <!-- ── Build on this — the developer affordance ── -->
  <section class="build" aria-label="Build on this">
    <header class="build__head">
      <span class="build__kicker">Build on this</span>
      <h2 class="build__title">One binary. One open hub. Query it now.</h2>
    </header>
    <div class="build__cols">
      <div class="build__col">
        <div class="build__col-head">
          <span class="build__col-tag">$ run locally</span>
          <span class="build__col-aside">~60 seconds</span>
        </div>
        <pre class="build__code"><code><span class="tm-ps">$</span> <span class="tm-cmd">git clone</span> {REPO_URL}
<span class="tm-ps">$</span> <span class="tm-cmd">cd</span> vela <span class="tm-ps">&&</span> <span class="tm-cmd">cargo build</span> <span class="tm-flag">--release</span>
<span class="tm-ps">$</span> ./target/release/vela <span class="tm-cmd">frontier compile</span> ./papers
<span class="tm-ps">$</span> ./target/release/vela <span class="tm-cmd">serve --workbench</span></code></pre>
        <p class="build__caption">A signed, content-addressed frontier from a folder of papers in four commands.</p>
      </div>
      <div class="build__col">
        <div class="build__col-head">
          <span class="build__col-tag">$ query the live hub</span>
          <span class="build__col-aside">no auth, CORS open</span>
        </div>
        <pre class="build__code"><code><span class="tm-ps">$</span> <span class="tm-cmd">curl</span> {HUB_URL}/entries \
    <span class="tm-flag">-H</span> <span class="tm-str">"accept: application/json"</span>
{`
# {"entries":[
#   {"vfr_id":"vfr_bd91…","name":"Alzheimer's Therapeutics",
#    "owner_actor_id":"reviewer:will-blair",
#    "signed_publish_at":"2026-04-27T18:32:01Z",
#    "snapshot_hash":"f23b4aba17…"}, …]}`}</code></pre>
        <p class="build__caption">
          Every entry is a signed manifest pointing at a frontier file. Pull, verify, replay.
          <a class="inline-link" href={`${HUB_URL}/entries`} rel="noopener">Browse the hub →</a>
        </p>
      </div>
    </div>
  </section>

  <!-- ── How this stays honest — the protocol entry, second-class ── -->
  <aside class="frontier-honest">
    <div class="frontier-honest__eyebrow">How this stays honest</div>
    <p class="frontier-honest__body">
      Every claim above is content-addressed, agent-proposed, human-reviewed, and Ed25519-signed.
      The same frontier on two machines reduces to the same hash. Retractions land as new events,
      not deletions. Contradictions are first-class objects, not lost arguments. Vela is the
      substrate; this page is what the substrate holds.
    </p>
    <p class="frontier-honest__more">
      <a class="inline-link" href="/protocol">Read the protocol →</a>
      <span class="frontier-honest__sep">·</span>
      <a class="inline-link" href="/workbench">Open the workbench →</a>
      <span class="frontier-honest__sep">·</span>
      <a class="inline-link" href="/essays/science-needs-state">Read the essay →</a>
    </p>
  </aside>

  <script>
    /* Hero constellation hover wiring. Build-time SVG; this just
       writes the hovered node's claim into the caption strip. */
    (function () {
      var tip = document.querySelector("[data-hero-tip]");
      var nodes = document.querySelectorAll(".hc-node");
      if (!tip || nodes.length === 0) return;
      var original = tip.innerHTML;
      nodes.forEach(function (n) {
        var write = function () {
          var claim = n.getAttribute("data-claim") || "";
          tip.innerHTML =
            '<span class="hero__constellation-quote">' + claim + "</span>";
        };
        var reset = function () {
          tip.innerHTML = original;
        };
        n.addEventListener("mouseenter", write);
        n.addEventListener("mouseleave", reset);
        n.addEventListener("focus", write);
        n.addEventListener("blur", reset);
      });
    })();
  </script>

  <!-- ── Quiet closing imprint ── -->
  <footer class="home-imprint" role="contentinfo">
    <span class="home-imprint__rule" aria-hidden="true"></span>
    <p class="home-imprint__lines">
      <a href="/lineage" class="home-imprint__link">Why this exists, named once →</a>
      <span class="home-imprint__sep">·</span>
      <a href="https://borrowedlight.org" rel="noopener" class="home-imprint__link">Borrowed Light, the essay →</a>
    </p>
    <p class="home-imprint__mark">for M.</p>
  </footer>
</Page>

<style>
  /* ── Hero: painted plate + italic Cormorant hook ──
     Single visible element above the data. The plate sets atmosphere,
     the italic line tells you what you're looking at, the sub line
     answers "why should I believe it" — all in two sentences. */
  .hero {
    margin: 0 0 var(--space-7);
    text-wrap: pretty;
  }
  .hero :global(.vela-image-plate) {
    margin-top: 0;
    margin-bottom: 1.4rem;
  }
  .hero__hook {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: clamp(1.45rem, 2.6vw, 1.95rem);
    line-height: 1.32;
    letter-spacing: var(--track-display);
    color: var(--ink-0);
    margin: 0 0 0.85rem;
    max-width: 44ch;
    text-wrap: balance;
  }
  .hero__hook em { font-style: italic; }
  .hero__sub {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 1rem;
    line-height: 1.55;
    letter-spacing: -0.005em;
    color: color-mix(in oklab, var(--ink-2) 92%, transparent);
    margin: 0;
    max-width: 60ch;
  }
  /* ── Hero mini-constellation ──
     Frame around the <HeroConstellation /> component. The SVG itself
     and the .hc-* node/dot/glow CSS live in the component. */
  .hero__constellation {
    margin: 1.4rem 0 0;
    padding: 0;
    background: var(--paper-1);
    border-top: 1px solid color-mix(in oklab, var(--gold) 28%, transparent);
    border-bottom: 1px solid var(--rule-2);
    overflow: hidden;
  }
  .hero__constellation-caption {
    margin: 0;
    padding: 10px 16px 12px;
    border-top: 1px solid var(--rule-1);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.04em;
    color: color-mix(in oklab, var(--ink-3) 92%, transparent);
    background: transparent;
    text-wrap: pretty;
    min-height: 1.4em;
  }
  .hero__constellation-link {
    margin-left: 8px;
    color: var(--ink-1);
    text-decoration: underline;
    text-decoration-color: color-mix(in oklab, var(--gold) 56%, transparent);
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
    transition: color var(--dur-1) var(--ease), text-decoration-color var(--dur-1) var(--ease);
  }
  .hero__constellation-link:hover {
    color: var(--gold);
    text-decoration-color: var(--gold);
  }
  .hero__constellation-quote {
    font-family: var(--font-body);
    font-style: italic;
    font-size: 12px;
    color: var(--ink-1);
    letter-spacing: 0;
    text-transform: none;
  }
  @media (max-width: 720px) {
    .hero__svg { max-height: 200px; }
    .hero__constellation-caption { font-size: 10px; padding: 8px 12px 10px; }
  }

  /* ── Hero proof affordances ──
     Three quiet routes into the substrate, surfaced right under the
     hook so a skeptic who scrolled the data doesn't have to know
     the URLs by heart. */
  .hero__paths {
    margin: 1.85rem 0 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    border-top: 1px solid color-mix(in oklab, var(--gold) 28%, transparent);
    border-bottom: 1px solid var(--rule-2);
  }
  .hero__path {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 0.95rem 1.2rem 1rem 0;
    text-decoration: none;
    color: var(--ink-1);
    border-right: 1px solid var(--rule-1);
    transition: color var(--dur-1) var(--ease), background var(--dur-1) var(--ease);
  }
  .hero__path:last-child { border-right: 0; }
  .hero__path:hover { color: var(--gold); background: color-mix(in oklab, var(--gold) 5%, transparent); }
  .hero__path-kicker {
    font-family: var(--font-mono);
    font-size: var(--size-kicker);
    letter-spacing: var(--track-imprint);
    text-transform: uppercase;
    color: color-mix(in oklab, var(--gold) 72%, var(--ink-3));
  }
  .hero__path-label {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.98rem;
    letter-spacing: -0.012em;
    color: inherit;
  }

  @media (max-width: 720px) {
    .hero { margin-bottom: var(--space-6); }
    .hero__hook { font-size: 1.35rem; }
    .hero__paths { grid-template-columns: 1fr; }
    .hero__path {
      border-right: 0;
      border-bottom: 1px solid var(--rule-1);
      padding: 0.85rem 0;
    }
    .hero__path:last-child { border-bottom: 0; }
  }

  .aside-link {
    font-family: var(--font-mono);
    font-size: var(--size-xs);
    letter-spacing: 0.06em;
    color: var(--ink-3);
  }
  .aside-link:hover { color: var(--ink-0); }
  .aside-version {
    font-family: var(--font-mono);
    font-size: var(--size-xs);
    letter-spacing: 0.06em;
    color: var(--ink-4);
    margin-left: 6px;
  }
  div[slot="aside"] {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .inline-link {
    color: var(--ink-1);
    text-decoration: underline;
    text-decoration-color: color-mix(in oklab, var(--gold) 56%, transparent);
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
    transition: color var(--dur-1) var(--ease), text-decoration-color var(--dur-1) var(--ease);
  }
  .inline-link:hover {
    color: var(--gold);
    text-decoration-color: var(--gold);
  }

  /* ── Frontier readout — instrument bar under the masthead ──
     v0.32 added replications. v0.33 added datasets + code. v0.34
     added predictions. The bar shows eight numbers on desktop and
     wraps responsively. */
  .frontier-readout {
    display: grid;
    grid-template-columns: repeat(8, 1fr);
    gap: 0;
    border-top: 1px solid var(--rule-2);
    border-bottom: 1px solid var(--rule-2);
    margin: 0 0 var(--space-6);
  }
  .frontier-readout__link {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    gap: 4px;
    transition: color var(--dur-1) var(--ease);
  }
  .frontier-readout__link:hover { color: var(--signal); }
  .frontier-readout__stat {
    padding: var(--space-4) var(--space-5);
    display: flex;
    flex-direction: column;
    gap: 4px;
    border-right: 1px solid var(--rule-1);
  }
  .frontier-readout__stat:last-child { border-right: none; }
  .frontier-readout__num {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: clamp(1.6rem, 2.8vw, 2rem);
    line-height: 1;
    color: var(--ink-0);
    font-variant-numeric: tabular-nums;
    letter-spacing: -0.02em;
  }
  .frontier-readout__num--small {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 400;
    letter-spacing: 0.02em;
  }
  .frontier-readout__label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: color-mix(in oklab, var(--ink-3) 92%, transparent);
  }
  /* ── Target rail — chips of drug targets, with counts ── */
  .target-rail {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin: 0 0 var(--space-5);
    padding: var(--space-3) 0;
  }
  .target-rail__label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: var(--track-label);
    text-transform: uppercase;
    color: var(--ink-3);
    margin-right: var(--space-2);
  }
  .target-rail__chip {
    display: inline-flex;
    align-items: baseline;
    gap: 6px;
    padding: 6px 12px;
    border: 1px solid var(--rule-2);
    border-radius: var(--radius-sm);
    font-family: var(--font-sans);
    font-size: 12px;
    color: var(--ink-1);
    text-decoration: none;
    background: transparent;
    transition: color var(--dur-1) var(--ease), border-color var(--dur-1) var(--ease), background var(--dur-1) var(--ease);
  }
  .target-rail__chip:hover {
    border-color: color-mix(in oklab, var(--gold) 56%, transparent);
    background: var(--paper-1);
    color: var(--ink-0);
  }
  .target-rail__count {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--ink-3);
    font-variant-numeric: tabular-nums;
  }

  /* ── Frontier claims — above the fold ── */
  .frontier-claims {
    margin: 0 0 var(--space-7);
  }
  .frontier-claims__head {
    margin-bottom: var(--space-4);
  }
  .frontier-claims__title {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: clamp(1.15rem, 2.2vw, 1.45rem);
    line-height: 1.16;
    color: var(--ink-0);
    margin: 0 0 6px;
    letter-spacing: -0.018em;
    text-wrap: balance;
  }
  .frontier-claims__sub {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 0.95rem;
    line-height: 1.5;
    letter-spacing: -0.005em;
    color: color-mix(in oklab, var(--ink-2) 92%, transparent);
    margin: 0;
    max-width: 60ch;
    text-wrap: pretty;
  }
  .frontier-claims__list {
    border-top: 1px solid var(--rule-2);
  }
  .frontier-claims__more {
    margin: var(--space-4) 0 0;
    font-family: var(--font-mono);
