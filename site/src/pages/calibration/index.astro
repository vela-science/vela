---
/*
  Calibration leaderboard.

  Every actor with at least one prediction gets a row. Sorted by Brier
  score ascending (lower is better). Resolved-only count is the
  numerator of the Brier denominator; expired predictions show the
  predictor's evasion-of-resolution rate without moving their score.

  This is one of the L4 applications the architecture doc names: a
  public, reproducible track record of how often each actor's stated
  beliefs matched reality. Forecaster's GitHub contribution graph,
  but for scientific predictions.
*/

import Page from "../../layouts/Page.astro";
import { calibrationRecords } from "../../lib/frontier";
import { FRONTIER, REPO_URL, VERSION } from "../../config";

const records = calibrationRecords();

// Rank by Brier ascending. Records without resolutions sink to the
// bottom (they have no Brier to rank by).
const ranked = [...records].sort((a, b) => {
  if (a.brier_score == null && b.brier_score == null) return 0;
  if (a.brier_score == null) return 1;
  if (b.brier_score == null) return -1;
  return a.brier_score - b.brier_score;
});

function fmt(n: number | null | undefined, digits = 3): string {
  if (n == null) return "—";
  return n.toFixed(digits);
}

function fmtPct(n: number | null | undefined): string {
  if (n == null) return "—";
  return `${(n * 100).toFixed(0)}%`;
}

const totalActors = ranked.length;
const totalPredictions = ranked.reduce((sum, r) => sum + r.n_predictions, 0);
const totalResolved = ranked.reduce((sum, r) => sum + r.n_resolved, 0);
const totalExpired = ranked.reduce((sum, r) => sum + (r.n_expired ?? 0), 0);
---

<Page
  title={`Calibration leaderboard · ${FRONTIER.name}`}
  description="Per-actor calibration: Brier, log score, hit rate, and the public track record of how often stated beliefs matched reality."
  active=""
  eyebrow="Calibration"
  pageTitle="Calibration leaderboard"
  subtitle="Public, reproducible record of how often each actor's predictions matched reality."
>
  <div slot="aside">
    <a href="/" class="aside-link">frontier</a>
    <span>·</span>
    <a href="/predictions" class="aside-link">predictions</a>
    <span>·</span>
    <a href={REPO_URL} class="aside-link">github</a>
    <span class="aside-version">v{VERSION}</span>
  </div>

  <aside class="cal-doctrine">
    <div class="cal-doctrine__eyebrow">How this works</div>
    <p class="cal-doctrine__body">
      Every prediction is a content-addressed <code>vpred_</code> record signed by an
      actor, scoped to specific findings, with a resolution criterion and a deadline.
      When a resolution lands (or the deadline expires), the substrate updates the
      predictor's calibration record. Brier score is the mean squared deviation between
      the predicted probability and the actual outcome (lower is better; 0 is perfect,
      0.25 is chance-level for binary predictions).
    </p>
    <p class="cal-doctrine__body">
      Expired predictions count toward <code>n_expired</code> but do not move the Brier
      score. A predictor with high <code>n_predictions</code> and low <code>n_resolved</code>
      but high <code>n_expired</code> is visibly evading calibration even when the
      resolved subset looks fine.
    </p>
  </aside>

  <section class="cal-summary">
    <div class="cal-stat">
      <div class="cal-stat__num">{totalActors}</div>
      <div class="cal-stat__lbl">actors</div>
    </div>
    <div class="cal-stat">
      <div class="cal-stat__num">{totalPredictions}</div>
      <div class="cal-stat__lbl">predictions</div>
    </div>
    <div class="cal-stat">
      <div class="cal-stat__num">{totalResolved}</div>
      <div class="cal-stat__lbl">resolved</div>
    </div>
    <div class="cal-stat">
      <div class="cal-stat__num">{totalExpired}</div>
      <div class="cal-stat__lbl">expired</div>
    </div>
  </section>

  {ranked.length === 0 ? (
    <p class="cal-empty">
      No predictions yet. The substrate has the schema and the runtime; the ledger fills
      in as actors record predictions and outcomes.
    </p>
  ) : (
    <section class="cal-section">
      <table class="cal-table">
        <thead>
          <tr>
            <th class="cal-table__rank">#</th>
            <th>Actor</th>
            <th class="cal-table__num">Predictions</th>
            <th class="cal-table__num">Resolved</th>
            <th class="cal-table__num">Expired</th>
            <th class="cal-table__num">Hit rate</th>
            <th class="cal-table__num cal-table__primary">Brier</th>
            <th class="cal-table__num">Log score</th>
          </tr>
        </thead>
        <tbody>
          {ranked.map((r, i) => (
            <tr class="cal-row">
              <td class="cal-table__rank">{r.brier_score == null ? "—" : i + 1}</td>
              <td>
                <a href={`/actors/${encodeURIComponent(r.actor)}`} class="cal-row__actor">
                  {r.actor}
                </a>
              </td>
              <td class="cal-table__num">{r.n_predictions}</td>
              <td class="cal-table__num">{r.n_resolved}</td>
              <td class="cal-table__num">{r.n_expired ?? 0}</td>
              <td class="cal-table__num">{fmtPct(r.hit_rate)}</td>
              <td class="cal-table__num cal-table__primary">{fmt(r.brier_score)}</td>
              <td class="cal-table__num">{fmt(r.log_score)}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>
  )}

  <section class="cal-section">
    <h2 class="cal-section__title">Reading the table</h2>
    <p class="cal-section__sub">
      Brier is the headline. Lower is better; 0 is perfect; 0.25 is chance-level for
      well-calibrated binary predictions; 1.0 is maximally wrong. Click an actor to see
      their full prediction history including the reliability diagram (predicted
      probability vs. observed match rate, bucketed in five bands of width 0.2).
    </p>
    <p class="cal-section__sub">
      The pattern that surfaces in real use: predictors who under-report confidence
      ("0.5 on everything") cluster near 0.25; predictors who pick the right side and
      mean it cluster below 0.10; predictors whose confidence runs ahead of their
      evidence cluster above 0.30.
    </p>
  </section>
</Page>

<style>
  .cal-doctrine {
    border: 1px solid var(--rule-2, #d8d4cc);
    background: var(--bg-2, #f5f2ec);
    padding: 1rem 1.25rem;
    margin: 0 0 1.5rem 0;
    font-size: 0.92rem;
    line-height: 1.55;
  }
  .cal-doctrine__eyebrow {
    font-size: 0.74rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-2, #6b665d);
    margin-bottom: 0.4rem;
  }
  .cal-doctrine__body {
    margin: 0 0 0.6rem 0;
  }
  .cal-doctrine__body:last-child { margin-bottom: 0; }
  .cal-doctrine code {
    background: var(--bg-3, #ebe6dd);
    padding: 0.05em 0.3em;
    border-radius: 2px;
    font-size: 0.88em;
  }

  .cal-summary {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.75rem;
    margin: 0 0 2rem 0;
  }
  .cal-stat {
    border: 1px solid var(--rule-2, #d8d4cc);
    padding: 0.85rem 1rem;
    background: var(--bg-1, #fafaf6);
  }
  .cal-stat__num {
    font-size: 2rem;
    font-weight: 300;
    line-height: 1;
    margin-bottom: 0.3rem;
  }
  .cal-stat__lbl {
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-2, #6b665d);
  }

  .cal-empty {
    border: 1px dashed var(--rule-2, #d8d4cc);
    padding: 1.5rem;
    text-align: center;
    color: var(--ink-2, #6b665d);
    font-size: 0.95rem;
    line-height: 1.55;
  }
  .cal-empty code {
    background: var(--bg-2, #f5f2ec);
    padding: 0.05em 0.3em;
    border-radius: 2px;
  }

  .cal-section { margin: 0 0 2.5rem 0; }
  .cal-section__title {
    font-size: 1rem;
    font-weight: 500;
    margin: 0 0 0.6rem 0;
  }
  .cal-section__sub {
    font-size: 0.92rem;
    color: var(--ink-2, #6b665d);
    line-height: 1.55;
    margin: 0 0 0.7rem 0;
  }

  .cal-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
  }
  .cal-table th {
    text-align: left;
    border-bottom: 1px solid var(--rule-2, #d8d4cc);
    padding: 0.55rem 0.75rem;
    font-weight: 500;
    color: var(--ink-2, #6b665d);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .cal-table td {
    padding: 0.55rem 0.75rem;
    border-bottom: 1px solid var(--rule-2, #d8d4cc);
  }
  .cal-table__num { text-align: right; font-variant-numeric: tabular-nums; }
  .cal-table__primary { font-weight: 500; }
  .cal-table__rank {
    width: 3rem;
    color: var(--ink-2, #6b665d);
    font-variant-numeric: tabular-nums;
  }
  .cal-row__actor {
    color: var(--ink-1, #2a2a2a);
    text-decoration: none;
    border-bottom: 1px solid var(--rule-3, #c8c2b5);
    font-family: var(--font-mono, monospace);
    font-size: 0.88rem;
  }
  .cal-row__actor:hover { border-bottom-color: var(--ink-1, #2a2a2a); }
</style>
