    color: var(--ink-1);
  }
  @media (max-width: 720px) {
    .fr-coda { margin: 28px 0 8px; padding-top: 18px; }
    .fr-coda__lantern { width: 24px; height: 36px; }
    .fr-coda__title { font-size: 15px; }
