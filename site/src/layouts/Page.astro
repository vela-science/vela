---
/*
  Page.astro — backward-compat shim over Reading.astro.

  Old API (eyebrow / pageTitle / subtitle / aside slot) is preserved
  so the 20-odd pages that import Page get the new brand-aligned
  Reading layout (SiteNav with serif Vela wordmark + sail glyph,
  cream paper, Fraunces serif page-head) without per-page edits.
  New work should import Reading directly and write its own
  <header class="page-head"> markup.
*/
import Reading from "./Reading.astro";

interface Props {
  title: string;
  description?: string;
  active?: string;
  eyebrow?: string;
  pageTitle: string;
  subtitle?: string;
  ogImage?: string;
  /* Optional: pages that need wide content (claim grids, etc.) */
  wide?: boolean;
}

const {
  title,
  description,
  active,
  eyebrow,
  pageTitle,
  subtitle,
  ogImage,
  wide = false,
} = Astro.props;
---

<Reading
  title={title}
  description={description}
  active={active}
  ogImage={ogImage}
  wide={wide}
>
  <header class="page-head">
    {eyebrow && <p class="eyebrow page-head__eyebrow">{eyebrow}</p>}
    <h1 class="page-head__title">{pageTitle}</h1>
    {subtitle && <p class="page-head__sub">{subtitle}</p>}
    <div class="page-head__aside"><slot name="aside" /></div>
  </header>

  <slot />
</Reading>

<style>
  .page-head__eyebrow { display: block; margin: 0 0 1rem; }
  .page-head__aside {
    margin-top: 1.4rem;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  .page-head__aside:empty { display: none; }
</style>
