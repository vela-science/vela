---
/*
  /lineage — quiet imprint, action register.

  Vela is the working substrate; the essay carries the wound. This
  page is a one-screen mark, not a re-telling. Everything that wants
  to be read in prose lives at borrowedlight.org.
*/
import Reading from "../layouts/Reading.astro";
import { BORROWED_LIGHT_URL } from "../config";
---

<Reading
  title="Lineage · Vela"
  description="Why this exists, named once."
  active="lineage"
>
  <article class="lineage">
    <p class="lineage__hook">
      <em>Everything you learn, you pass on.</em>
    </p>
    <p class="lineage__attr">— Misha · 1997 – 2025</p>

    <p class="lineage__line">
      The argument lives in the essay at
      <a href={BORROWED_LIGHT_URL} rel="noopener" class="lineage__link">borrowedlight.org</a>.
      The substrate is here. Every Finding, Constellation, and signed Correction in this
      site is built so the next person does not have to wait twelve doctors.
    </p>

    <div class="lineage__imprint" role="contentinfo">
      <span class="lineage__rule" aria-hidden="true"></span>
      <p class="lineage__mark">for M.</p>
    </div>
  </article>
</Reading>

<style>
  .aside-link {
    font-family: var(--font-mono);
    font-size: var(--size-imprint);
    letter-spacing: var(--track-imprint);
    text-transform: uppercase;
    color: var(--ink-3);
    border-bottom: 1px solid transparent;
    transition: color var(--dur-1) var(--ease), border-bottom-color var(--dur-1) var(--ease);
  }
  .aside-link:hover {
    color: var(--gold);
    border-bottom-color: color-mix(in oklab, var(--gold) 56%, transparent);
  }

  .lineage {
    max-width: var(--measure);
    margin: clamp(2rem, 6vh, 4rem) auto 0;
    padding: 0;
    text-align: center;
  }

  .lineage__hook {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(1.9rem, 4vw, 2.8rem);
    line-height: 1.08;
    letter-spacing: -0.02em;
    color: var(--ink-0);
    margin: 0 0 0.7rem;
    text-wrap: balance;
    font-variation-settings: "opsz" 144, "SOFT" 30;
  }
  .lineage__hook em { font-style: italic; }
  .lineage__attr {
    margin: 0 0 2.4rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: color-mix(in oklab, var(--gold) 76%, var(--ink-2));
  }
  .lineage__line {
    font-family: var(--font-sans);
    font-size: 1rem;
    line-height: 1.55;
    color: color-mix(in oklab, var(--ink-1) 88%, var(--ink-2));
    margin: 0 auto;
    max-width: 48ch;
    text-wrap: pretty;
    text-align: center;
  }
  .lineage__link {
    color: var(--ink-1);
    text-decoration: none;
    border-bottom: 1px solid color-mix(in oklab, var(--gold) 38%, transparent);
    transition: color var(--dur-1) var(--ease), border-bottom-color var(--dur-1) var(--ease);
  }
  .lineage__link:hover {
    color: var(--gold);
    border-bottom-color: var(--gold);
  }

  .lineage__imprint {
    margin-top: clamp(3rem, 8vh, 5rem);
    padding-top: 1.4rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.85rem;
  }
  .lineage__rule {
    display: block;
    width: 4rem;
    height: 1px;
    background: linear-gradient(
      to right,
      transparent 0%,
      color-mix(in oklab, var(--gold) 48%, transparent) 50%,
      transparent 100%
    );
  }
  .lineage__mark {
    margin: 0;
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: var(--size-imprint);
    letter-spacing: 0.34em;
    text-transform: uppercase;
    color: color-mix(in oklab, var(--gold) 72%, var(--ink-2));
  }
</style>
