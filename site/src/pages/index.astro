---
import Page from "../layouts/Page.astro";
import FrontierDirectory from "../components/FrontierDirectory.astro";
import TerminalPaper from "../components/TerminalPaper.astro";
import Chip from "../components/Chip.astro";
import { HUB_URL, REPO_URL, VERSION } from "../config";

const HUB_HOST = HUB_URL.replace(/^https?:\/\//, "");
---
<Page
  title="Vela · scientific frontier state, signed and replayable"
  description="A directory of public scientific frontiers — claims, evidence, conditions, and signatures, content-addressed and replayable. The git-native protocol for science."
  active="home"
  eyebrow="Vela"
  pageTitle="Vela"
  subtitle="A directory of public scientific frontiers — content-addressed, signed, replayable."
>
  <div slot="aside">
    <a href={REPO_URL} class="aside-link">github</a>
    <span>·</span>
    <a href={HUB_URL} class="aside-link">hub</a>
    <span>·</span>
    <Chip variant="live" label={`v${VERSION}`} />
  </div>

  <!-- The directory IS the page. Everything else is supporting context. -->
  <FrontierDirectory />

  <!-- Quickstart: install + publish, side-by-side. -->
  <section class="qs">
    <header class="qs__head">
      <span class="qs__eyebrow">Get started</span>
      <h2 class="qs__title">Publish your own frontier</h2>
      <p class="qs__sub">
        One Rust binary. Five commands. No allowlist, no gatekeeper — anyone with an Ed25519 key can publish their own <code>vfr_id</code>.
      </p>
    </header>
    <div class="qs__grid">
      <TerminalPaper title="install">
        <span class="tm-ps">$</span> <span class="tm-cmd">git clone</span> {REPO_URL}
<span class="tm-ps">$</span> <span class="tm-cmd">cd</span> vela <span class="tm-ps">&&</span> <span class="tm-cmd">cargo build</span> <span class="tm-flag">--release</span>
<span class="tm-ps">$</span> <span class="tm-cmd">./target/release/vela</span> <span class="tm-flag">--version</span>
      </TerminalPaper>
      <TerminalPaper title="publish">
        <span class="tm-ps">$</span> <span class="tm-cmd">vela frontier new</span> ./frontier.json <span class="tm-flag">--name</span> "Your bounded question"
<span class="tm-ps">$</span> <span class="tm-cmd">vela sign generate-keypair</span> <span class="tm-flag">--out</span> keys
<span class="tm-ps">$</span> <span class="tm-cmd">vela actor add</span> ./frontier.json reviewer:you <span class="tm-flag">--pubkey</span> "$(cat keys/public.key)"
<span class="tm-ps">$</span> <span class="tm-cmd">vela registry publish</span> ./frontier.json <span class="tm-flag">--owner</span> reviewer:you <span class="tm-flag">--key</span> keys/private.key <span class="tm-flag">--locator</span> &lt;url&gt; <span class="tm-flag">--to</span> {HUB_URL}
      </TerminalPaper>
    </div>
    <p class="qs__more">
      Full walk-through with cross-frontier composition and CI signing at <a class="inline-link" href="/publish">/publish</a>.
    </p>
  </section>

  <!-- Concepts: the six nouns, compact, scannable. -->
  <section class="cn">
    <header class="cn__head">
      <span class="cn__eyebrow">Concepts</span>
      <h2 class="cn__title">Six nouns</h2>
    </header>
    <div class="cn__grid">
      <article class="ct">
        <span class="ct__k">finding</span>
        <p class="ct__d">A typed assertion: what was observed, in what conditions, with what evidence, by whom, citing what. Content-addressed <code>vf_…</code> id.</p>
      </article>
      <article class="ct">
        <span class="ct__k">frontier</span>
        <p class="ct__d">A bounded scope holding findings, links, actors, and the event log that records every change. Content-addressed <code>vfr_…</code> id.</p>
      </article>
      <article class="ct">
        <span class="ct__k">proposal</span>
        <p class="ct__d">A signed change-request — revise, retract, contest, annotate. Becomes a canonical event when reviewed and accepted.</p>
      </article>
      <article class="ct">
        <span class="ct__k">event</span>
        <p class="ct__d">An immutable record in the log. Replay events on a fresh frontier and you reconstruct state byte-identically.</p>
      </article>
      <article class="ct">
        <span class="ct__k">registry</span>
        <p class="ct__d">A directory of signed manifests pointing at frontier publications. Anyone publishes; clients verify on read.</p>
      </article>
      <article class="ct">
        <span class="ct__k">proof packet</span>
        <p class="ct__d">A sealed snapshot another party can re-verify offline. Snapshot hash + event-log hash + signatures are the audit.</p>
      </article>
    </div>
  </section>

  <!-- Quiet "why" + essay link, last. -->
  <aside class="why">
    <div class="why__inner">
      <p class="why__text">
        Science publishes claims; it has no shared object for state. Two papers contradict each other and the disagreement lives in someone's head. A retraction reaches one lab and not the three depending on it. Vela is the smallest substrate that holds: a finding has a content-addressed id, a frontier has a content-addressed id, two implementations agree byte-for-byte, the signature is the bind.
      </p>
      <a class="why__link" href="/essays/science-needs-state">Read the essay →</a>
    </div>
  </aside>
</Page>

<style>
  .aside-link {
    font-family: var(--font-mono);
    font-size: var(--size-xs);
    letter-spacing: 0.06em;
    color: var(--ink-3);
  }
  .aside-link:hover { color: var(--ink-0); }
  div[slot="aside"] {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  /* === Quickstart === */
  .qs { margin: 0 0 56px; }
  .qs__head { margin-bottom: 18px; padding-bottom: 14px; border-bottom: 1px solid var(--rule-2); }
  .qs__eyebrow {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-3);
  }
  .qs__title {
    font-family: var(--font-serif);
    font-size: 26px;
    line-height: 1.15;
    letter-spacing: -0.012em;
    color: var(--ink-0);
    margin: 6px 0 8px;
  }
  .qs__sub {
    font-family: var(--font-serif);
    font-size: 16px;
    line-height: 1.55;
    color: var(--ink-2);
    margin: 0;
    max-width: 64ch;
  }
  .qs__sub code {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--ink-1);
    background: var(--paper-1);
    padding: 1px 5px;
    border-radius: 2px;
  }
  .qs__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
  }
  @media (max-width: 900px) {
    .qs__grid { grid-template-columns: 1fr; }
  }
  .qs__more {
    font-family: var(--font-serif);
    font-size: 14px;
    color: var(--ink-2);
    margin: 14px 0 0;
  }

  /* === Concepts === */
  .cn { margin: 0 0 56px; }
  .cn__head { margin-bottom: 18px; padding-bottom: 14px; border-bottom: 1px solid var(--rule-2); }
  .cn__eyebrow {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-3);
  }
  .cn__title {
    font-family: var(--font-serif);
    font-size: 26px;
    line-height: 1.15;
    letter-spacing: -0.012em;
    color: var(--ink-0);
    margin: 6px 0 0;
  }
  .cn__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 14px;
  }
  .ct {
    padding: 14px 16px;
    background: var(--paper-0);
    border: 1px solid var(--rule-1);
    border-radius: var(--radius-1);
  }
  .ct__k {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-3);
    margin-bottom: 8px;
  }
  .ct__d {
    font-family: var(--font-serif);
    font-size: 14px;
    line-height: 1.5;
    color: var(--ink-1);
    margin: 0;
  }
  .ct__d code {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--ink-2);
    background: var(--paper-1);
    padding: 1px 4px;
    border-radius: 2px;
  }

  /* === Why (quiet) === */
  .why {
    margin: 0 0 32px;
    padding: 18px 0;
    border-top: 1px solid var(--rule-2);
    border-bottom: 1px solid var(--rule-2);
  }
  .why__inner {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 32px;
    flex-wrap: wrap;
  }
  .why__text {
    font-family: var(--font-serif);
    font-size: 15px;
    line-height: 1.55;
    color: var(--ink-2);
    margin: 0;
    max-width: 64ch;
    flex: 1;
    min-width: 0;
  }
  .why__link {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    color: var(--ink-3);
    border-bottom: 1px solid var(--rule-2);
    flex-shrink: 0;
  }
  .why__link:hover { color: var(--signal); border-bottom-color: var(--signal); }

  .inline-link {
    color: var(--signal);
    text-decoration: underline;
    text-underline-offset: 2px;
    text-decoration-thickness: 1px;
  }
</style>
