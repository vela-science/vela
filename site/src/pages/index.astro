---
import Reading from "../layouts/Reading.astro";
import ClaimCard from "../components/ClaimCard.astro";
import {
  loadFrontier,
  frontierStats,
  contradictions,
  corpusBreakdown,
  publicationGroundedClaims,
  type ClaimView,
} from "../lib/frontier";
import { FRONTIER, REPO_URL, HUB_URL, VERSION } from "../config";

const claims = loadFrontier();
const stats = frontierStats();
const tensionList = contradictions();
const corpus = corpusBreakdown();

const featured: ClaimView[] = publicationGroundedClaims()
  .slice()
  .sort((a, b) => b.finding.confidence.score - a.finding.confidence.score)
  .slice(0, 6);

const lastUpdated = stats.lastUpdated
  ? new Date(stats.lastUpdated).toISOString().slice(0, 10)
  : "—";
---

<Reading
  title="Vela · open protocol for scientific findings"
  description="An open protocol where scientific findings, evidence, and corrections are first-class, signed, content-addressed objects."
  active="home"
  wide
  noFoot
>
  <!-- ── Hero — text on the left, full workbench dashboard mock on the
       right. The mock is the single load-bearing visual: it shows the
       actual product surface, in the same Atelier register the brand
       toolkit specifies. ─── -->
  <header class="vh-hero">
    <div class="vh-hero__copy">
      <p class="vh-hero__eyebrow">vela {VERSION} · open protocol</p>
      <h1 class="vh-hero__title">An open protocol for scientific findings.</h1>
      <p class="vh-hero__sub">
        Vela turns claims, evidence, uncertainty, provenance, and corrections
        into signed, versioned objects that humans and AI systems can read,
        verify, compose, and update. One Rust binary, three reducer
        implementations agreeing byte-for-byte, one open hub.
      </p>
      <div class="vh-hero__ctas">
        <a class="vh-btn vh-btn--primary" href="/quickstart">
          Quickstart <span aria-hidden="true">→</span>
        </a>
        <a class="vh-btn" href="/spec">
          Read the spec <span aria-hidden="true">→</span>
        </a>
        <a class="vh-btn" href="/workbench">
          Open workbench <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>

    <!-- ── Workbench dashboard mock. Mirrors the Atelier flagship-screen
         layout: left sidebar with nav, main constellation map, findings
         list on the right. All static SVG / styled HTML, no JS. ─── -->
    <figure class="vh-app" aria-label="Vela workbench preview">
      <div class="vh-app__chrome">
        <span class="vh-app__dot"></span>
        <span class="vh-app__dot"></span>
        <span class="vh-app__dot"></span>
        <span class="vh-app__url">vela · workbench</span>
      </div>

      <div class="vh-app__body">
        <!-- Sidebar -->
        <aside class="vh-app__side">
          <div class="vh-app__brand">
            <svg viewBox="0 0 24 28" class="vh-app__brand-glyph" aria-hidden="true">
              <path d="M12 4 L12 22 L4 22 Z" fill="currentColor" opacity="0.92" />
              <path d="M12 6 L12 22 L20 22 Z" fill="currentColor" opacity="0.5" />
              <path class="vh-app__brand-star" d="M16 4 L16.6 5.6 L18.2 6 L16.6 6.4 L16 8 L15.4 6.4 L13.8 6 L15.4 5.6 Z" />
            </svg>
            <span class="vh-app__brand-word">vela</span>
          </div>
          <nav class="vh-app__nav">
            <a class="vh-app__nav-item vh-app__nav-item--on">Overview</a>
            <a class="vh-app__nav-item">Map</a>
            <a class="vh-app__nav-item">Findings</a>
            <a class="vh-app__nav-item">Trails</a>
            <a class="vh-app__nav-item">Sources</a>
            <a class="vh-app__nav-item">Collections</a>
            <a class="vh-app__nav-item">Notes</a>
            <a class="vh-app__nav-item">Alerts</a>
          </nav>
        </aside>

        <!-- Main: knowledge constellation map -->
        <section class="vh-app__main">
          <header class="vh-app__main-head">
            <span class="vh-app__crumb">Constellation Map</span>
            <span class="vh-app__searchbar">Search knowledge, concepts, papers…</span>
          </header>

          <svg class="vh-app__map" viewBox="0 0 600 380" aria-hidden="true">
            <defs>
              <radialGradient id="vh-map-glow" cx="50%" cy="55%" r="42%">
                <stop offset="0%" stop-color="#FBF1D6" stop-opacity="0.95" />
                <stop offset="55%" stop-color="#E5D49A" stop-opacity="0.20" />
                <stop offset="100%" stop-color="#D4AF37" stop-opacity="0" />
              </radialGradient>
            </defs>

            <!-- Halo behind the focal node -->
            <circle cx="300" cy="200" r="150" fill="url(#vh-map-glow)" />

            <!-- Connection lines -->
            <g stroke="#1E2F44" stroke-width="0.6" opacity="0.35" fill="none">
              <line x1="120" y1="80" x2="220" y2="140" />
              <line x1="220" y1="140" x2="300" y2="200" />
              <line x1="300" y1="200" x2="400" y2="120" />
              <line x1="400" y1="120" x2="500" y2="160" />
              <line x1="300" y1="200" x2="180" y2="260" />
              <line x1="180" y1="260" x2="280" y2="320" />
              <line x1="280" y1="320" x2="420" y2="290" />
              <line x1="420" y1="290" x2="500" y2="220" />
              <line x1="500" y1="220" x2="500" y2="160" />
              <line x1="220" y1="140" x2="180" y2="260" />
              <line x1="300" y1="200" x2="420" y2="290" />
              <line x1="300" y1="200" x2="400" y2="120" />
              <line x1="120" y1="80" x2="80" y2="180" />
              <line x1="80" y1="180" x2="180" y2="260" />
            </g>

            <!-- Nodes -->
            <g>
              <!-- Focal node — the active finding -->
              <circle cx="300" cy="200" r="9" fill="#D4AF37" />
              <circle cx="300" cy="200" r="14" fill="none" stroke="#D4AF37" stroke-width="1" opacity="0.45" />
              <text x="300" y="180" text-anchor="middle" class="vh-app__map-label vh-app__map-label--focal">Cellular resilience</text>
              <text x="300" y="225" text-anchor="middle" class="vh-app__map-count">24</text>

              <!-- Surrounding concept nodes -->
              <circle cx="120" cy="80" r="3.5" fill="#1E2F44" />
              <text x="120" y="68" text-anchor="middle" class="vh-app__map-label">Gene regulation</text>
              <text x="120" y="96" text-anchor="middle" class="vh-app__map-count">12</text>

              <circle cx="220" cy="140" r="3" fill="#1E2F44" />
              <text x="220" y="128" text-anchor="middle" class="vh-app__map-label">Protein interaction</text>

              <circle cx="400" cy="120" r="3.5" fill="#1E2F44" />
              <text x="400" y="108" text-anchor="middle" class="vh-app__map-label">Hypoxia</text>
              <text x="400" y="138" text-anchor="middle" class="vh-app__map-count">07</text>

              <circle cx="500" cy="160" r="3.5" fill="#1E2F44" />
              <text x="500" y="148" text-anchor="middle" class="vh-app__map-label">Oxidative stress</text>

              <circle cx="500" cy="220" r="3" fill="#1E2F44" />
              <text x="500" y="240" text-anchor="middle" class="vh-app__map-label">Pathway plasticity</text>

              <circle cx="80" cy="180" r="3" fill="#1E2F44" />
              <text x="80" y="200" text-anchor="middle" class="vh-app__map-label">Microglial activation</text>

              <circle cx="180" cy="260" r="3" fill="#1E2F44" />
              <text x="180" y="280" text-anchor="middle" class="vh-app__map-label">Inflammation</text>

              <circle cx="280" cy="320" r="3.5" fill="#1E2F44" />
              <text x="280" y="340" text-anchor="middle" class="vh-app__map-label">Transcriptional adaptation</text>

              <circle cx="420" cy="290" r="3" fill="#1E2F44" />
              <text x="420" y="310" text-anchor="middle" class="vh-app__map-label">Apoptotic resistance</text>
            </g>
          </svg>

          <footer class="vh-app__legend">
            <span><i class="vh-legend-dot vh-legend-dot--gold"></i>High confidence</span>
            <span><i class="vh-legend-dot vh-legend-dot--mid"></i>Medium</span>
            <span><i class="vh-legend-dot vh-legend-dot--low"></i>Low</span>
            <span><i class="vh-legend-dot vh-legend-dot--hyp"></i>Hypothesis</span>
          </footer>
        </section>

        <!-- Right: findings list -->
        <aside class="vh-app__list">
          <header class="vh-app__list-head">
            <span class="vh-app__list-title">Findings</span>
            <span class="vh-app__list-meta">Sort · Recent</span>
          </header>
          <ol class="vh-app__list-rows">
            <li class="vh-app__list-row vh-app__list-row--on">
              <span class="vh-app__list-id">F-087</span>
              <span class="vh-app__list-conf">0.92</span>
              <p class="vh-app__list-text">Gene expression linked to cellular resilience</p>
              <div class="vh-app__list-tags">
                <span>Genomics</span><span>Cells</span>
              </div>
            </li>
            <li class="vh-app__list-row">
              <span class="vh-app__list-id">F-076</span>
              <span class="vh-app__list-conf">0.87</span>
              <p class="vh-app__list-text">Protein interaction networks refine adaptive responses in hypoxia</p>
              <div class="vh-app__list-tags">
                <span>Proteomics</span><span>Hypoxia</span>
              </div>
            </li>
            <li class="vh-app__list-row">
              <span class="vh-app__list-id">F-061</span>
              <span class="vh-app__list-conf">0.79</span>
              <p class="vh-app__list-text">Environmental factor modulates response mechanisms</p>
              <div class="vh-app__list-tags">
                <span>Environmental</span><span>Systems</span>
              </div>
            </li>
            <li class="vh-app__list-row">
              <span class="vh-app__list-id">F-049</span>
              <span class="vh-app__list-conf">0.71</span>
              <p class="vh-app__list-text">Microglial activation correlates with stress biomarkers</p>
              <div class="vh-app__list-tags">
                <span>Neuroscience</span>
              </div>
            </li>
          </ol>
        </aside>
      </div>
    </figure>
  </header>

  <!-- ── Frontier readout — single hairline strip beneath the hero. ─── -->
  <section class="vh-readout" aria-label="Frontier state">
    <a class="vh-readout__cell" href="/frontiers/alzheimers-bbb">
      <span class="vh-readout__num">{corpus.publicationGrounded}</span>
      <span class="vh-readout__label">signed findings · {corpus.uniquePapers} papers</span>
    </a>
    <a class="vh-readout__cell" href="/frontiers/alzheimers-bbb#open-questions">
      <span class="vh-readout__num">{corpus.openQuestions}</span>
      <span class="vh-readout__label">open questions</span>
    </a>
    <a class="vh-readout__cell" href="/spec#reducer">
      <span class="vh-readout__num">3</span>
      <span class="vh-readout__label">reducer impls · byte-identical</span>
    </a>
    <span class="vh-readout__cell vh-readout__cell--quiet">
      <span class="vh-readout__num vh-readout__num--mono">{lastUpdated}</span>
      <span class="vh-readout__label">last signed</span>
    </span>
  </section>

  <!-- ── This is a Finding — the object, named once. ─── -->
  <section class="vh-object" aria-label="The Finding object">
    <div class="vh-object__copy">
      <p class="vh-eyebrow">01 · the object</p>
      <h2 class="vh-section__title">This is a Finding.</h2>
      <p class="vh-section__sub">
        A scientific claim, scoped, sourced, signed, and content-addressed.
        Carries its evidence, its confidence, its provenance, and a typed link
        graph to every finding that depends on it. When a Correction lands,
        every dependent finding knows.
      </p>
      <p class="vh-section__sub">
        Five primitives: <span class="vh-pill">Finding</span>
        <span class="vh-pill">EvidenceObject</span>
        <span class="vh-pill">Correction</span>
        <span class="vh-pill">Link</span>
        <span class="vh-pill">Frontier</span>. Defined in
        <a class="vh-link" href="/spec">/spec</a>; used in
        <a class="vh-link" href="/quickstart">/quickstart</a>.
      </p>
    </div>
    <pre class="vh-object__code" aria-label="A Finding object encoded as YAML"><code lang="yaml"><span class="vh-tk">finding</span>:
  <span class="vh-tk">id</span>:        vf_83185611d673465b
  <span class="vh-tk">assertion</span>: <span class="vh-str">"Pericyte loss precedes cognitive decline in early Alzheimer's."</span>
  <span class="vh-tk">scope</span>:     [human, sporadic_AD, prodromal_stage]
  <span class="vh-tk">confidence</span>:
    <span class="vh-tk">score</span>: 0.62
    <span class="vh-tk">basis</span>: replication_count + study_design
  <span class="vh-tk">evidence</span>:
    - <span class="vh-tk">type</span>: postmortem_histology
      <span class="vh-tk">doi</span>:  10.1038/jcbfm.2015.44
  <span class="vh-tk">provenance</span>:
    <span class="vh-tk">extracted_from</span>: halliday-2016.pdf
    <span class="vh-tk">reviewed_by</span>:    reviewer:demo-curator
  <span class="vh-tk">signature</span>:  ed25519:88ccb43144e9e228…
  <span class="vh-tk">links</span>:
    <span class="vh-tk">narrowed_by</span>: vrev_b0144a…
    <span class="vh-tk">depends</span>:     [vf_a91c…, vf_4d22…]</code></pre>
  </section>

  <!-- ── Three pillars ─── -->
  <section class="vh-pillars" aria-label="Three pillars">
    <div class="vh-pillar">
      <span class="vh-pillar__num">A</span>
      <h3 class="vh-pillar__title">Structured.</h3>
      <p class="vh-pillar__body">
        Findings, evidence, corrections, and links are first-class objects with
        declared schemas. Not free-text papers, not metadata-on-PDFs. The
        substrate stores claims, not artifacts.
      </p>
    </div>
    <div class="vh-pillar">
      <span class="vh-pillar__num">B</span>
      <h3 class="vh-pillar__title">Provenance-preserving.</h3>
      <p class="vh-pillar__body">
        Every event is content-addressed and signed with Ed25519 over
        canonical-JSON. The reducer is deterministic: same input bytes, same
        output bytes, in three independent implementations.
      </p>
    </div>
    <div class="vh-pillar">
      <span class="vh-pillar__num">C</span>
      <h3 class="vh-pillar__title">Correctable.</h3>
      <p class="vh-pillar__body">
        A Correction is an event, not an erratum buried beside a paper. When a
        finding weakens or a scope narrows, every downstream finding, trial,
        and review article that depended on it is notified.
      </p>
    </div>
  </section>

  <!-- ── Finding Detail panel — dark-navy register, mirrors Atelier 02. ─── -->
  <section class="vh-detail" aria-label="Finding detail preview">
    <div class="vh-detail__head">
      <p class="vh-eyebrow vh-eyebrow--dark">02 · finding detail</p>
      <h2 class="vh-detail__title">Every finding opens to its evidence chain.</h2>
      <p class="vh-detail__sub">
        Confidence with a basis. Reproducibility recorded. Consensus across
        cohorts. Provenance traceable to the source PDF.
      </p>
    </div>

    <div class="vh-detail__panel">
      <div class="vh-detail__panel-head">
        <span class="vh-detail__crumb">Findings / F-087</span>
        <span class="vh-detail__chip vh-detail__chip--ok">High confidence</span>
      </div>

      <h3 class="vh-detail__h">Gene expression linked to cellular resilience</h3>
      <p class="vh-detail__meta">F-087 · Last updated {lastUpdated}</p>

      <div class="vh-detail__tags">
        <span>Genomics</span>
        <span>Cells</span>
        <span>Resilience</span>
        <span>Transcriptomics</span>
      </div>

      <p class="vh-detail__lede">
        Analysis of 12 independent cohorts shows consistent upregulation of the
        RELA pathway in response to oxidative stress, associated with improved
        cell survival.
      </p>

      <dl class="vh-detail__stats">
        <div>
          <dt>Confidence</dt>
          <dd>0.92</dd>
        </div>
        <div>
          <dt>Reproducibility</dt>
          <dd>High</dd>
        </div>
        <div>
          <dt>Consensus</dt>
          <dd>87%</dd>
        </div>
        <div>
          <dt>Date</dt>
          <dd>{lastUpdated}</dd>
        </div>
      </dl>

      <div class="vh-detail__evidence">
        <p class="vh-detail__evidence-head">Evidence</p>
        <ol>
          <li>
            <span class="vh-detail__ev-conf">0.92</span>
            <div>
              <p class="vh-detail__ev-title">Differential expression in human epithelial cells under oxidative stress</p>
              <p class="vh-detail__ev-meta">RNA-seq · GSE242321 · Nature, 2024</p>
            </div>
          </li>
          <li>
            <span class="vh-detail__ev-conf">0.86</span>
            <div>
              <p class="vh-detail__ev-title">RELA pathway activation confers survival advantage</p>
              <p class="vh-detail__ev-meta">CRISPR screen · GSE190675 · Science, 2024</p>
            </div>
          </li>
          <li>
            <span class="vh-detail__ev-conf">0.80</span>
            <div>
              <p class="vh-detail__ev-title">Cross-cohort validation in murine models</p>
              <p class="vh-detail__ev-meta">Bulk RNA-seq · GSE194343 · Cell, 2023</p>
            </div>
          </li>
        </ol>
      </div>

      <dl class="vh-detail__provenance">
        <div><dt>Studies</dt><dd>12</dd></div>
        <div><dt>Datasets</dt><dd>8</dd></div>
        <div><dt>Samples</dt><dd>3,421</dd></div>
        <div><dt>Species</dt><dd>6</dd></div>
      </dl>
    </div>
  </section>

  <!-- ── What Vela is not. ─── -->
  <section class="vh-not" aria-label="What Vela is not">
    <p class="vh-not__title">What Vela is not.</p>
    <p class="vh-not__body">
      Vela is not an electronic lab notebook, not a publisher, not a citation
      manager, not a knowledge graph, not an AI scientist, and not a journal
      replacement. It is the open shared-state layer those systems can write
      to, read from, and verify against. Apache Arrow for code, the Protein
      Data Bank for structures, OpenTelemetry for traces. Vela for findings.
    </p>
  </section>

  <!-- ── Live frontier — claim cards. ─── -->
  <section class="vh-section" aria-label="Live frontier">
    <div class="vh-section__head">
      <p class="vh-eyebrow">03 · live frontier · {FRONTIER.name}</p>
      <h2 class="vh-section__title">Strongest claims, by confidence.</h2>
      <p class="vh-section__sub">
        {stats.claims} signed findings, {stats.papers} papers, {stats.contradictions} open
        contradictions. Each card is content-addressed; click to read the
        evidence chain.
      </p>
    </div>

    <div class="vh-grid">
      {featured.map((c) => <ClaimCard claim={c} />)}
    </div>

    <div class="vh-section__foot">
      <a class="vh-link" href="/workbench">Open the workbench →</a>
      {tensionList.length > 0 && (
        <a class="vh-link" href="/workbench?contested=1">
          {tensionList.length} open contradictions →
        </a>
      )}
      <a class="vh-link" href="/quickstart">Deposit your first finding →</a>
    </div>
  </section>

  <!-- ── Build on this — two panes. ─── -->
  <section class="vh-section" aria-label="Build on this">
    <div class="vh-section__head">
      <p class="vh-eyebrow">04 · build on this</p>
      <h2 class="vh-section__title">One binary. One open hub. Query it now.</h2>
      <p class="vh-section__sub">
        Compile a frontier from a folder of papers, or pull signed manifests
        from the live hub.
      </p>
    </div>

    <div class="vh-build">
      <div class="vh-build__pane">
        <div class="vh-build__pane-head">
          <span class="vh-build__pane-tag">$ run locally</span>
          <span class="vh-build__pane-aside">~60 seconds</span>
        </div>
        <pre class="vh-code vh-code--block" aria-label="Build and run the Vela CLI locally"><code lang="bash"><span class="vh-ps">$</span> <span class="vh-cmd">git clone</span> {REPO_URL}
<span class="vh-ps">$</span> <span class="vh-cmd">cd</span> vela <span class="vh-ps">&&</span> <span class="vh-cmd">cargo build</span> <span class="vh-flag">--release</span>
<span class="vh-ps">$</span> ./target/release/vela <span class="vh-cmd">frontier compile</span> ./papers
<span class="vh-ps">$</span> ./target/release/vela <span class="vh-cmd">serve --workbench</span></code></pre>
      </div>
      <div class="vh-build__pane">
        <div class="vh-build__pane-head">
          <span class="vh-build__pane-tag">$ query the live hub</span>
          <span class="vh-build__pane-aside">no auth · CORS open</span>
        </div>
        <pre class="vh-code vh-code--block" aria-label="Query the live Vela hub for frontier entries"><code lang="bash"><span class="vh-ps">$</span> <span class="vh-cmd">curl</span> {HUB_URL}/entries \
    <span class="vh-flag">-H</span> <span class="vh-str">"accept: application/json"</span>
{`
# {"entries":[
#   {"vfr_id":"vfr_bd91…",
#    "name":"Alzheimer's Therapeutics",
#    "owner_actor_id":"reviewer:will-blair",
#    "snapshot_hash":"f23b4aba17…"}, …]}`}</code></pre>
      </div>
    </div>
  </section>

  <!-- ── Design system showcase — mirrors Atelier 07. ─── -->
  <section class="vh-system" aria-label="Design system">
    <div class="vh-section__head">
      <p class="vh-eyebrow">05 · system &amp; components</p>
      <h2 class="vh-section__title">A small, honest set of parts.</h2>
    </div>

    <div class="vh-system__grid">
      <div class="vh-system__col">
        <p class="vh-system__col-head">Buttons</p>
        <a class="vh-system__btn vh-system__btn--primary">Primary action</a>
        <a class="vh-system__btn vh-system__btn--secondary">Secondary action</a>
        <a class="vh-system__btn vh-system__btn--tertiary">Tertiary action</a>
      </div>

      <div class="vh-system__col">
        <p class="vh-system__col-head">Tags</p>
        <div class="vh-system__tags">
          <span class="vh-tag">Genomics</span>
          <span class="vh-tag">Cells</span>
          <span class="vh-tag">Proteomics</span>
        </div>
        <div class="vh-system__tags">
          <span class="vh-tag vh-tag--ok">High confidence</span>
          <span class="vh-tag vh-tag--mid">Medium</span>
          <span class="vh-tag vh-tag--low">Low</span>
        </div>
      </div>

      <div class="vh-system__col">
        <p class="vh-system__col-head">Confidence</p>
        <div class="vh-system__conf">
          <span class="vh-system__conf-num">0.92</span>
          <span class="vh-system__conf-lbl">High</span>
        </div>
        <div class="vh-system__bar">
          <div class="vh-system__bar-fill" style="width: 92%"></div>
        </div>
      </div>

      <div class="vh-system__col">
        <p class="vh-system__col-head">Palette</p>
        <div class="vh-system__swatches">
          <span class="vh-swatch" style="background: #081320"></span>
          <span class="vh-swatch" style="background: #1E2F44"></span>
          <span class="vh-swatch" style="background: #6E7B8B"></span>
