---
/*
  Counterfactual index (v0.45 — Pearl level 3).

  Lists the (cause, effect) pairs in the loaded frontier whose
  source→target paths are fully mechanism-annotated and therefore
  admit a twin-network counterfactual answer. This is the entry
  surface for the level-3 reasoning layer; per-pair pages live at
  /counterfactual/[from]/[to].
*/

import Reading from "../../layouts/Reading.astro";
import {
  loadFrontier,
  liveCounterfactualPairs,
  loadCausalGraph,
} from "../../lib/frontier";
import { FRONTIER, VERSION } from "../../config";

const pairs = liveCounterfactualPairs();
const claims = loadFrontier();
const claimById = new Map(claims.map((c) => [c.finding.id, c]));
const graph = loadCausalGraph();

function trunc(s: string, n: number): string {
  return s.length > n ? `${s.slice(0, n - 1)}…` : s;
}
---

<Reading
  title={`Counterfactuals · ${FRONTIER.name}`}
  description="Pearl level 3 — twin-network counterfactual queries over the claim graph. Lists the (cause, effect) pairs whose source-to-target path is fully mechanism-annotated."
  active="docs"
>
  <header class="page-head">
    <p class="eyebrow">Counterfactuals</p>
    <h1 class="page-head__title">What if we had observed differently?</h1>
    <p class="page-head__sub">Pearl level 3: twin-network counterfactuals along mechanism-annotated edges.</p>
  </header>

  <section class="cf-doctrine">
    <p class="cf-doctrine__eyebrow">Doctrine</p>
    <p class="cf-doctrine__body">
      A counterfactual asks: <em>given that we observed Y, what would Y have been if we had
      seen X take a different value?</em> Vela answers via twin-network propagation along the
      directed claim graph, using the optional <code>mechanism</code> annotation on each
      <code>depends</code> / <code>supports</code> link. Edges without a mechanism block
      propagation honestly and surface as <code>mechanism_unspecified</code>.
    </p>
    <p class="cf-doctrine__body">
      Mechanisms are deliberately coarse — five shapes (linear, monotonic, threshold,
      saturating, unknown) cover the empirical distribution of biology and clinical claims
      while keeping us out of the business of inventing functional forms.
    </p>
    <p class="cf-doctrine__body">
      The Rust kernel <code>crate::counterfactual</code> is canonical; this page mirrors the
      same algorithm at build time so the same query returns the same answer here and on the
      command line.
    </p>
  </section>

  <section class="cf-summary">
    <h2 class="cf-summary__title">Frontier counterfactual surface</h2>
    <dl class="cf-summary__dl">
      <dt>Findings in graph</dt>
      <dd>{graph.nodes.size}</dd>
      <dt>Directed edges</dt>
      <dd>{graph.edges.length}</dd>
      <dt>Live counterfactual pairs</dt>
      <dd>{pairs.length}</dd>
    </dl>
  </section>

  <ol class="cf-list">
    {pairs.map(({ from, to }) => {
      const fromClaim = claimById.get(from);
      const toClaim = claimById.get(to);
      if (!fromClaim || !toClaim) return null;
      return (
        <li class="cf-item">
          <p class="cf-item__head">
            <a href={`/counterfactual/${fromClaim.slug}/${toClaim.slug}`} class="cf-item__link">
              do({fromClaim.shortId}) → {toClaim.shortId}
            </a>
          </p>
          <p class="cf-item__body">
            <strong>cause:</strong> {trunc(fromClaim.finding.assertion.text, 110)}
          </p>
          <p class="cf-item__body">
            <strong>effect:</strong> {trunc(toClaim.finding.assertion.text, 110)}
          </p>
        </li>
      );
    })}
  </ol>

  <!-- ── HTTP API spec — the same kernel, callable over the wire ── -->
  <section class="cf-api" aria-labelledby="cf-api-head">
    <h2 id="cf-api-head" class="cf-api__head">HTTP API · POST /api/counterfactual/&#123;vfr_id&#125;</h2>
    <p class="cf-api__lede">
      The hub runs the same <code>answer_counterfactual</code> kernel a local CLI runs, against the
      registered frontier the registry declares. Same input, same output, regardless of where the
      query originates.
    </p>
    <pre class="cf-api__code"><code>{`# Request — JSON body, all three fields required.
POST /api/counterfactual/vfr_bd91…
Content-Type: application/json

{
  "intervene_on": "vf_<id>",   // finding to imagine setting confidence on
  "set_to":       0.8,         // confidence value, in [0.0, 1.0]
  "target":       "vf_<id>"    // finding whose counterfactual confidence to read
}

# Response — verdict tagged by kind.
HTTP/1.1 200 OK
{
  "ok": true,
  "vfr_id": "vfr_bd91…",
  "query":   { … },
  "verdict": {
    "kind": "Resolved",
    "factual":        0.62,
    "counterfactual": 0.81,
    "delta":          0.19,
    "paths_used": [["vf_a", "vf_b", "vf_c"]]
  }
}

# Other verdicts the kernel may return:
#   { "kind": "MechanismUnspecified", "unspecified_edges": [["vf_a","vf_b"], …] }
#   { "kind": "NoCausalPath",         "factual": 0.5 }
#   { "kind": "UnknownNode",          "which": "vf_???" }
#   { "kind": "InvalidIntervention",  "reason": "set_to outside [0,1]" }`}</code></pre>
    <p class="cf-api__caption">
      Schema: <code>https://vela.science/schema/counterfactual/v0.45.1</code>.
      Kernel source: <code>vela_protocol::counterfactual::answer_counterfactual</code>.
      The CLI form (<code>vela counterfactual</code>) wraps the same call locally.
    </p>
  </section>

  <p class="cf-version">vela {VERSION} · level 3</p>
</Reading>

