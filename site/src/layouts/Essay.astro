---
import Page from "./Page.astro";

interface Props {
  title: string;
  description?: string;
  pubDate?: string;
  active?: string;
}
const { title, description, pubDate, active = "essays" } = Astro.props;
const fullTitle = `${title} · Vela`;
---
<Page
  title={fullTitle}
  description={description}
  active={active}
  eyebrow={pubDate ? `Essay · <span style="color:var(--ink-2);">${pubDate}</span>` : "Essay"}
  pageTitle={title}
  subtitle={description}
>
  <a href="/" slot="aside" class="back-link">← back</a>
  <article class="reading">
    <slot />
  </article>
</Page>

<style is:global>
  /* WbHead already renders the page title — suppress the markdown h1
     so the essay body starts with the first paragraph, not a duplicate. */
  article.reading > h1:first-child { display: none; }
</style>
<style>
  article.reading {
    padding: 8px 0 32px;
    margin: 0 auto;
  }
  .back-link {
    font-family: var(--font-mono);
    font-size: var(--size-imprint);
    letter-spacing: var(--track-imprint);
    text-transform: uppercase;
    color: var(--ink-3);
    border-bottom: 1px solid transparent;
    transition: color var(--dur-1) var(--ease), border-bottom-color var(--dur-1) var(--ease);
  }
  .back-link:hover {
    color: var(--gold);
    border-bottom-color: color-mix(in oklab, var(--gold) 56%, transparent);
  }
</style>
