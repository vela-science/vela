---
/*
  Protocol page — short, interactive, show by doing.

  Was a docs-shaped wall of prose; now a 4-section essay where each
  section opens with a watercolor plate + glyph and contains ONE
  sentence + a working interactive demonstration of the concept.
  Whitepaper-shaped depth lives in /docs.
*/

import Reading from "../../layouts/Reading.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import ImagePlate from "../../components/ImagePlate.astro";
import Imprint from "../../components/Imprint.astro";
import ClaimCard from "../../components/ClaimCard.astro";
import LiveHub from "../../components/LiveHub.astro";
import TerminalPaper from "../../components/TerminalPaper.astro";
import { loadFrontier } from "../../lib/frontier";
import { HUB_URL, REPO_URL, VERSION } from "../../config";

// Pick the highest-confidence claim as the "show, don't tell" example.
const allClaims = loadFrontier();
const featuredClaim = allClaims
  .slice()
  .sort((a, b) => b.finding.confidence.score - a.finding.confidence.score)[0];
---

<Reading
  title="Vela protocol · scientific memory for humans and AI"
  description="A short, interactive walkthrough of the Vela protocol: findings, constellations, proof packets, and how to use it."
  active="docs"
  wide
>
  <header class="page-head">
    <p class="eyebrow">00 · The protocol</p>
    <h1 class="page-head__title">The protocol</h1>
    <p class="page-head__sub">
      Scientific memory humans and agents can correct, replay, and sign.
    </p>
  </header>

  <article class="protocol">
    <!-- ── Hero ──
         Watercolor plate removed: pale watercolor on cream paper
         under mix-blend-mode multiply rendered as a viewport-scale
         void. The page header (eyebrow + h1 + subtitle) already does
         the masthead work; this section now adds the four-noun thesis
         and a jump-to-section nav so a developer scrolling can see
         the full doc shape immediately. -->
    <section class="protocol__hero">
      <p class="protocol__hook">
        <em>Four nouns, one binary.</em>
      </p>
      <p class="protocol__sub">
        Vela is the smallest substrate that holds: a finding has a content-addressed id,
        a constellation of findings has a content-addressed id,
        two implementations agree byte-for-byte, the signature is the bind.
      </p>

      <nav class="protocol__toc" aria-label="On this page">
        <span class="protocol__toc-label">on this page</span>
        <ol class="protocol__toc-list">
          <li><a href="#finding"><span class="protocol__toc-num">§1</span> Finding</a></li>
          <li><a href="#constellation"><span class="protocol__toc-num">§2</span> Constellation</a></li>
          <li><a href="#proof-packet"><span class="protocol__toc-num">§3</span> Proof packet</a></li>
          <li><a href="#use-it"><span class="protocol__toc-num">§4</span> Use it</a></li>
        </ol>
      </nav>
    </section>

    <!-- ── §1 Finding ── -->
    <section id="finding" class="protocol__section">
      <SectionHeading title="Finding" glyph="finding" kicker="§1 · the unit" />
      <p class="protocol__status">
        <span class="protocol__badge protocol__badge--shipping">shipping · v0.48</span>
        <span class="protocol__status-note"><code>FindingBundle</code> in <code>crates/vela-protocol/src/bundle.rs</code> · 86 real findings on the BBB frontier today</span>
      </p>
      <ImagePlate
        fallback="/images/plates/finding.png"
        width={1916}
        height={821}
        alt="A single bright watercolor pinpoint surrounded by faint atmospheric rings."
      />
      <p class="protocol__line">
        A typed assertion with evidence, conditions, confidence, provenance,
        and a content-addressed <code>vf_…</code> id. The unit science writes once and refers to everywhere.
      </p>
      {featuredClaim && (
        <div class="protocol__demo">
          <ClaimCard claim={featuredClaim} />
          <p class="protocol__demo-caption">
            ↑ One real finding from the live frontier. Click for evidence.
          </p>
        </div>
      )}
    </section>

    <!-- ── §2 Constellation ── -->
    <section id="constellation" class="protocol__section">
      <SectionHeading title="Constellation" glyph="constellation" kicker="§2 · the field" />
      <p class="protocol__status">
        <span class="protocol__badge protocol__badge--shipping">shipping · v0.48</span>
        <span class="protocol__status-note"><code>Project</code> + signed events + Ed25519 registry · <a class="inline-link" href="https://vela-hub.fly.dev/entries" rel="noopener">live hub</a> serving 3 published constellations from a Postgres backend</span>
      </p>
      <ImagePlate
        fallback="/images/plates/constellation.png"
        width={1817}
        height={866}
        alt="A watercolor field of navy and gold stars connected by faint dotted arcs across pale paper."
      />
      <p class="protocol__line">
        A bounded set of findings, the links between them, and the event log of every change.
        Has a content-addressed <code>vfr_…</code> id. Two machines compute the same hash from the same constellation, or one of them is wrong.
      </p>
      <div class="protocol__demo">
        <LiveHub />
        <p class="protocol__demo-caption">
          ↑ Live hub status. Each entry is a signed manifest pointing at a constellation.
          <a class="inline-link" href="/workbench">Open the workbench →</a>
          <span class="protocol__sep">·</span>
          <a class="inline-link" href="/replay">Drag through one event log →</a>
        </p>
      </div>
    </section>

    <!-- ── §3 Proof ── -->
    <section id="proof-packet" class="protocol__section">
      <SectionHeading title="Proof packet" glyph="proof" kicker="§3 · the seam" />
      <p class="protocol__status">
        <span class="protocol__badge protocol__badge--shipping">shipping · v0.48</span>
        <span class="protocol__status-note">35-file canonical packet structure · byte-level verifier ships in the binary as <code>vela verify &lt;packet&gt;</code></span>
      </p>
      <ImagePlate
        fallback="/images/plates/proof.png"
        width={1672}
        height={941}
        alt="A watercolor sealed envelope with a faint gold seam and atmospheric warmth."
      />
      <p class="protocol__line">
        A sealed snapshot another party can re-verify offline. Manifest, signed-trace chain, integrity lock, file-by-file SHA-256 — the bytes the skeptic actually wants to see.
      </p>
      <div class="protocol__demo">
        <div class="proof-excerpt">
          <div class="proof-excerpt__row"><span class="k">snapshot_hash</span><span class="v">f23b4aba173f3fb840c6ec2555715bdc…</span></div>
          <div class="proof-excerpt__row"><span class="k">event_log_hash</span><span class="v">4f53cda18c2baa0c0354bb5f9a3ecbe5…</span></div>
          <div class="proof-excerpt__row"><span class="k">vela_version</span><span class="v">0.8.0</span></div>
          <div class="proof-excerpt__row"><span class="k">findings</span><span class="v">48 · contested 1 · gaps 1 · sources 10</span></div>
          <div class="proof-excerpt__row"><span class="k">replay_status</span><span class="v">no_events</span></div>
          <div class="proof-excerpt__row"><span class="k">status</span><span class="v">ok</span></div>
        </div>
        <p class="protocol__demo-caption">
          ↑ Excerpt from a real BBB Flagship proof packet.
          <span class="protocol__sep">·</span>
          <a class="inline-link" href="/proof/pericyte-correction">See one Correction event in motion →</a>
        </p>
      </div>

      <!-- "Verify it yourself" — the actual byte-level check anyone can run -->
      <div class="protocol__demo protocol__demo--verify">
        <div class="protocol__verify-head">
          <span class="protocol__verify-tag">verify it yourself</span>
          <span class="protocol__verify-aside">35 files · sha256 recomputed · pull on any machine</span>
        </div>
        <pre class="protocol__verify-code"><code>{`$ vela verify ./bbb-alzheimer-proof-packet

vela packet validate
  root: ./bbb-alzheimer-proof-packet
  status: ok
  checked_files: 35
  project: BBB Flagship

verify: ok
  every file in the manifest matched its claimed sha256.
  pull this packet on another machine, run the same
  command, see the same line.`}</code></pre>
        <p class="protocol__demo-caption">
          ↑ Real output from the binary against a real packet.
          The verifier reads each file, recomputes the SHA-256, and compares to the manifest.
          One mismatch and it exits non-zero.
        </p>
      </div>

      <!-- ── 30-second proof — no install required ──
           A second, independent implementation of the verifier in
           pure Python stdlib. Pipe to bash and watch a real packet
           verified byte-for-byte against its manifest. The point is
           portability: if two implementations agree on every hash
           in the manifest, the protocol is a specification, not an
           artifact of one binary. Sceptics: read the script first
           with `curl … | less`. ── -->
      <div class="protocol__demo protocol__demo--try">
        <div class="protocol__verify-head">
          <span class="protocol__verify-tag">30-second proof — no install</span>
          <span class="protocol__verify-aside">downloads ~80 KB · runs locally · python stdlib only</span>
        </div>
        <pre class="protocol__verify-code"><code>{`$ curl -sSL https://vela.science/try | bash

  vela · 30-second proof
  downloading a real signed proof packet, then independently verifying every byte.

  · fetching sample-packet.tar.gz from https://vela.science
  · fetching vela_verify.py (stdlib-only python verifier)
  · extracting packet
  · running verifier against bbb-alzheimer-proof-packet

vela verify (python · stdlib)
  root:           /tmp/vela-try.XXXXXX/bbb-alzheimer-proof-packet
  status:         ok
  checked_files:  35 / 35
  project:        BBB Flagship
  vela_version:   0.8.0
  packet_format:  vela.frontier-packet · v1
  proof_trace:    ok

verify: ok
  every file in the manifest matched its claimed sha256, computed
  by an independent python implementation. the protocol is
  not a rust artifact — it is a portable specification.

  ✓ independently verified.`}</code></pre>
        <p class="protocol__demo-caption">
          ↑ A second implementation, in pure Python stdlib, computes the same hashes.
          Two implementations agreeing byte-for-byte on every file is the test that matters for any portable specification.
          <span class="protocol__sep">·</span>
          <a class="inline-link" href="/try">Read the script</a>
          <span class="protocol__sep">·</span>
          <a class="inline-link" href="/vela_verify.py">Read the verifier</a>
          <span class="protocol__sep">·</span>
          <a class="inline-link" href="/proof/packet">Browse the manifest →</a>
        </p>
      </div>

      <!-- ── Cross-implementation reducer agreement ──
           The packet verifier proves byte-identical agreement on the
           hashed file layer. The reducer is the harder claim: two
           implementations of the per-kind mutation rules must produce
           the same post-replay finding state from the same event log.
           This block ships the second implementation and a fixture
           set so a reviewer can exercise it offline. ── -->
      <div class="protocol__demo protocol__demo--reducer">
        <div class="protocol__verify-head">
          <span class="protocol__verify-tag">cross-impl reducer agreement</span>
          <span class="protocol__verify-aside">5 fixtures · every dispatch arm covered · stdlib python · stdlib node</span>
        </div>
        <pre class="protocol__verify-code"><code>{`# Three implementations of the per-kind reducer must produce
# byte-equivalent post-replay finding state. Run all three ends:

$ curl -sSL https://vela.science/vela_reducer.py -O
$ curl -sSL https://vela.science/vela_reducer.mjs -O
$ curl -sSL https://vela.science/reducer-fixtures.tar.gz | tar -xz
$ python3 vela_reducer.py fixtures/
$ node    vela_reducer.mjs fixtures/

vela reducer (typescript / node · third implementation)
  ok   · frontier 00 · 8/8 findings · 22 events · cascade depth 5
  ok   · frontier 01 · 8/8 findings · 22 events · cascade depth 5
  ok   · frontier 02 · 8/8 findings · 22 events · cascade depth 5
  ok   · frontier 03 · 8/8 findings · 24 events · cascade depth 0  # review-branches + confidence-revised
  ok   · frontier 04 · 8/8 findings · 17 events · cascade depth 0  # annotations + rejected

reducer: ok
  every event-log replay through the typescript reducer produced
  the same per-finding state the rust and python reducers produced.
  the per-kind mutation rules now have three independent
  implementations that agree byte-for-byte.`}</code></pre>
        <p class="protocol__demo-caption">
          ↑ Cross-implementation agreement on every dispatch arm of the per-kind reducer — including a depth-5 retraction cascade, all four <code>finding.reviewed</code> branches (accepted / contested / needs_revision / rejected), <code>finding.confidence_revised</code> with both integer and fractional new_score values, both annotation kinds (<code>noted</code> / <code>caveated</code>), and <code>finding.rejected</code>. Each fixture carries genesis findings, the canonical event log, and the post-replay <code>expected_states</code> the Rust reducer produced. Python and Node reduce the same log through their own dispatch tables and assert deep equality on every finding's <code>retracted</code>, <code>contested</code>, <code>review_state</code>, <code>confidence_score</code>, and <code>annotation_ids</code>.
          <span class="protocol__sep">·</span>
          <a class="inline-link" href="/vela_reducer.py">Python reducer</a>
          <span class="protocol__sep">·</span>
          <a class="inline-link" href="/vela_reducer.mjs">TypeScript reducer (Node)</a>
        </p>
        <p class="protocol__demo-caption protocol__demo-caption--coda">
          <strong>Three independent implementations</strong> of the per-kind mutation rules — Rust, Python, TypeScript — agree byte-for-byte across <strong>every dispatch arm</strong> in the reducer.
          A coverage-assertion test fails CI if a new event kind ships without a fixture branch, so the agreement claim cannot drift in either direction.
          The doctrine "two implementations of the reducer must agree on the mutation rules per kind" is no longer aspirational.
        </p>
      </div>
    </section>

    <!-- ── §4 Use it ── -->
    <section id="use-it" class="protocol__section">
      <SectionHeading title="Use it" kicker="§4 · one binary" />
      <p class="protocol__status">
        <span class="protocol__badge protocol__badge--shipping">shipping · v0.48</span>
        <span class="protocol__status-note">Rust workspace, ~440 protocol tests · single static binary, ~30 subcommands</span>
      </p>
      <p class="protocol__line">
        Clone, build, publish your own bounded question.
      </p>
      <div class="protocol__terminals">
        <TerminalPaper title="install">
          <span class="tm-ps">$</span> <span class="tm-cmd">git clone</span> {REPO_URL}
<span class="tm-ps">$</span> <span class="tm-cmd">cd</span> vela <span class="tm-ps">&&</span> <span class="tm-cmd">cargo build</span> <span class="tm-flag">--release</span>
<span class="tm-ps">$</span> <span class="tm-cmd">./target/release/vela</span> <span class="tm-flag">--version</span>
        </TerminalPaper>
        <TerminalPaper title="publish your own constellation">
          <span class="tm-ps">$</span> <span class="tm-cmd">vela frontier new</span> ./constellation.json <span class="tm-flag">--name</span> "Your bounded question"
<span class="tm-ps">$</span> <span class="tm-cmd">vela finding add</span> ./constellation.json <span class="tm-flag">--assertion</span> "..." <span class="tm-flag">--apply</span>
<span class="tm-ps">$</span> <span class="tm-cmd">vela sign generate-keypair</span> <span class="tm-flag">--out</span> keys
<span class="tm-ps">$</span> <span class="tm-cmd">vela registry publish</span> ./constellation.json <span class="tm-flag">--key</span> keys/private.key <span class="tm-flag">--to</span> {HUB_URL}
        </TerminalPaper>
      </div>
      <p class="protocol__line protocol__line--muted">
        Agent integration (the four-step write surface — draft, review, sign, publish — plus the <code>AgentRun</code>/<code>ToolCallTrace</code>/<code>PermissionState</code> schema) at <a class="inline-link" href="/protocol/agents">/protocol/agents</a>.
        Walk-through with cross-frontier composition at <a class="inline-link" href="/publish">/publish</a>.
        Whitepaper-depth shape and schemas at <a class="inline-link" href="/docs/protocol">/docs/protocol</a>.
      </p>
    </section>

    <Imprint returnHref="/" returnLabel="Back to the live frontier" />
  </article>
</Reading>

<style>
  .aside-link {
    font-family: var(--font-mono);
    font-size: var(--size-xs);
    letter-spacing: 0.06em;
    color: var(--ink-3);
  }
  .aside-link:hover { color: var(--gold); }
  .aside-version {
    font-family: var(--font-mono);
    font-size: var(--size-xs);
    letter-spacing: 0.06em;
    color: var(--ink-4);
    margin-left: 6px;
  }
  div[slot="aside"] {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .protocol {
    max-width: var(--measure-wide);
    margin: 0 auto;
    padding: 0;
  }

  /* ── Hero ── */
  .protocol__hero {
    margin: 0 0 clamp(2.5rem, 6vh, 4rem);
  }
  .protocol__hero :global(.vela-image-plate) {
    margin-top: 0;
    margin-bottom: 1.4rem;
  }
  .protocol__hook {
    font-family: var(--font-display);
    font-weight: 450;
    font-size: clamp(1.7rem, 3.2vw, 2.4rem);
    line-height: 1.08;
    letter-spacing: -0.018em;
    color: var(--ink-0);
    margin: 0 0 1rem;
    max-width: 32ch;
    text-wrap: balance;
    font-variation-settings: "opsz" 144, "SOFT" 30;
  }
  .protocol__hook em { font-style: normal; }
  .protocol__sub {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 1rem;
    line-height: 1.55;
    letter-spacing: -0.005em;
    color: color-mix(in oklab, var(--ink-2) 92%, transparent);
    margin: 0 0 var(--space-5);
    max-width: 60ch;
  }

  /* ── Table of contents ──
     Stripe-style "on this page" jump nav so a developer scanning a
     long doc sees the full shape immediately. */
  .protocol__toc {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 0.85rem 0;
    border-top: 1px solid color-mix(in oklab, var(--gold) 28%, transparent);
    border-bottom: 1px solid var(--rule-1);
    max-width: 60ch;
  }
  .protocol__toc-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: color-mix(in oklab, var(--gold) 76%, var(--ink-2));
  }
  .protocol__toc-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0 1.2rem;
  }
  .protocol__toc-list li { padding: 2px 0; }
  .protocol__toc-list a {
    display: inline-flex;
    align-items: baseline;
    gap: 8px;
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1.05rem;
    letter-spacing: 0.005em;
    color: var(--ink-1);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: color var(--dur-1) var(--ease), border-bottom-color var(--dur-1) var(--ease);
  }
  .protocol__toc-list a:hover {
    color: var(--gold);
    border-bottom-color: color-mix(in oklab, var(--gold) 56%, transparent);
  }
  .protocol__toc-num {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.06em;
    color: var(--ink-3);
    font-weight: 400;
  }

  /* ── Sections ── */
  .protocol__section {
    margin: 0 0 clamp(3rem, 7vh, 4.5rem);
  }
  .protocol__section :global(.vela-image-plate) {
    margin-top: 1rem;
    margin-bottom: 1.4rem;
  }
  .protocol__line {
    font-family: var(--font-body);
    font-size: 1.1rem;
    line-height: 1.6;
    color: color-mix(in oklab, var(--ink-1) 92%, var(--ink-2));
    margin: 0 0 1.4rem;
    max-width: 56ch;
    text-wrap: pretty;
  }
  .protocol__line--muted {
    font-size: 0.95rem;
    color: color-mix(in oklab, var(--ink-2) 88%, transparent);
    margin-top: 1.2rem;
  }
  .protocol__line code {
    font-family: var(--font-mono);
    font-size: 0.86em;
    color: var(--ink-1);
    background: var(--paper-1);
    padding: 1px 5px;
    border: 1px solid var(--rule-2);
    border-radius: var(--radius-xs);
  }

  /* ── Demo blocks (claim card, hub, proof excerpt) ── */
  .protocol__demo {
    margin: 1.2rem 0 0;
  }
  .protocol__demo-caption {
    margin: 0.85rem 0 0;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.04em;
    color: color-mix(in oklab, var(--ink-3) 92%, transparent);
  }
  .protocol__demo-caption code {
    font-family: var(--font-mono);
    font-size: 0.95em;
    color: var(--ink-2);
    background: var(--paper-1);
    padding: 1px 5px;
    border: 1px solid var(--rule-2);
    border-radius: var(--radius-xs);
  }
  .protocol__sep { color: var(--ink-4); margin: 0 4px; }

  /* ── Status badges ──
     Honest about what's shipping vs deferred. Reviewer's "prose ahead
     of artifact" critique gets blunted when each section names the
     code path that backs the claim. */
  .protocol__status {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 8px 12px;
    margin: 0 0 1.1rem;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.04em;
    color: color-mix(in oklab, var(--ink-3) 92%, transparent);
  }
  .protocol__badge {
    display: inline-block;
    padding: 2px 8px;
    border: 1px solid color-mix(in oklab, var(--gold) 38%, transparent);
    border-radius: var(--radius-sm);
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 500;
    color: color-mix(in oklab, var(--gold) 80%, var(--ink-2));
    flex: 0 0 auto;
  }
  .protocol__badge--shipping {
    color: color-mix(in oklab, var(--moss) 80%, var(--ink-1));
    border-color: color-mix(in oklab, var(--moss) 38%, transparent);
  }
  .protocol__badge--deferred {
    color: color-mix(in oklab, var(--brass) 80%, var(--ink-2));
    border-color: color-mix(in oklab, var(--brass) 38%, transparent);
  }
  .protocol__status-note {
    color: color-mix(in oklab, var(--ink-3) 92%, transparent);
    line-height: 1.45;
  }
  .protocol__status-note code {
    font-family: var(--font-mono);
    font-size: 0.92em;
    color: var(--ink-1);
    background: var(--paper-1);
    padding: 1px 5px;
    border: 1px solid var(--rule-2);
    border-radius: var(--radius-xs);
  }

  /* ── Verify panel — Stripe-style live API echo, but for the proof
     command. Real output from `vela verify` against a real packet. */
  .protocol__demo--verify {
    margin-top: 1.4rem;
    border-top: 1px solid color-mix(in oklab, var(--gold) 28%, transparent);
    padding-top: 1.1rem;
  }
  .protocol__verify-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 10px;
    margin-bottom: 0.65rem;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: color-mix(in oklab, var(--ink-3) 92%, transparent);
  }
  .protocol__verify-tag {
    color: color-mix(in oklab, var(--gold) 76%, var(--ink-2));
    font-weight: 500;
  }
  .protocol__verify-code {
    margin: 0;
    padding: 14px 18px 16px;
    background: var(--paper-1);
    border: 1px solid var(--rule-2);
    border-radius: var(--radius-sm);
    font-family: var(--font-mono);
    font-size: 12px;
    line-height: 1.6;
    color: var(--ink-1);
    overflow-x: auto;
    white-space: pre;
  }
  .protocol__verify-code code {
    font-family: inherit;
    font-size: inherit;
    color: inherit;
    background: transparent;
    border: 0;
    padding: 0;
  }

