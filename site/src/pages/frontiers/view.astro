---
import Page from "../../layouts/Page.astro";
import { HUB_URL, WORKBENCH_URL } from "../../config";
const HUB_HOST = HUB_URL.replace(/^https?:\/\//, "");
---
<Page
  title="Frontier · Vela"
  description="A signed scientific frontier on the public Vela hub."
  active="home"
  eyebrow="Frontier"
  pageTitle="Loading frontier…"
  subtitle="Signed manifest, content-addressed, replayable."
>
  <div slot="aside">
    <a class="aside-link" href={`${HUB_URL}/entries`}>hub</a>
    <span>·</span>
    <a class="aside-link" id="fr-rawmanifest" href="#">manifest</a>
  </div>

  <article class="fr" data-fr data-hub-url={HUB_URL} data-workbench-url={WORKBENCH_URL}>
    <!-- Header card -->
    <header class="fr-hdr">
      <div class="fr-hdr__row">
        <div class="fr-hdr__main">
          <div class="fr-hdr__owner-line">
            <a class="fr-hdr__owner" href="/" id="fr-owner">—</a>
            <span class="fr-hdr__sep">/</span>
            <span class="fr-hdr__name" id="fr-name">…</span>
            <span class="fr-hdr__sig" id="fr-sig" title="hub-validated signature">signed</span>
          </div>
          <p class="fr-hdr__desc" id="fr-desc">—</p>
          <div class="fr-hdr__chiprow">
            <span class="frc" id="fr-vfr">vfr_…</span>
            <span class="frc frc--mono" id="fr-snap">snapshot —</span>
            <span class="frc frc--ok" id="fr-ver">verified</span>
            <span class="frc" id="fr-when">—</span>
          </div>
        </div>
        <div class="fr-hdr__cta">
          <a class="wb-btn wb-btn--ink" id="fr-open-wb" href="#">
            Open in Workbench
            <span class="wb-btn__kbd">↗</span>
          </a>
          <button class="wb-btn" id="fr-copy-pull" type="button">
            Copy pull command
          </button>
          <a class="wb-btn wb-btn--ghost" id="fr-locator" href="#" rel="noopener">
            View raw frontier ↗
          </a>
        </div>
      </div>
    </header>

    <!-- Tabs -->
    <nav class="fr-tabs" role="tablist" aria-label="Frontier sections">
      <button class="fr-tab fr-tab--on" data-tab="findings" role="tab">
        Findings <span class="fr-tab__count" id="fr-tab-findings">—</span>
      </button>
      <button class="fr-tab" data-tab="inbox" role="tab">
        Inbox <span class="fr-tab__count" id="fr-tab-inbox">—</span>
      </button>
      <button class="fr-tab" data-tab="diff" role="tab">
        Diff <span class="fr-tab__count" id="fr-tab-diff">—</span>
      </button>
      <button class="fr-tab" data-tab="snapshots" role="tab">
        Snapshots <span class="fr-tab__count" id="fr-tab-snapshots">—</span>
      </button>
      <button class="fr-tab" data-tab="deps" role="tab">
        Cross-frontier deps <span class="fr-tab__count" id="fr-tab-deps">—</span>
      </button>
      <button class="fr-tab" data-tab="actors" role="tab">
        Actors <span class="fr-tab__count" id="fr-tab-actors">—</span>
      </button>
      <button class="fr-tab" data-tab="about" role="tab">About</button>
    </nav>

    <!-- Two-col layout: main + sidebar -->
    <div class="fr-body">
      <div class="fr-main">
        <section class="fr-pane" data-pane="findings">
          <div class="fr-toolbar">
            <label class="fr-search">
              <svg width="13" height="13" viewBox="0 0 16 16" fill="none" stroke="currentColor" aria-hidden="true">
                <circle cx="7" cy="7" r="5" stroke-width="1.2"/><line x1="11" y1="11" x2="15" y2="15" stroke-width="1.2"/>
              </svg>
              <input type="search" id="fr-find-q" placeholder="filter findings by claim, vf_id, kind…" autocomplete="off" spellcheck="false" />
              <span class="fr-search__count" id="fr-find-count">— / —</span>
            </label>
          </div>
          <div class="fr-findings" id="fr-findings"></div>
        </section>

        <section class="fr-pane" data-pane="inbox" hidden>
          <div class="ib-banner" id="ib-banner" hidden></div>
          <div class="ib-summary" id="ib-summary"></div>
          <div class="ib-runs" id="ib-runs">
            <div class="fr-empty fr-empty--guided">
              <div class="fr-empty__title">The Inbox is where agents propose.</div>
              <p class="fr-empty__body">
                Run an ingestion agent against your local research folder
                and pending proposals appear here, grouped by run.
                Hover any card to see the agent's reasoning;
                accept or reject through the UI; sign with the CLI.
              </p>
              <pre class="fr-empty__cmd"><span class="fr-empty__ps">$</span> vela scout ./papers --frontier ./frontier.json
<span class="fr-empty__ps">$</span> vela compile-notes ./notes --frontier ./frontier.json
<span class="fr-empty__ps">$</span> vela compile-code  ./code  --frontier ./frontier.json
<span class="fr-empty__ps">$</span> vela compile-data  ./data  --frontier ./frontier.json</pre>
              <p class="fr-empty__doctrine">Agents propose. Humans review. The CLI signs.</p>
            </div>
          </div>
        </section>

        <section class="fr-pane" data-pane="diff" hidden>
          <div class="df-summary" id="df-summary"></div>
          <div class="df-events" id="df-events">
            <div class="fr-empty fr-empty--guided">
              <div class="fr-empty__title">The Diff is the canonical event log.</div>
              <p class="fr-empty__body">
                Every accepted proposal becomes a signed event here. The log
                replays byte-identically — pull this frontier on another
                machine and you reconstruct the same state.
              </p>
              <pre class="fr-empty__cmd"><span class="fr-empty__ps">$</span> vela queue sign --actor reviewer:you --key ./keys/private.key --yes-to-all</pre>
            </div>
          </div>
        </section>

        <section class="fr-pane" data-pane="snapshots" hidden>
          <div class="fr-snaps" id="fr-snaps"></div>
        </section>

        <section class="fr-pane" data-pane="deps" hidden>
          <div class="fr-deps" id="fr-deps">
            <div class="fr-empty">No cross-frontier dependencies.</div>
          </div>
        </section>

        <section class="fr-pane" data-pane="actors" hidden>
          <div class="fr-actors" id="fr-actors">
            <div class="fr-empty">No actors registered.</div>
          </div>
        </section>

        <section class="fr-pane" data-pane="about" hidden>
          <div class="fr-about" id="fr-about"></div>
        </section>
      </div>

      <aside class="fr-side">
        <div class="fr-side__group">
          <h4 class="fr-side__head">About</h4>
          <p class="fr-side__about" id="fr-side-desc">—</p>
        </div>
        <div class="fr-side__group">
          <h4 class="fr-side__head">Identity</h4>
          <dl class="fr-side__dl">
            <dt>vfr_id</dt><dd id="fr-side-vfr">—</dd>
            <dt>schema</dt><dd id="fr-side-schema">—</dd>
            <dt>compiler</dt><dd id="fr-side-compiler">—</dd>
            <dt>compiled</dt><dd id="fr-side-compiled">—</dd>
          </dl>
        </div>
        <div class="fr-side__group">
          <h4 class="fr-side__head">Signature</h4>
          <dl class="fr-side__dl">
            <dt>owner</dt><dd id="fr-side-owner">—</dd>
            <dt>pubkey</dt><dd id="fr-side-pubkey" title="">—</dd>
            <dt>signed</dt><dd id="fr-side-signed">—</dd>
            <dt>locator</dt><dd id="fr-side-locator">—</dd>
          </dl>
        </div>
        <div class="fr-side__group">
          <h4 class="fr-side__head">Stats</h4>
          <dl class="fr-side__dl">
            <dt>findings</dt><dd id="fr-side-fc">—</dd>
            <dt>events</dt><dd id="fr-side-ec">—</dd>
            <dt>proposals</dt><dd id="fr-side-pc">—</dd>
            <dt>snapshots</dt><dd id="fr-side-sc">—</dd>
          </dl>
        </div>
        <div class="fr-side__group">
          <h4 class="fr-side__head">Pull this frontier</h4>
          <pre class="fr-side__cmd" id="fr-side-cmd">vela registry pull …</pre>
        </div>
      </aside>
    </div>

    {/*
      Cross-reference back to Borrowed Light. The frontier the
      reader is poking at exists because the essay there argues
      it should. Reinforces the architecture: this substrate ←
      that essay. Same shape as the colophon on the Vela index.
    */}
    <aside class="fr-coda" aria-label="Borrowed Light essay">
      <a class="fr-coda__link" href="https://borrowedlight.org" rel="noopener">
        <svg class="fr-coda__lantern" viewBox="0 0 64 96" aria-hidden="true" focusable="false">
          <circle cx="32" cy="6" r="1.6" fill="currentColor" opacity="0.85" />
          <path d="M14 18 L32 9 L50 18 L46 21 L18 21 Z" fill="none" stroke="currentColor" stroke-width="1.1" stroke-linejoin="round" />
          <line x1="14" y1="21" x2="50" y2="21" stroke="currentColor" stroke-width="0.7" opacity="0.55" />
          <rect x="20" y="22" width="24" height="22" fill="none" stroke="currentColor" stroke-width="1.1" stroke-linejoin="round" />
          <line x1="28" y1="22" x2="28" y2="44" stroke="currentColor" stroke-width="0.55" opacity="0.5" />
          <line x1="36" y1="22" x2="36" y2="44" stroke="currentColor" stroke-width="0.55" opacity="0.5" />
          <circle cx="32" cy="33" r="3.2" fill="var(--vela-lantern-gold)" opacity="0.9" />
          <circle cx="32" cy="33" r="6" fill="var(--vela-lantern-gold)" opacity="0.16" />
          <path d="M16 44 L48 44 L46 48 L18 48 Z" fill="none" stroke="currentColor" stroke-width="1.1" stroke-linejoin="round" />
          <line x1="28" y1="48" x2="28" y2="78" stroke="currentColor" stroke-width="1.1" />
          <line x1="36" y1="48" x2="36" y2="78" stroke="currentColor" stroke-width="1.1" />
          <path d="M14 78 L50 78 L52 84 L12 84 Z" fill="none" stroke="currentColor" stroke-width="1.1" stroke-linejoin="round" />
        </svg>
        <span class="fr-coda__pair">
          <span class="fr-coda__sub">the essay this substrate was built for</span>
          <span class="fr-coda__title">← Borrowed Light</span>
        </span>
      </a>
    </aside>
  </article>
</Page>

<style>
  .fr {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  /* === Header card === */
  .fr-hdr {
    background: var(--paper-0);
    border: 1px solid var(--rule-2);
    border-radius: var(--radius-1);
    padding: 22px 24px;
    position: relative;
  }
  .fr-hdr::before {
    content: "";
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 6px;
    background-image: linear-gradient(to right, var(--rule-3) 0 1px, transparent 1px 100%);
    background-size: 12px 100%;
    background-repeat: repeat-x;
    opacity: 0.5;
    border-radius: var(--radius-1) var(--radius-1) 0 0;
  }
  .fr-hdr__row {
    display: flex;
    gap: 28px;
    align-items: flex-start;
    justify-content: space-between;
    padding-top: 6px;
  }
  .fr-hdr__main { min-width: 0; flex: 1; }
  .fr-hdr__owner-line {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 6px;
    font-family: var(--font-serif);
    font-size: 26px;
    line-height: 1.15;
    letter-spacing: -0.012em;
    color: var(--ink-0);
    margin-bottom: 12px;
  }
  .fr-hdr__owner {
    font-family: var(--font-mono);
    font-size: 14px;
    color: var(--ink-3);
    border-bottom: 1px solid transparent;
  }
  .fr-hdr__owner:hover { color: var(--ink-1); border-bottom-color: var(--rule-2); }
  .fr-hdr__sep { color: var(--ink-4); font-family: var(--font-mono); font-size: 14px; }
  .fr-hdr__name { color: var(--ink-0); }
  .fr-hdr__sig {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--state-ok);
    margin-left: 8px;
    align-self: center;
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }
  .fr-hdr__sig::before {
    content: "";
    width: 5px; height: 5px;
    border-radius: 50%;
    background: var(--state-ok);
    box-shadow: 0 0 0 2px rgba(63, 107, 78, 0.16);
  }

  .fr-hdr__desc {
    font-family: var(--font-serif);
    font-size: 16px;
    line-height: 1.55;
    color: var(--ink-2);
    margin: 0 0 14px;
    max-width: 64ch;
  }

  .fr-hdr__chiprow {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  /* .frc chips appear both in static markup and runtime-injected
     snapshot rows; global so both render the same. */
  :global(.frc) {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.04em;
    color: var(--ink-2);
    background: var(--paper-1);
    border: 1px solid var(--rule-1);
    padding: 3px 8px;
    border-radius: 3px;
    white-space: nowrap;
  }
  :global(.frc--mono) { color: var(--ink-3); }
  :global(.frc--ok) { color: var(--state-ok); border-color: rgba(63, 107, 78, 0.18); background: rgba(63, 107, 78, 0.06); }

  .fr-hdr__cta {
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex-shrink: 0;
    min-width: 200px;
  }
  .fr-hdr__cta .wb-btn { justify-content: space-between; }

  /* === Tabs === */
  .fr-tabs {
    display: flex;
    gap: 0;
    border-bottom: 1px solid var(--rule-2);
    margin: 0;
    overflow-x: auto;
  }
  .fr-tab {
    border: 0;
    background: transparent;
    padding: 12px 16px;
    font-family: var(--font-sans);
    font-size: 13px;
    color: var(--ink-3);
    cursor: pointer;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    transition: color var(--dur-1) var(--ease), border-color var(--dur-1) var(--ease);
    white-space: nowrap;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .fr-tab:hover { color: var(--ink-1); }
  .fr-tab--on { color: var(--ink-0); border-bottom-color: var(--ink-0); }
  .fr-tab__count {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--ink-3);
    background: var(--paper-1);
    border: 1px solid var(--rule-1);
    padding: 1px 6px;
    border-radius: 8px;
    font-variant-numeric: tabular-nums;
  }
  .fr-tab--on .fr-tab__count { color: var(--ink-1); border-color: var(--rule-2); }

  /* === Body === */
  .fr-body {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 280px;
    gap: 36px;
  }
  @media (max-width: 960px) {
    .fr-body { grid-template-columns: 1fr; }
    .fr-hdr__row { flex-direction: column; }
    .fr-hdr__cta { width: 100%; min-width: 0; flex-direction: row; flex-wrap: wrap; }
  }

  .fr-pane[hidden] { display: none; }

  /* Toolbar (findings) */
  .fr-toolbar {
    display: flex;
    gap: 10px;
    align-items: center;
    margin-bottom: 12px;
  }
  .fr-search {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border: 1px solid var(--rule-2);
    border-radius: 4px;
    padding: 6px 10px;
    background: var(--paper-0);
    width: 100%;
  }
  .fr-search:focus-within { border-color: var(--rule-ink); }
  .fr-search svg { color: var(--ink-3); flex-shrink: 0; }
  .fr-search input {
    flex: 1;
    border: 0;
    outline: 0;
    background: transparent;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--ink-1);
  }
  .fr-search input::placeholder { color: var(--ink-4); }
  .fr-search__count {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--ink-3);
    flex-shrink: 0;
  }

  /* === Findings list === */
  .fr-findings {
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--rule-1);
  }
  /* Rows below are injected via innerHTML at runtime, so they need to
     escape Astro's scoped-style hash. Use :global() so the selectors
     match the un-hashed elements the script generates. */
  :global(.ff) {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 16px;
    padding: 14px 4px;
    border-bottom: 1px solid var(--rule-1);
    color: var(--ink-1);
    text-decoration: none;
    transition: background var(--dur-1) var(--ease);
  }
  :global(.ff:hover) { background: var(--paper-1); }
  :global(.ff:hover .ff__claim) { color: var(--signal); }
  :global(.ff__main) { min-width: 0; }
  :global(.ff__claim) {
    font-family: var(--font-serif);
    font-size: 16px;
    line-height: 1.4;
    color: var(--ink-0);
    margin-bottom: 6px;
    transition: color var(--dur-1) var(--ease);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  :global(.ff__sub) {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--ink-3);
    letter-spacing: 0.04em;
    display: flex;
    flex-wrap: wrap;
    gap: 0 12px;
  }
  :global(.ff__sub strong) { color: var(--ink-2); font-weight: 500; }
  :global(.ff__meta) {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--ink-3);
    text-align: right;
    white-space: nowrap;
    flex-shrink: 0;
  }
  :global(.ff__kind) {
    display: inline-block;
    padding: 2px 7px;
    border: 1px solid var(--rule-2);
    border-radius: 3px;
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  :global(.ff__kind--retraction)        { color: var(--state-lost); border-color: rgba(138, 58, 58, 0.32); }
  :global(.ff__kind--revision)          { color: var(--state-warn); border-color: rgba(138, 106, 31, 0.32); }
  :global(.ff__kind--annotation)        { color: var(--state-stale); border-color: var(--rule-2); }
  :global(.ff__kind--observation)       { color: var(--state-ok); border-color: rgba(63, 107, 78, 0.32); }
  :global(.ff__kind--therapeutic)       { color: var(--signal); border-color: var(--signal-edge); }
  :global(.ff__kind--mechanistic)       { color: var(--ink-2); border-color: var(--rule-3); }
  :global(.ff__kind--methodological)    { color: var(--state-stale); border-color: var(--rule-2); }
  /* v0.23 Notes Compiler */
  :global(.ff__kind--open_question)     { color: var(--signal); border-color: var(--signal-edge); }
  :global(.ff__kind--hypothesis)        { color: var(--state-warn); border-color: rgba(138, 106, 31, 0.32); }
  :global(.ff__kind--candidate_finding) { color: var(--state-ok); border-color: rgba(63, 107, 78, 0.32); }
  :global(.ff__kind--tension)           { color: var(--state-lost); border-color: rgba(138, 58, 58, 0.32); }
  /* v0.28.x Contradiction Finder — same hue as tension. */
  :global(.ff__kind--cross_finding_tension) { color: var(--state-lost); border-color: rgba(138, 58, 58, 0.32); }
  /* v0.24 Code & Notebook Analyst */
  :global(.ff__kind--analysis_run)      { color: var(--state-ok); border-color: rgba(63, 107, 78, 0.32); }
  :global(.ff__kind--code_derived)      { color: var(--signal); border-color: var(--signal-edge); }
  :global(.ff__kind--experiment_intent) { color: var(--state-warn); border-color: rgba(138, 106, 31, 0.32); }
  /* v0.25 Datasets */
  :global(.ff__kind--dataset_summary)        { color: var(--state-stale); border-color: var(--rule-2); }
  :global(.ff__kind--dataset_supported_claim){ color: var(--signal); border-color: var(--signal-edge); }
  :global(.ff__kind--unknown)           { color: var(--ink-3); }

  /* === Snapshots === */
  .fr-snaps {
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--rule-1);
  }
  :global(.fs) {
    display: flex;
    align-items: baseline;
    gap: 16px;
    padding: 12px 4px;
    border-bottom: 1px solid var(--rule-1);
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--ink-2);
  }
  :global(.fs__hash) { flex: 1; min-width: 0; overflow: hidden; text-overflow: ellipsis; color: var(--ink-1); }
  :global(.fs__when) { color: var(--ink-3); white-space: nowrap; }
  :global(.fs__sig) { color: var(--state-ok); font-size: 9px; letter-spacing: 0.1em; text-transform: uppercase; }
  :global(.fs__open) {
    color: var(--ink-3);
    border-bottom: 1px solid var(--rule-2);
    text-decoration: none;
    font-size: 10px;
  }
  :global(.fs__open:hover) { color: var(--signal); border-bottom-color: var(--signal); }

  /* === Deps === */
  :global(.fd) {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 14px 4px;
    border-bottom: 1px solid var(--rule-1);
    text-decoration: none;
  }
  :global(.fd:hover .fd__name) { color: var(--signal); }
  :global(.fd__name) {
    font-family: var(--font-serif);
    font-size: 16px;
    color: var(--ink-0);
    transition: color var(--dur-1) var(--ease);
  }
  :global(.fd__sub) {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--ink-3);
  }

  /* === Actors === */
  :global(.fa) {
    display: flex;
    align-items: baseline;
    gap: 14px;
    padding: 12px 4px;
    border-bottom: 1px solid var(--rule-1);
  }
  :global(.fa__handle) {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--ink-1);
    min-width: 200px;
  }
  :global(.fa__pubkey) {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--ink-3);
    flex: 1;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  :global(.fa__tier) {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-3);
    border: 1px solid var(--rule-2);
    padding: 2px 7px;
    border-radius: 3px;
  }

  /* === About === */
  .fr-about {
    font-family: var(--font-serif);
    font-size: 16px;
    line-height: 1.6;
    color: var(--ink-1);
    max-width: 64ch;
    padding: 8px 0;
  }
  /* === Inbox === */
  .ib-banner {
    margin: 0 0 14px;
    padding: 12px 14px;
    background: var(--paper-1);
    border: 1px solid var(--rule-2);
    border-left: 3px solid var(--signal);
    border-radius: var(--radius-1);
    display: flex;
    align-items: center;
    gap: 14px;
    flex-wrap: wrap;
  }
  .ib-banner__text {
    font-family: var(--font-serif);
    font-size: 14px;
    color: var(--ink-1);
    flex: 1;
    min-width: 220px;
  }
  .ib-banner__cmd {
    font-family: var(--font-mono);
    font-size: 12px;
    color: #E6E1D4;
    background: var(--ink-0);
    padding: 6px 10px;
    border-radius: 3px;
  }
  .ib-banner__copy {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.06em;
    color: var(--ink-2);
    background: var(--paper-0);
    border: 1px solid var(--rule-2);
    padding: 5px 10px;
    border-radius: 3px;
    cursor: pointer;
    transition: color var(--dur-1) var(--ease), border-color var(--dur-1) var(--ease);
  }
  .ib-banner__copy:hover { color: var(--ink-0); border-color: var(--rule-ink); }

  .ib-summary {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--ink-3);
    letter-spacing: 0.04em;
    padding: 8px 0 14px;
    border-bottom: 1px solid var(--rule-1);
    margin-bottom: 12px;
  }
  .ib-summary strong { color: var(--ink-1); font-weight: 500; }
  .ib-runs { display: flex; flex-direction: column; gap: 18px; }

  /* Run header + proposal cards are runtime-injected; need :global. */
  :global(.ib-run) {
    border: 1px solid var(--rule-2);
    border-radius: var(--radius-1);
    background: var(--paper-0);
    overflow: hidden;
  }
  :global(.ib-run__head) {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 12px;
    padding: 12px 14px;
    background: var(--paper-1);
    border-bottom: 1px solid var(--rule-1);
  }
  :global(.ib-run__agent) {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-1);
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  :global(.ib-run__agent::before) {
    content: "";
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--signal);
    box-shadow: 0 0 0 2px var(--signal-soft);
  }
  :global(.ib-run__id) {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--ink-3);
    letter-spacing: 0.04em;
  }
  :global(.ib-run__model) {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--ink-3);
  }
  :global(.ib-run__when) {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--ink-3);
    margin-left: auto;
  }
  :global(.ib-run__count) {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--ink-2);
    background: var(--paper-0);
    border: 1px solid var(--rule-2);
    padding: 1px 7px;
    border-radius: 8px;
  }

  :global(.ib-card) {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 16px;
    padding: 14px 14px;
    border-bottom: 1px solid var(--rule-1);
  }
  :global(.ib-card:last-child) { border-bottom: 0; }
  :global(.ib-card__main) { min-width: 0; }
  :global(.ib-card__claim) {
    font-family: var(--font-serif);
    font-size: 16px;
    line-height: 1.4;
    color: var(--ink-0);
    margin: 0 0 8px;
  }
  :global(.ib-card__rationale) {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 13px;
    line-height: 1.5;
    color: var(--ink-2);
    margin: 0 0 8px;
  }
  :global(.ib-card__sub) {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 8px;
  }
  :global(.ib-card__chip) {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.04em;
    color: var(--ink-3);
    background: var(--paper-1);
    border: 1px solid var(--rule-1);
    padding: 2px 7px;
    border-radius: 3px;
  }
  :global(.ib-card__chip--source) { color: var(--ink-2); }
  :global(.ib-card__chip--id) { color: var(--ink-3); }
  :global(.ib-card__chip--flag) {
    color: var(--state-warn);
    border-color: rgba(138, 106, 31, 0.32);
  }
  :global(.ib-card__chip--flag--low_confidence) {
    color: var(--state-stale);
    border-color: var(--rule-2);
  }
  :global(.ib-card__chip--flag--possible_duplicate) {
    color: var(--state-lost);
    border-color: rgba(138, 58, 58, 0.32);
  }

  :global(.ib-card__meta) {
    text-align: right;
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--ink-3);
    white-space: nowrap;
  }
  :global(.ib-card__pending) {
    display: inline-block;
    padding: 2px 7px;
    border: 1px solid var(--rule-2);
    border-radius: 3px;
    color: var(--ink-2);
    margin-bottom: 4px;
  }

  /* Staged state: card visually fades + tints depending on action. */
  :global(.ib-card.is-staged-accept) { background: rgba(63, 107, 78, 0.06); }
  :global(.ib-card.is-staged-reject) { background: rgba(138, 58, 58, 0.06); }
  :global(.ib-card.is-disabled-actions) { opacity: 0.85; }

  :global(.ib-card__actions) {
    display: flex;
    gap: 6px;
    margin-top: 8px;
    justify-content: flex-end;
  }
  :global(.ib-card__btn) {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 5px 11px;
    border-radius: 3px;
    cursor: pointer;
    background: var(--paper-0);
    border: 1px solid var(--rule-2);
    color: var(--ink-2);
    transition: color var(--dur-1) var(--ease),
                background var(--dur-1) var(--ease),
                border-color var(--dur-1) var(--ease);
  }
  :global(.ib-card__btn:hover:not(:disabled)) {
    color: var(--ink-0);
    border-color: var(--rule-ink);
  }
  :global(.ib-card__btn:disabled) { cursor: default; opacity: 0.6; }
  :global(.ib-card__btn--accept:hover:not(:disabled)) {
    color: var(--state-ok);
    border-color: rgba(63, 107, 78, 0.4);
    background: rgba(63, 107, 78, 0.08);
  }
  :global(.ib-card__btn--reject:hover:not(:disabled)) {
    color: var(--state-lost);
    border-color: rgba(138, 58, 58, 0.4);
    background: rgba(138, 58, 58, 0.08);
  }

  :global(.ib-card__staged-pill) {
    display: inline-block;
    padding: 2px 7px;
    border: 1px solid;
    border-radius: 3px;
    margin-bottom: 4px;
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  :global(.ib-card__staged-pill--accept) {
    color: var(--state-ok);
    border-color: rgba(63, 107, 78, 0.4);
  }
  :global(.ib-card__staged-pill--reject) {
    color: var(--state-lost);
    border-color: rgba(138, 58, 58, 0.4);
  }

  :global(.ib-card__hint) {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--ink-3);
    margin-top: 6px;
    text-align: right;
    font-style: italic;
  }

  /* === Diff (event log) === */
  .df-summary {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    padding: 8px 0 14px;
    border-bottom: 1px solid var(--rule-1);
    margin-bottom: 12px;
  }
  .df-summary__chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 10px;
    border: 1px solid var(--rule-2);
    border-radius: 3px;
    background: var(--paper-0);
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.04em;
    color: var(--ink-2);
  }
  .df-summary__chip strong {
    color: var(--ink-0);
    font-weight: 500;
    font-variant-numeric: tabular-nums;
  }

  /* Event rows are runtime-injected; need :global. */
  :global(.df-event) {
    display: grid;
    grid-template-columns: 110px minmax(0, 1fr) auto;
    gap: 14px;
    padding: 12px 4px;
    border-bottom: 1px solid var(--rule-1);
    align-items: baseline;
  }
  :global(.df-event:last-child) { border-bottom: 0; }
  :global(.df-event__kind) {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 3px 8px;
    border: 1px solid var(--rule-2);
    border-radius: 3px;
    text-align: center;
    color: var(--ink-2);
    background: var(--paper-0);
  }
  :global(.df-event__kind--add)      { color: var(--state-ok); border-color: rgba(63, 107, 78, 0.32); }
  :global(.df-event__kind--review)   { color: var(--signal); border-color: var(--signal-edge); }
  :global(.df-event__kind--retract)  { color: var(--state-lost); border-color: rgba(138, 58, 58, 0.32); }
  :global(.df-event__kind--note)     { color: var(--state-stale); border-color: var(--rule-2); }
  :global(.df-event__kind--caveat)   { color: var(--state-warn); border-color: rgba(138, 106, 31, 0.32); }
  :global(.df-event__kind--revise)   { color: var(--state-warn); border-color: rgba(138, 106, 31, 0.32); }
  :global(.df-event__kind--unknown)  { color: var(--ink-3); }

  :global(.df-event__main) { min-width: 0; }
  :global(.df-event__target) {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--ink-1);
    margin-bottom: 4px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  :global(.df-event__reason) {
    font-family: var(--font-serif);
    font-size: 13px;
    line-height: 1.45;
    color: var(--ink-2);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  :global(.df-event__sub) {
    margin-top: 6px;
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--ink-3);
    letter-spacing: 0.04em;
    display: flex;
    flex-wrap: wrap;
    gap: 0 12px;
  }
  :global(.df-event__sub strong) { color: var(--ink-2); font-weight: 500; }
  :global(.df-event__when) {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--ink-3);
    text-align: right;
    white-space: nowrap;
    align-self: start;
    padding-top: 3px;
  }

  @media (max-width: 720px) {
    :global(.df-event) {
      grid-template-columns: 1fr;
      gap: 6px;
    }
    :global(.df-event__when) { text-align: left; }
  }

  /* About content is innerHTML-injected; needs :global. */
  :global(.fr-about p) { margin: 0 0 1em; }
  :global(.fr-about pre) {
    background: var(--paper-1);
    border: 1px solid var(--rule-1);
    padding: 12px;
    border-radius: var(--radius-1);
    overflow-x: auto;
    font-family: var(--font-mono);
    font-size: 12px;
  }
  :global(.fr-about code) {
    font-family: var(--font-mono);
    font-size: 13px;
    background: var(--paper-1);
    padding: 1px 5px;
    border-radius: 2px;
