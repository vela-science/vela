    margin: 0 auto;
    padding: 0;
  }

  .wc__lede {
    font-family: var(--font-sans);
    font-size: 0.98rem;
    line-height: 1.6;
    color: var(--ink-2);
    margin: 0 0 var(--rhythm-section);
    max-width: 70ch;
  }
  .wc__inline {
    color: var(--ink-1);
    text-decoration: underline;
    text-decoration-color: color-mix(in oklab, var(--gold) 56%, transparent);
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
    transition: color var(--dur-1) var(--ease), text-decoration-color var(--dur-1) var(--ease);
