    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--ink-0);
    margin: 0;
    text-wrap: balance;
  }
  .spec__body p {
    font-family: var(--font-sans);
    font-size: 0.98rem;
    line-height: 1.62;
    letter-spacing: -0.005em;
    color: color-mix(in oklab, var(--ink-1) 90%, var(--ink-2));
    margin: 0 0 var(--space-3);
    max-width: 70ch;
    text-wrap: pretty;
  }
  .spec__body p strong {
    color: var(--ink-0);
    font-family: var(--font-mono);
    font-size: 0.92em;
    letter-spacing: 0.06em;
  }
  .spec__pair {
    display: grid;
    grid-template-columns: 14rem 1fr;
    gap: 0.75rem var(--space-5);
    margin: 0 0 var(--space-4);
  }
  .spec__pair--narrow { grid-template-columns: 16rem 1fr; }
  .spec__pair dt {
