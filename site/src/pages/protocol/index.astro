---
/*
  Protocol page — short, interactive, show by doing.

  Was a docs-shaped wall of prose; now a 4-section essay where each
  section opens with a watercolor plate + glyph and contains ONE
  sentence + a working interactive demonstration of the concept.
  Whitepaper-shaped depth lives in /docs.
*/

import Page from "../../layouts/Page.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import ImagePlate from "../../components/ImagePlate.astro";
import Imprint from "../../components/Imprint.astro";
import ClaimCard from "../../components/ClaimCard.astro";
import LiveHub from "../../components/LiveHub.astro";
import TerminalPaper from "../../components/TerminalPaper.astro";
import { loadFrontier } from "../../lib/frontier";
import { HUB_URL, REPO_URL, VERSION } from "../../config";

// Pick the highest-confidence claim as the "show, don't tell" example.
const allClaims = loadFrontier();
const featuredClaim = allClaims
  .slice()
  .sort((a, b) => b.finding.confidence.score - a.finding.confidence.score)[0];
---

<Page
  title="Vela protocol · scientific memory for humans and AI"
  description="A short, interactive walkthrough of the Vela protocol: findings, constellations, proof packets, and how to use it."
  active="protocol"
  eyebrow="00 · The protocol"
  pageTitle="The protocol"
  subtitle="Scientific memory humans and agents can correct, replay, and sign."
>
  <div slot="aside">
    <a href={REPO_URL} class="aside-link">github</a>
    <span>·</span>
    <a href={HUB_URL} class="aside-link">hub</a>
    <span class="aside-version" title={`Vela ${VERSION}`}>v{VERSION}</span>
  </div>

  <article class="protocol">
    <!-- ── Hero ── -->
    <section class="protocol__hero">
      <ImagePlate
        fallback="/images/plates/frontier.png"
        width={1916}
        height={821}
        alt="A quiet watercolor cross-section beneath a horizon, with faint navy and gold stars forming above structured records below."
      />
      <p class="protocol__hook">
        <em>Four nouns, one binary.</em>
      </p>
      <p class="protocol__sub">
        Vela is the smallest substrate that holds: a finding has a content-addressed id,
        a constellation of findings has a content-addressed id,
        two implementations agree byte-for-byte, the signature is the bind.
      </p>
    </section>

    <!-- ── §1 Finding ── -->
    <section class="protocol__section">
      <SectionHeading title="Finding" glyph="finding" kicker="§1 · the unit" />
      <ImagePlate
        fallback="/images/plates/finding.png"
        width={1916}
        height={821}
        alt="A single bright watercolor pinpoint surrounded by faint atmospheric rings."
      />
      <p class="protocol__line">
        A typed assertion with evidence, conditions, confidence, provenance,
        and a content-addressed <code>vf_…</code> id. The unit science writes once and refers to everywhere.
      </p>
      {featuredClaim && (
        <div class="protocol__demo">
          <ClaimCard claim={featuredClaim} />
          <p class="protocol__demo-caption">
            ↑ One real finding from the live frontier. Click for evidence.
          </p>
        </div>
      )}
    </section>

    <!-- ── §2 Constellation ── -->
    <section class="protocol__section">
      <SectionHeading title="Constellation" glyph="constellation" kicker="§2 · the field" />
      <ImagePlate
        fallback="/images/plates/constellation.png"
        width={1817}
        height={866}
        alt="A watercolor field of navy and gold stars connected by faint dotted arcs across pale paper."
      />
      <p class="protocol__line">
        A bounded set of findings, the links between them, and the event log of every change.
        Has a content-addressed <code>vfr_…</code> id. Two machines compute the same hash from the same constellation, or one of them is wrong.
      </p>
      <div class="protocol__demo">
        <LiveHub />
        <p class="protocol__demo-caption">
          ↑ Live hub status. Each entry is a signed manifest pointing at a constellation.
          <a class="inline-link" href="/workbench">Open the workbench →</a>
          <span class="protocol__sep">·</span>
          <a class="inline-link" href="/replay">Drag through one event log →</a>
        </p>
      </div>
    </section>

    <!-- ── §3 Proof ── -->
    <section class="protocol__section">
      <SectionHeading title="Proof packet" glyph="proof" kicker="§3 · the seam" />
      <ImagePlate
        fallback="/images/plates/proof.png"
        width={1672}
        height={941}
        alt="A watercolor sealed envelope with a faint gold seam and atmospheric warmth."
      />
      <p class="protocol__line">
        A sealed snapshot another party can re-verify offline. Manifest, signed-trace chain, integrity lock, file-by-file SHA-256 — the bytes the skeptic actually wants to see.
      </p>
      <div class="protocol__demo">
        <div class="proof-excerpt">
          <div class="proof-excerpt__row"><span class="k">snapshot_hash</span><span class="v">f23b4aba173f3fb840c6ec2555715bdc…</span></div>
          <div class="proof-excerpt__row"><span class="k">event_log_hash</span><span class="v">4f53cda18c2baa0c0354bb5f9a3ecbe5…</span></div>
          <div class="proof-excerpt__row"><span class="k">vela_version</span><span class="v">0.8.0</span></div>
          <div class="proof-excerpt__row"><span class="k">findings</span><span class="v">48 · contested 1 · gaps 1 · sources 10</span></div>
          <div class="proof-excerpt__row"><span class="k">replay_status</span><span class="v">no_events</span></div>
          <div class="proof-excerpt__row"><span class="k">status</span><span class="v">ok</span></div>
        </div>
        <p class="protocol__demo-caption">
          ↑ Excerpt from a real BBB Flagship proof packet.
          Verify locally with <code>shasum -a 256</code>.
          <span class="protocol__sep">·</span>
          <a class="inline-link" href="/proof/pericyte-correction">See one Correction event in motion →</a>
        </p>
      </div>
    </section>

    <!-- ── §4 Use it ── -->
    <section class="protocol__section">
      <SectionHeading title="Use it" kicker="§4 · one binary" />
      <p class="protocol__line">
        Clone, build, publish your own bounded question.
      </p>
      <div class="protocol__terminals">
        <TerminalPaper title="install">
          <span class="tm-ps">$</span> <span class="tm-cmd">git clone</span> {REPO_URL}
<span class="tm-ps">$</span> <span class="tm-cmd">cd</span> vela <span class="tm-ps">&&</span> <span class="tm-cmd">cargo build</span> <span class="tm-flag">--release</span>
<span class="tm-ps">$</span> <span class="tm-cmd">./target/release/vela</span> <span class="tm-flag">--version</span>
        </TerminalPaper>
        <TerminalPaper title="publish your own constellation">
          <span class="tm-ps">$</span> <span class="tm-cmd">vela frontier new</span> ./constellation.json <span class="tm-flag">--name</span> "Your bounded question"
<span class="tm-ps">$</span> <span class="tm-cmd">vela finding add</span> ./constellation.json <span class="tm-flag">--assertion</span> "..." <span class="tm-flag">--apply</span>
<span class="tm-ps">$</span> <span class="tm-cmd">vela sign generate-keypair</span> <span class="tm-flag">--out</span> keys
<span class="tm-ps">$</span> <span class="tm-cmd">vela registry publish</span> ./constellation.json <span class="tm-flag">--key</span> keys/private.key <span class="tm-flag">--to</span> {HUB_URL}
        </TerminalPaper>
      </div>
      <p class="protocol__line protocol__line--muted">
        Walk-through with cross-frontier composition at <a class="inline-link" href="/publish">/publish</a>.
        Whitepaper-depth shape and schemas at <a class="inline-link" href="/docs/protocol">/docs/protocol</a>.
      </p>
    </section>

    <Imprint returnHref="/" returnLabel="Back to the live frontier" />
  </article>
</Page>

<style>
  .aside-link {
    font-family: var(--font-mono);
    font-size: var(--size-xs);
    letter-spacing: 0.06em;
    color: var(--ink-3);
  }
  .aside-link:hover { color: var(--gold); }
  .aside-version {
    font-family: var(--font-mono);
    font-size: var(--size-xs);
    letter-spacing: 0.06em;
    color: var(--ink-4);
    margin-left: 6px;
  }
  div[slot="aside"] {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .protocol {
    max-width: var(--measure-wide);
    margin: 0 auto;
    padding: 0;
  }

  /* ── Hero ── */
  .protocol__hero {
    margin: 0 0 clamp(2.5rem, 6vh, 4rem);
  }
  .protocol__hero :global(.vela-image-plate) {
    margin-top: 0;
    margin-bottom: 1.4rem;
  }
  .protocol__hook {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: clamp(1.45rem, 2.6vw, 1.95rem);
    line-height: 1.32;
    letter-spacing: var(--track-display);
    color: var(--ink-0);
    margin: 0 0 0.85rem;
    max-width: 44ch;
    text-wrap: balance;
  }
  .protocol__sub {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 1rem;
    line-height: 1.55;
    letter-spacing: -0.005em;
    color: color-mix(in oklab, var(--ink-2) 92%, transparent);
    margin: 0;
    max-width: 60ch;
  }

  /* ── Sections ── */
  .protocol__section {
    margin: 0 0 clamp(3rem, 7vh, 4.5rem);
  }
  .protocol__section :global(.vela-image-plate) {
    margin-top: 1rem;
    margin-bottom: 1.4rem;
  }
  .protocol__line {
    font-family: var(--font-body);
    font-size: 1.1rem;
    line-height: 1.6;
    color: color-mix(in oklab, var(--ink-1) 92%, var(--ink-2));
    margin: 0 0 1.4rem;
    max-width: 56ch;
    text-wrap: pretty;
  }
  .protocol__line--muted {
    font-size: 0.95rem;
    color: color-mix(in oklab, var(--ink-2) 88%, transparent);
    margin-top: 1.2rem;
  }
  .protocol__line code {
    font-family: var(--font-mono);
    font-size: 0.86em;
    color: var(--ink-1);
    background: var(--paper-1);
    padding: 1px 5px;
    border: 1px solid var(--rule-2);
    border-radius: var(--radius-xs);
  }

  /* ── Demo blocks (claim card, hub, proof excerpt) ── */
  .protocol__demo {
    margin: 1.2rem 0 0;
  }
  .protocol__demo-caption {
    margin: 0.85rem 0 0;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.04em;
    color: color-mix(in oklab, var(--ink-3) 92%, transparent);
  }
  .protocol__demo-caption code {
    font-family: var(--font-mono);
    font-size: 0.95em;
    color: var(--ink-2);
    background: var(--paper-1);
    padding: 1px 5px;
    border: 1px solid var(--rule-2);
    border-radius: var(--radius-xs);
  }
  .protocol__sep { color: var(--ink-4); margin: 0 4px; }

  /* Proof excerpt — a few rows from a real packet, mono table */
  .proof-excerpt {
    border-top: 1px solid color-mix(in oklab, var(--gold) 28%, transparent);
    border-bottom: 1px solid var(--rule-2);
    background: transparent;
    padding: 0;
  }
  .proof-excerpt__row {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 12px;
    padding: 10px 0;
    border-bottom: 1px solid var(--rule-1);
    align-items: baseline;
  }
  .proof-excerpt__row:last-child { border-bottom: 0; }
  .proof-excerpt__row .k {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: color-mix(in oklab, var(--gold) 64%, var(--ink-3));
    font-weight: 500;
  }
  .proof-excerpt__row .v {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--ink-1);
    word-break: break-all;
    letter-spacing: 0.02em;
  }

  .protocol__terminals {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
    margin: 0 0 0.4rem;
  }
  @media (max-width: 900px) {
    .protocol__terminals { grid-template-columns: 1fr; }
  }

  .inline-link {
    color: var(--ink-1);
    text-decoration: underline;
    text-decoration-color: color-mix(in oklab, var(--gold) 56%, transparent);
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
    transition: color var(--dur-1) var(--ease), text-decoration-color var(--dur-1) var(--ease);
  }
  .inline-link:hover {
    color: var(--gold);
    text-decoration-color: var(--gold);
  }

  @media (max-width: 720px) {
    .protocol__hook { font-size: 1.35rem; }
    .protocol__line { font-size: 1.02rem; }
    .proof-excerpt__row { grid-template-columns: 1fr; gap: 4px; }
  }
</style>
