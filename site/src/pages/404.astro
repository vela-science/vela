---
import Page from "../layouts/Page.astro";
---

<Page
  title="404 · Vela"
  description="Page not found."
  active="home"
  eyebrow="404"
  pageTitle="Not found"
  subtitle="A finding moves to a new id when its content changes. The canonical version is one of the routes below."
>
  <ul class="nf__paths">
    <li><a class="nf__link" href="/">/</a> — frontier home</li>
    <li><a class="nf__link" href="/spec">/spec</a> — protocol spec</li>
    <li><a class="nf__link" href="/sdk">/sdk</a> — SDK reference</li>
    <li><a class="nf__link" href="/quickstart">/quickstart</a> — five-command walkthrough</li>
    <li><a class="nf__link" href="/workbench">/workbench</a> — live BBB Flagship frontier</li>
    <li><a class="nf__link" href="/proof/pericyte-correction">/proof/pericyte-correction</a> — worked Correction</li>
  </ul>
</Page>

<style>
  .nf__paths {
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: 1px solid var(--rule-2);
  }
  .nf__paths li {
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--rule-1);
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--ink-2);
  }
  .nf__link {
    color: var(--ink-1);
    text-decoration: none;
    border-bottom: 1px solid color-mix(in oklab, var(--gold) 38%, transparent);
    padding-bottom: 1px;
    margin-right: 0.6rem;
  }
  .nf__link:hover { color: var(--gold); border-bottom-color: var(--gold); }
</style>
