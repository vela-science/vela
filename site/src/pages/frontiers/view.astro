  }

  /* Cross-reference colophon back to Borrowed Light. */
  .fr-coda {
    margin: 36px 0 8px;
    padding-top: 22px;
    border-top: 1px solid var(--rule-2);
  }
  .fr-coda__link {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    text-decoration: none;
    color: var(--ink-2);
