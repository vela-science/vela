  }
  .wc__dep-where {
    color: var(--ink-2);
    text-transform: none;
    letter-spacing: 0.04em;
    font-size: 11px;
  }
  .wc__dep-body {
    font-family: var(--font-body);
    font-size: 1.02rem;
