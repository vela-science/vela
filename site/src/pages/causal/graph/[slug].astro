---
/*
  Causal graph view for a single finding's neighborhood (v0.44.1).

  Renders 1-2 hops of parents (causes), children (downstream), and
  grandparents/grandchildren around a focal finding as a layered SVG.
  Edge color encodes the v0.44.0 back-door identifiability verdict
  for the focal-to-each-visible-pair effect; node color encodes the
  v0.40 audit verdict (identified / conditional / underidentified /
  underdetermined).

  This is the visible artifact of Pearl level 2 reasoning. Without
  it, the substrate's clearest novelty premium lives only in the
  CLI. With it, anyone hitting the site can see real back-door
  structure on a real Alzheimer's claim graph.
*/

import Page from "../../../layouts/Page.astro";
import {
  loadFrontier,
  causalNeighborhood,
  identifyEffect,
  type CausalNode,
  type Identifiability,
  type EffectVerdict,
} from "../../../lib/frontier";
import { FRONTIER, REPO_URL, VERSION } from "../../../config";

export async function getStaticPaths() {
  const claims = loadFrontier();
  return claims.map((c) => ({
    params: { slug: c.slug },
    props: { vfId: c.finding.id, slug: c.slug, finding: c.finding },
  }));
}

const { vfId, slug, finding } = Astro.props;
const neighborhood = causalNeighborhood(vfId);

// Layout constants — tuned for legibility on a 900px-wide content
// column. Layers from top to bottom: grandparents, parents, focal,
// children, grandchildren. Each layer wraps if more than ~5 nodes.
const NODE_W = 180;
const NODE_H = 56;
const LAYER_H = 110;
const X_GAP = 28;
const SVG_W = 980;

type Layer = { y: number; label: string; nodes: CausalNode[] };

const layers: Layer[] = neighborhood
  ? [
      { y: 0, label: "grandparents", nodes: neighborhood.grandparents },
      { y: LAYER_H, label: "parents", nodes: neighborhood.parents },
      { y: 2 * LAYER_H, label: "focal", nodes: [neighborhood.focal] },
      { y: 3 * LAYER_H, label: "children", nodes: neighborhood.children },
      { y: 4 * LAYER_H, label: "grandchildren", nodes: neighborhood.grandchildren },
    ]
  : [];

// Compute x positions per node by layer.
const nodePositions = new Map<string, { x: number; y: number; node: CausalNode }>();
for (const layer of layers) {
  if (layer.nodes.length === 0) continue;
  const totalW = layer.nodes.length * NODE_W + (layer.nodes.length - 1) * X_GAP;
  const startX = (SVG_W - totalW) / 2;
  layer.nodes.forEach((n, i) => {
    nodePositions.set(n.vf_id, {
      x: startX + i * (NODE_W + X_GAP),
      y: layer.y,
      node: n,
    });
  });
}

const SVG_H = layers.length * LAYER_H + NODE_H;

// Node fill / border by audit verdict.
const verdictColors: Record<Identifiability, { fill: string; stroke: string; chip: string }> = {
  identified:       { fill: "#dceadd", stroke: "#2f5d3a", chip: "ok" },
  conditional:      { fill: "#f0e7d0", stroke: "#8a6d1f", chip: "warn" },
  underidentified:  { fill: "#f3dada", stroke: "#872c2c", chip: "lost" },
  underdetermined:  { fill: "#e0ddd5", stroke: "#6b665d", chip: "stale" },
};

// Pairwise effect verdicts: focal → child, focal → grandchild,
// parent → focal, etc. Only useful for visible neighbors.
type EdgeView = {
  from: { x: number; y: number };
  to: { x: number; y: number };
  fromId: string;
  toId: string;
  verdict: EffectVerdict;
};

const edgeViews: EdgeView[] = neighborhood
  ? neighborhood.edges
      .map((e) => {
        const fp = nodePositions.get(e.from);
        const tp = nodePositions.get(e.to);
        if (!fp || !tp) return null;
        // identifyEffect direction: source → target.
        // Our edge convention: from = dependent (child), to = parent (cause).
        // The CAUSAL arrow is to → from (cause to dependent). For
        // effect-of-X-on-Y reasoning, we render the arrow following
        // causal direction: from parent (top) to dependent (bottom).
        const verdict = identifyEffect(e.to, e.from);
        return {
          from: { x: tp.x + NODE_W / 2, y: tp.y + NODE_H },
          to:   { x: fp.x + NODE_W / 2, y: fp.y },
          fromId: e.to,
          toId: e.from,
          verdict,
        };
      })
      .filter((x): x is EdgeView => x != null)
  : [];

function edgeStroke(v: EffectVerdict): { color: string; dash: string; width: number } {
  if (v.kind === "identified") {
    return v.adjustment_set.length === 0
      ? { color: "#2f5d3a", dash: "0", width: 1.6 }
      : { color: "#8a6d1f", dash: "0", width: 1.8 };
  }
  if (v.kind === "identified_by_front_door") {
    // Distinct from back-door amber: a brighter teal for front-door identification.
    return { color: "#1f6f7a", dash: "0", width: 1.8 };
  }
  if (v.kind === "underidentified") {
    return { color: "#872c2c", dash: "5 4", width: 2.0 };
  }
  return { color: "#a09a8d", dash: "0", width: 1.2 };
}

function trunc(s: string, n: number): string {
  if (s.length <= n) return s;
  return s.slice(0, n - 1) + "…";
}

const focalAssertion = neighborhood?.focal.assertion_text ?? finding.assertion.text;
const focalShort = trunc(focalAssertion, 100);
---

<Page
  title={`Causal graph · ${vfId} · ${FRONTIER.name}`}
  description={`Local causal neighborhood of ${vfId}. The substrate's Pearl-level reasoning rendered as a directed graph.`}
  active=""
  eyebrow="Causal graph"
  pageTitle={trunc(focalAssertion, 80)}
  subtitle="Pearl level 2 reasoning over the link graph. Arrows go from cause to effect."
>
  <div slot="aside">
    <a href={`/claims/${slug}`} class="aside-link">claim</a>
    <span>·</span>
    <a href="/causal/audit" class="aside-link">audit</a>
    <span>·</span>
    <a href={REPO_URL} class="aside-link">github</a>
    <span class="aside-version">v{VERSION}</span>
  </div>

  {neighborhood == null ? (
    <p class="cg-empty">
      Finding <code>{vfId}</code> is not in the frontier.
    </p>
  ) : (
    <>
      <aside class="cg-doctrine">
        <div class="cg-doctrine__eyebrow">Reading the graph</div>
        <p class="cg-doctrine__body">
          Each node is a finding (<code>vf_</code>); the focal node is highlighted in
          the middle row. Arrows point from cause to effect (parent to dependent).
          Node fill encodes the v0.40 identifiability verdict for the finding's own
          claim type and evidence grade. Edge color encodes the v0.44.1 identification
          verdict (back-door + front-door) for the corresponding effect:
        </p>
        <ul class="cg-legend">
          <li><span class="cg-legend__line cg-legend__line--green"></span> identified, no back-door adjustment needed</li>
          <li><span class="cg-legend__line cg-legend__line--amber"></span> identified, requires adjustment set Z (confounder)</li>
          <li><span class="cg-legend__line cg-legend__line--teal"></span> identified via front-door criterion (mediator-based, Pearl 1995 §3.3)</li>
          <li><span class="cg-legend__line cg-legend__line--red"></span> underidentified — open back-door path remains</li>
          <li><span class="cg-legend__line cg-legend__line--gray"></span> contextual edge (no pair-level analysis)</li>
        </ul>
      </aside>

      <section class="cg-viewport">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox={`0 0 ${SVG_W} ${SVG_H}`}
          width="100%"
          height="auto"
          role="img"
          aria-label={`Causal neighborhood of ${vfId}`}
          class="cg-svg"
        >
          <defs>
            <marker id="arrowhead-green" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
              <path d="M0,0 L10,5 L0,10 z" fill="#2f5d3a"/>
            </marker>
            <marker id="arrowhead-amber" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
              <path d="M0,0 L10,5 L0,10 z" fill="#8a6d1f"/>
            </marker>
            <marker id="arrowhead-teal" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
              <path d="M0,0 L10,5 L0,10 z" fill="#1f6f7a"/>
            </marker>
            <marker id="arrowhead-red" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
              <path d="M0,0 L10,5 L0,10 z" fill="#872c2c"/>
            </marker>
            <marker id="arrowhead-gray" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
              <path d="M0,0 L10,5 L0,10 z" fill="#a09a8d"/>
            </marker>
          </defs>

          <!-- Edges first so nodes render on top -->
          {edgeViews.map((e) => {
            const stroke = edgeStroke(e.verdict);
            const colorKey =
              e.verdict.kind === "identified" && e.verdict.adjustment_set.length === 0 ? "green" :
              e.verdict.kind === "identified" ? "amber" :
              e.verdict.kind === "identified_by_front_door" ? "teal" :
              e.verdict.kind === "underidentified" ? "red" : "gray";
            return (
              <line
                x1={e.from.x}
                y1={e.from.y}
                x2={e.to.x}
                y2={e.to.y}
                stroke={stroke.color}
                stroke-width={stroke.width}
                stroke-dasharray={stroke.dash}
                marker-end={`url(#arrowhead-${colorKey})`}
              >
                <title>
                  {`${e.fromId} → ${e.toId}: ${e.verdict.kind === "identified"
                    ? (e.verdict.adjustment_set.length === 0
                        ? "identified, no adjustment"
                        : `identified by adjusting on ${e.verdict.adjustment_set.join(", ")}`)
                    : e.verdict.kind === "underidentified"
                    ? "underidentified — open back-door path"
                    : e.verdict.kind === "no_causal_path"
                    ? "no causal path"
                    : "unknown"
                  }`}
                </title>
              </line>
            );
          })}

          <!-- Layer labels -->
          {layers.filter((l) => l.nodes.length > 0).map((l) => (
            <text
              x={20}
              y={l.y + NODE_H / 2 + 4}
              fill="#6b665d"
              font-size="10"
              font-family="ui-monospace, Menlo, monospace"
              text-transform="uppercase"
              letter-spacing="1"
            >
              {l.label}
            </text>
          ))}

          <!-- Nodes -->
          {Array.from(nodePositions.values()).map(({ x, y, node }) => {
            const c = verdictColors[node.verdict];
            const isFocal = node.vf_id === vfId;
            return (
              <a href={`/causal/graph/${node.slug}`}>
                <rect
                  x={x}
                  y={y}
                  width={NODE_W}
                  height={NODE_H}
                  rx={4}
                  fill={c.fill}
                  stroke={c.stroke}
                  stroke-width={isFocal ? 2.4 : 1.2}
                />
                <text
                  x={x + 10}
                  y={y + 18}
                  font-size="11"
                  font-family="ui-monospace, Menlo, monospace"
                  fill="#2a2a2a"
                  font-weight={isFocal ? 600 : 400}
                >
                  {node.vf_id}
                </text>
                <text
                  x={x + 10}
                  y={y + 36}
                  font-size="11"
                  fill="#2a2a2a"
                  font-family="Georgia, serif"
                >
                  {trunc(node.assertion_text, 28)}
                </text>
                <text
                  x={x + 10}
                  y={y + 50}
                  font-size="9"
                  fill="#6b665d"
                  font-family="ui-monospace, Menlo, monospace"
                  text-transform="uppercase"
                  letter-spacing="0.6"
                >
                  {node.verdict}
                  {node.causal_claim ? ` · ${node.causal_claim}` : ""}
                </text>
                <title>
                  {`${node.vf_id}\n${node.assertion_text}\nverdict: ${node.verdict}${node.causal_claim ? `\nclaim: ${node.causal_claim}` : ""}${node.causal_evidence_grade ? ` / ${node.causal_evidence_grade}` : ""}`}
                </title>
              </a>
            );
          })}
        </svg>
      </section>

      <section class="cg-summary">
        <h2 class="cg-summary__title">Neighborhood summary</h2>
        <dl class="cg-summary__dl">
          <dt>Focal</dt>
          <dd><a href={`/claims/${slug}`}>{vfId}</a> · {focalShort}</dd>
          <dt>Direct parents</dt>
          <dd>{neighborhood.parents.length} (findings the focal depends on)</dd>
          <dt>Direct children</dt>
          <dd>{neighborhood.children.length} (findings that depend on the focal)</dd>
          <dt>Grandparents</dt>
          <dd>{neighborhood.grandparents.length}</dd>
          <dt>Grandchildren</dt>
          <dd>{neighborhood.grandchildren.length}</dd>
          <dt>Edges shown</dt>
          <dd>{edgeViews.length}</dd>
        </dl>
        <p class="cg-summary__note">
          Hover any edge to see its identifiability verdict and adjustment set.
          Click any node to recenter the graph on that finding.
        </p>
      </section>
    </>
  )}
</Page>

<style>
  .cg-empty {
    padding: 2rem;
    text-align: center;
    color: var(--ink-2, #6b665d);
  }
  .cg-empty code {
    background: var(--bg-2, #f5f2ec);
    padding: 0.05em 0.3em;
    border-radius: 2px;
  }

  .cg-doctrine {
    border: 1px solid var(--rule-2, #d8d4cc);
    background: var(--bg-2, #f5f2ec);
    padding: 1rem 1.25rem;
    margin: 0 0 1.5rem 0;
    font-size: 0.92rem;
    line-height: 1.55;
  }
  .cg-doctrine__eyebrow {
    font-size: 0.74rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-2, #6b665d);
    margin-bottom: 0.4rem;
  }
  .cg-doctrine__body { margin: 0 0 0.6rem 0; }
  .cg-doctrine code {
    background: var(--bg-3, #ebe6dd);
    padding: 0.05em 0.3em;
    border-radius: 2px;
    font-size: 0.88em;
  }
  .cg-legend {
    list-style: none;
    padding: 0;
    margin: 0.5rem 0 0 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.4rem 1rem;
    font-size: 0.86rem;
    color: var(--ink-2, #6b665d);
  }
  .cg-legend__line {
    display: inline-block;
    width: 28px;
    height: 2px;
    margin-right: 6px;
    vertical-align: middle;
  }
  .cg-legend__line--green { background: #2f5d3a; }
  .cg-legend__line--amber { background: #8a6d1f; }
  .cg-legend__line--teal { background: #1f6f7a; }
  .cg-legend__line--red {
    background: linear-gradient(to right, #872c2c 0 5px, transparent 5px 9px, #872c2c 9px 14px, transparent 14px 18px, #872c2c 18px 23px, transparent 23px 28px);
    height: 3px;
  }
  .cg-legend__line--gray { background: #a09a8d; }

  .cg-viewport {
    border: 1px solid var(--rule-2, #d8d4cc);
    background: var(--bg-1, #fafaf6);
    padding: 1rem;
    margin: 0 0 1.5rem 0;
    overflow-x: auto;
  }
  .cg-svg {
    display: block;
    min-width: 760px;
  }
  .cg-svg a:hover rect {
    filter: brightness(0.97);
    stroke-width: 2.4 !important;
  }

  .cg-summary {
    margin: 0 0 2rem 0;
  }
  .cg-summary__title {
    font-size: 1rem;
    font-weight: 500;
    margin: 0 0 0.6rem 0;
  }
  .cg-summary__dl {
    display: grid;
    grid-template-columns: 14rem 1fr;
    gap: 0.4rem 1rem;
    font-size: 0.92rem;
  }
  .cg-summary__dl dt {
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-2, #6b665d);
    padding-top: 0.1rem;
  }
  .cg-summary__dl dd { margin: 0; }
  .cg-summary__dl a {
    color: var(--ink-1, #2a2a2a);
    border-bottom: 1px solid var(--rule-3, #c8c2b5);
    text-decoration: none;
    font-family: var(--font-mono, monospace);
    font-size: 0.88rem;
  }
  .cg-summary__note {
    margin-top: 0.8rem;
    color: var(--ink-2, #6b665d);
    font-size: 0.88rem;
    line-height: 1.5;
  }
</style>
