---
// The Vela mark — three rings, alidade, signal star.
// Strokes use currentColor so the mark adapts to ink in light/dark mode.
interface Props {
  size?: number;
  class?: string;
}
const { size = 26, class: extraClass = "" } = Astro.props;
---
<svg
  width={size}
  height={size}
  viewBox="0 0 64 64"
  fill="none"
  class={extraClass}
  aria-hidden="true"
>
  <circle cx="32" cy="32" r="28" stroke="currentColor" stroke-width="1" />
  <circle cx="32" cy="32" r="20" stroke="currentColor" stroke-width="1" />
  <circle cx="32" cy="32" r="11" stroke="currentColor" stroke-width="1" />
  <line
    x1="8"
    y1="32"
    x2="56"
    y2="32"
    stroke="currentColor"
    stroke-width="1"
    transform="rotate(-25 32 32)"
  />
  <circle cx="32" cy="32" r="1.8" fill="currentColor" />
  <circle cx="52" cy="22" r="1.2" fill="#3B5BDB" />
</svg>
