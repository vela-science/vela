    align-items: baseline;
    gap: 14px;
    margin-bottom: var(--space-4);
  }
  .spec__num {
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: 13px;
    letter-spacing: 0.18em;
    color: color-mix(in oklab, var(--gold) 72%, var(--ink-2));
    flex-shrink: 0;
  }
  .spec__title {
