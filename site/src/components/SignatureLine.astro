---
/*
  Live signature line — a thin mono row above every page header
  showing the current state of the substrate. Makes "this is updating
  right now" visible from any page without the visitor having to think.

  Format: `vela 0.48.0 · Alzheimer's Therapeutics · 188 findings ·
           5 contradictions · last signed 2026-04-27 · vfr_bd91…`

  Built at site build time from the canonical frontier; redeploys
  refresh it. The pulse on the version dot signals "live."
*/
import { frontierStats, contradictions } from "../lib/frontier";
import { FRONTIER, VERSION } from "../config";

const stats = frontierStats();
const tensions = contradictions();
const lastSigned = stats.lastUpdated
  ? new Date(stats.lastUpdated).toISOString().slice(0, 10)
  : "—";

// Frontier id is content-addressed and changes with content; we read it
// from the canonical manifest at build time. Fall back to a placeholder
// if the manifest hasn't been generated yet.
import { readFileSync, existsSync } from "node:fs";
import { join } from "node:path";

let vfrId = "vfr_pending";
try {
  const manifestPath = join(
    process.cwd(),
    "..",
    "frontiers",
    FRONTIER.manifestFile,
  );
  if (existsSync(manifestPath)) {
    const raw = readFileSync(manifestPath, "utf8");
    const m = JSON.parse(raw) as { frontier_id?: string };
    if (m.frontier_id) vfrId = m.frontier_id;
  }
} catch {
  // best-effort; stays as placeholder
}

const vfrShort = vfrId.length > 16 ? `${vfrId.slice(0, 14)}…` : vfrId;
---

<aside class="sigline" aria-label="Live frontier signature">
  <span class="sigline__pulse" aria-hidden="true"></span>
  <span class="sigline__seg sigline__seg--name">vela {VERSION}</span>
  <span class="sigline__sep">·</span>
  <span class="sigline__seg">{FRONTIER.name}</span>
  <span class="sigline__sep">·</span>
  <span class="sigline__seg"><span class="sigline__num">{stats.claims}</span> findings</span>
  <span class="sigline__sep">·</span>
  <span class="sigline__seg"><span class="sigline__num">{tensions.length}</span> contradictions</span>
  <span class="sigline__sep">·</span>
  <span class="sigline__seg">last signed <span class="sigline__date">{lastSigned}</span></span>
  <span class="sigline__sep sigline__sep--soft">·</span>
  <span class="sigline__seg sigline__seg--id" title={vfrId}>{vfrShort}</span>
</aside>

<style>
  .sigline {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 6px 8px;
    padding: 8px clamp(1.5rem, 4vw, 3rem) 10px;
    border-bottom: 1px solid var(--rule-1);
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.06em;
    color: color-mix(in oklab, var(--ink-3) 88%, transparent);
    background: transparent;
  }
  .sigline__pulse {
    display: inline-block;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--gold);
    box-shadow: 0 0 0 2px var(--gold-soft);
    margin-right: 6px;
    animation: sigline-pulse 3.6s var(--ease) infinite;
    flex: 0 0 auto;
  }
  @keyframes sigline-pulse {
    0%, 100% { box-shadow: 0 0 0 2px var(--gold-soft); }
    50%      { box-shadow: 0 0 0 3px var(--gold-glow); }
  }
  .sigline__seg {
    color: color-mix(in oklab, var(--ink-3) 92%, transparent);
    white-space: nowrap;
  }
  .sigline__seg--name {
    color: color-mix(in oklab, var(--gold) 72%, var(--ink-2));
    font-weight: 500;
    text-transform: lowercase;
    letter-spacing: 0.08em;
  }
  .sigline__num {
    color: var(--ink-1);
    font-variant-numeric: tabular-nums;
    font-weight: 500;
  }
  .sigline__date {
    color: var(--ink-2);
    font-variant-numeric: tabular-nums;
  }
  .sigline__seg--id {
    color: color-mix(in oklab, var(--ink-4) 92%, transparent);
    font-variant-numeric: tabular-nums;
    cursor: help;
  }
  .sigline__sep { color: var(--ink-4); }
  .sigline__sep--soft { color: color-mix(in oklab, var(--ink-4) 50%, transparent); }

  @media (max-width: 720px) {
    .sigline {
      padding: 6px clamp(1rem, 4vw, 1.5rem) 8px;
      font-size: 9px;
      gap: 4px 6px;
    }
    .sigline__pulse { width: 4px; height: 4px; }
  }
  @media (max-width: 480px) {
    /* Hide the contradictions + id segments on very small viewports */
    .sigline__seg--id,
    .sigline__seg:has(+ .sigline__sep--soft) { display: none; }
  }
</style>
