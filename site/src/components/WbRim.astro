---
import Mark from "./Mark.astro";
import { HUB_URL, VERSION } from "../config";

interface NavLink {
  id: string;
  href: string;
  label: string;
}
interface Props {
  active?: string;
  links?: NavLink[];
  version?: string;
}

const defaultLinks: NavLink[] = [
  /* The home route IS the live frontier (Alzheimer's Therapeutics)
     after the v0.31 topic-first redesign. The protocol substrate
     gets its own second-class entry. The lantern mark above this
     nav carries the Vela brand identity.

     v0.49 adds /proof, /replay, and /lineage as the three "show by
     doing" routes — they're the surfaces a skeptic should be one
     click away from on every page. */
  { id: "home", href: "/", label: "01 · Frontier" },
  { id: "protocol", href: "/protocol", label: "02 · Protocol" },
  { id: "proof", href: "/proof/pericyte-correction", label: "03 · Proof" },
  { id: "replay", href: "/replay", label: "04 · Replay" },
  { id: "workbench", href: "/workbench", label: "05 · Workbench" },
  { id: "docs", href: "/docs/protocol", label: "06 · Docs" },
  { id: "essays", href: "/essays/science-needs-state", label: "07 · Essay" },
  { id: "publish", href: "/publish", label: "08 · Publish" },
  { id: "lineage", href: "/lineage", label: "09 · Lineage" },
  { id: "hub", href: HUB_URL, label: "10 · Hub" },
];

const { active = "home", links = defaultLinks, version = `v${VERSION}` } =
  Astro.props;
---
<aside class="wb-rim">
  <div class="wb-rim__mark" style="color: var(--vela-lantern-gold);">
    <a href="/" aria-label="Vela home">
      <Mark size={32} />
    </a>
  </div>
  <nav class="wb-rim__nav" aria-label="Site sections">
    {links.map((l) => (
      <a
        class={`wb-rim__link${l.id === active ? " wb-rim__link--on" : ""}`}
        href={l.href}
      >
        {l.label}
      </a>
    ))}
  </nav>
  <div class="wb-rim__index">{version}</div>
</aside>
