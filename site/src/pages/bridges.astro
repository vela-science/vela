---
/*
  Cross-frontier bridges (v0.46).

  A bridge is a content-addressed `vbr_<id>` record asserting "this
  entity links findings in two frontiers." Bridges are derived
  deterministically by `vela bridges derive`; reviewer judgment
  promotes them from `derived` to `confirmed` or `refuted`.
*/

import Page from "../layouts/Page.astro";
import { loadBridges, type Bridge } from "../lib/frontier";
import { FRONTIER, REPO_URL, VERSION } from "../config";

const bridges = loadBridges();

const counts = {
  total: bridges.length,
  derived: bridges.filter((b) => b.status === "derived").length,
  confirmed: bridges.filter((b) => b.status === "confirmed").length,
  refuted: bridges.filter((b) => b.status === "refuted").length,
  with_tension: bridges.filter((b) => b.tension && b.tension.length > 0).length,
};

function statusChip(s: Bridge["status"]): string {
  return s === "confirmed" ? "ok" : s === "refuted" ? "lost" : "warn";
}

function trunc(s: string, n: number): string {
  return s.length > n ? `${s.slice(0, n - 1)}…` : s;
}
---

<Page
  title={`Bridges · ${FRONTIER.name}`}
  description="Cross-frontier bridges: content-addressed vbr_ records linking findings across two frontiers via shared entities. Reviewer judgment promotes them from derived to confirmed."
  active=""
  eyebrow="Bridges"
  pageTitle="Cross-frontier bridges"
  subtitle="Content-addressed compositional hypotheses across frontier pairs."
>
  <div slot="aside">
    <a href="/" class="aside-link">frontier</a>
    <span>·</span>
    <a href="/causal/audit" class="aside-link">causal audit</a>
    <span>·</span>
    <a href="/counterfactual" class="aside-link">counterfactuals</a>
    <span>·</span>
    <a href={REPO_URL} class="aside-link">github</a>
    <span class="aside-version">v{VERSION}</span>
  </div>

  <section class="br-doctrine">
    <p class="br-doctrine__eyebrow">Doctrine</p>
    <p class="br-doctrine__body">
      A bridge is a <em>compositional hypothesis</em>: the same entity (a protein, a
      target, a disease, a method) appears in findings from two separate frontiers.
      The kernel records the link; it does not assert the hypothesis is true.
    </p>
    <p class="br-doctrine__body">
      Bridges are derived deterministically. Re-running <code>vela bridges derive</code>
      against the same frontier pair produces the same <code>vbr_&lt;id&gt;</code> set.
      Reviewer judgment promotes each bridge from <code>derived</code> to
      <code>confirmed</code> (a real cross-domain claim) or <code>refuted</code>
      (mere shared vocabulary, not a real composition). Reviewer state is sticky;
      re-derivation preserves it.
    </p>
    <p class="br-doctrine__body">
      <strong>Tension</strong> flags an entity asserted positively in one frontier and
      negatively in another. These are the highest-information bridges: cross-domain
      disagreements that future work has to resolve.
    </p>
  </section>

  <section class="br-summary">
    <h2 class="br-summary__title">This frontier's bridge surface</h2>
    <dl class="br-summary__dl">
      <dt>Total bridges</dt><dd>{counts.total}</dd>
      <dt>Confirmed</dt><dd>{counts.confirmed}</dd>
      <dt>Derived (awaiting review)</dt><dd>{counts.derived}</dd>
      <dt>Refuted</dt><dd>{counts.refuted}</dd>
      <dt>With cross-domain tension</dt><dd>{counts.with_tension}</dd>
    </dl>
  </section>

  {bridges.length === 0 && (
    <p class="br-empty">
      No bridges yet. Derive one with:
      <code>vela bridges derive {FRONTIER.repoPath} --label-a bbb &lt;other-frontier&gt; --label-b other</code>
    </p>
  )}

  <ol class="br-list">
    {bridges.map((b) => (
      <li class="br-item">
        <p class="br-item__head">
          <span class={`br-chip br-chip--${statusChip(b.status)}`}>{b.status}</span>
          <code class="br-id">{b.id}</code>
          <span class="br-entity">{b.entity_name}</span>
        </p>
        <p class="br-item__body">
          <strong>frontiers:</strong> {b.frontiers.join(" ↔ ")} · <strong>findings:</strong> {b.finding_refs.length}
        </p>
        {b.tension && (
          <p class="br-item__body br-tension">
            <strong>tension:</strong> {b.tension}
          </p>
        )}
        <ul class="br-refs">
          {b.finding_refs.slice(0, 4).map((r) => (
            <li>
              <span class="br-ref__frontier">[{r.frontier}]</span>
              <code>{r.finding_id}</code>
              <span class="br-ref__conf">conf {r.confidence.toFixed(2)}</span>
              {r.direction && <span class="br-ref__dir">{r.direction}</span>}
              <p class="br-ref__text">{trunc(r.assertion_text, 110)}</p>
            </li>
          ))}
        </ul>
        {b.finding_refs.length > 4 && (
          <p class="br-item__more">… and {b.finding_refs.length - 4} more refs</p>
        )}
      </li>
    ))}
  </ol>

  <p class="br-version">vela {VERSION} · v0.46 bridge runtime</p>
</Page>

<style>
  .br-doctrine {
    border: 1px solid var(--rule-2, #d8d4cc);
    background: var(--bg-2, #f5f2ec);
    padding: 1rem 1.25rem;
    margin: 0 0 1.5rem 0;
    font-size: 0.92rem;
    line-height: 1.55;
  }
  .br-doctrine__eyebrow {
    font-size: 0.74rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-2, #6b665d);
    margin-bottom: 0.4rem;
  }
  .br-doctrine__body { margin: 0 0 0.6rem 0; }
  .br-doctrine code {
    background: var(--bg-3, #ebe6dd);
    padding: 0.05em 0.3em;
    border-radius: 2px;
    font-size: 0.88em;
  }

  .br-summary {
    border: 1px solid var(--rule-2, #d8d4cc);
    background: var(--bg-1, #fafaf6);
    padding: 0.8rem 1.25rem;
    margin: 0 0 1.5rem 0;
  }
  .br-summary__title { font-size: 1rem; margin: 0 0 0.4rem 0; }
  .br-summary__dl {
    display: grid;
    grid-template-columns: max-content 1fr;
    gap: 0.2rem 0.75rem;
    margin: 0;
    font-size: 0.92rem;
  }
  .br-summary__dl dt { color: var(--ink-2, #6b665d); font-weight: 500; }
  .br-summary__dl dd { margin: 0; }

  .br-empty {
    padding: 1rem;
    color: var(--ink-2, #6b665d);
    font-size: 0.92rem;
    border: 1px dashed var(--rule-2, #d8d4cc);
  }
  .br-empty code {
    display: block;
    margin-top: 0.4rem;
    background: var(--bg-3, #ebe6dd);
    padding: 0.4em 0.6em;
    border-radius: 2px;
    font-size: 0.86em;
    overflow-x: auto;
  }

  .br-list { list-style: none; padding: 0; margin: 0; }
  .br-item {
    border-top: 1px solid var(--rule-2, #d8d4cc);
    padding: 0.85rem 0;
  }
  .br-item:last-child { border-bottom: 1px solid var(--rule-2, #d8d4cc); }
  .br-item__head {
    margin: 0 0 0.4rem 0;
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    flex-wrap: wrap;
  }
  .br-id {
    font-family: ui-monospace, Menlo, monospace;
    font-size: 0.86rem;
    color: var(--ink-1, #2a2a2a);
  }
  .br-entity {
    font-weight: 600;
    font-size: 1rem;
  }
  .br-item__body { margin: 0.15rem 0; font-size: 0.92rem; }
  .br-tension {
    color: #872c2c;
    font-style: italic;
  }

  .br-chip {
    display: inline-block;
    padding: 0.05em 0.5em;
    border-radius: 2px;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .br-chip--ok { background: #d6e4d3; color: #2f5d3a; }
  .br-chip--warn { background: #efe2c0; color: #8a6d1f; }
  .br-chip--lost { background: #efd1cf; color: #872c2c; }

  .br-refs {
    margin: 0.4rem 0 0.2rem 0;
    padding: 0;
    list-style: none;
  }
  .br-refs li {
    margin: 0.4rem 0;
    padding: 0.3rem 0.6rem;
    background: var(--bg-2, #f5f2ec);
    border-left: 2px solid var(--rule-2, #d8d4cc);
    font-size: 0.88rem;
  }
  .br-ref__frontier {
    font-family: ui-monospace, Menlo, monospace;
    color: var(--ink-2, #6b665d);
    margin-right: 0.4em;
  }
  .br-ref__conf,
  .br-ref__dir {
    color: var(--ink-2, #6b665d);
    margin-left: 0.4em;
    font-size: 0.78rem;
  }
  .br-ref__text {
    margin: 0.15rem 0 0 0;
    font-size: 0.88rem;
    line-height: 1.4;
  }
  .br-item__more {
    margin: 0.2rem 0 0 0;
    font-size: 0.82rem;
    color: var(--ink-2, #6b665d);
  }

  .br-version {
    margin-top: 2rem;
    color: var(--ink-2, #6b665d);
    font-size: 0.78rem;
    text-align: right;
    font-family: ui-monospace, Menlo, monospace;
  }
</style>
