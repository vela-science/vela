---
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
}
const { eyebrow, title, subtitle } = Astro.props;
---
<header class="wb-head">
  <div class="wb-head__row">
    <div>
      {eyebrow && <div class="wb-head__eyebrow" set:html={eyebrow} />}
      <h1 class="wb-head__title">{title}</h1>
      {subtitle && <p class="wb-head__sub" set:html={subtitle} />}
    </div>
    <div class="wb-head__aside">
      <slot name="aside" />
    </div>
  </div>
  <div class="wb-head__ticks"></div>
</header>
