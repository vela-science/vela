---
/*
  ImagePlate — picture wrapped in a FigurePlate, with deckled-edge
  fade for a printed-plate feel. Adapted from Borrowed Light.
  WebP source auto-derived from the fallback path.
*/
import FigurePlate from "./FigurePlate.astro";

interface Props {
  alt: string;
  caption?: string;
  class?: string;
  eyebrow?: string;
  fallback: string;
  figNum?: number | string;
  height: number;
  sizes?: string;
  variant?: "open" | "plate" | "quiet";
  webpSrc?: string;
  webpSrcSet?: string;
  width: number;
  wide?: boolean;
}

const {
  alt,
  caption,
  class: className = "",
  eyebrow,
  fallback,
  figNum,
  height,
  sizes = "(max-width: 760px) calc(100vw - 2rem), 54rem",
  variant = "open",
  webpSrc,
  webpSrcSet,
  width,
  wide = false,
} = Astro.props;

const derivedWebpSrc = fallback.replace(/\.(png|jpe?g)$/i, ".webp");
const resolvedWebpSrcSet = webpSrcSet ?? webpSrc ?? derivedWebpSrc;
---

<FigurePlate
  class={`vela-image-plate ${className}`}
  variant={variant}
  caption={caption}
  eyebrow={eyebrow}
  figNum={figNum}
  wide={wide}
>
  <picture>
    {resolvedWebpSrcSet && <source type="image/webp" srcset={resolvedWebpSrcSet} sizes={sizes} />}
    <img
      src={fallback}
      alt={alt}
      width={width}
      height={height}
      loading="lazy"
      decoding="async"
      class="vela-image-plate__image"
    />
  </picture>
</FigurePlate>

<style>
  :global(.vela-image-plate) {
    --vela-plate-fade-x: 11%;
    --vela-plate-fade-y: 10%;
    width: min(100%, 52rem);
    max-width: min(100%, 52rem);
    margin-inline: auto;
  }

  .vela-image-plate :global(picture) {
    display: block;
    position: relative;
    isolation: isolate;
  }

  .vela-image-plate__image {
    display: block;
    width: 100%;
    height: auto;
    background: transparent;
    mix-blend-mode: multiply;
    -webkit-mask-image:
      linear-gradient(to right, transparent 0%, black var(--vela-plate-fade-x), black calc(100% - var(--vela-plate-fade-x)), transparent 100%),
      linear-gradient(to bottom, transparent 0%, black var(--vela-plate-fade-y), black calc(100% - var(--vela-plate-fade-y)), transparent 100%);
    mask-image:
      linear-gradient(to right, transparent 0%, black var(--vela-plate-fade-x), black calc(100% - var(--vela-plate-fade-x)), transparent 100%),
      linear-gradient(to bottom, transparent 0%, black var(--vela-plate-fade-y), black calc(100% - var(--vela-plate-fade-y)), transparent 100%);
    -webkit-mask-composite: source-in;
    mask-composite: intersect;
  }

  @media (max-width: 640px) {
    :global(.vela-image-plate) {
      width: calc(100vw - 2rem);
      max-width: calc(100vw - 2rem);
      --vela-plate-fade-x: 8%;
      --vela-plate-fade-y: 7%;
    }
  }
</style>
