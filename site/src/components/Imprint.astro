---
/*
  Imprint — companion-page footer mark. Hairline rule, vela-mark on
  the left, return link on the right. Adapted from Borrowed Light's
  essay-imprint pattern. Mono small-caps signal dot for the mark.
*/
interface Props {
  /** Where the return link points. Defaults to "/" */
  returnHref?: string;
  /** Label for the return link. Defaults to "Back" */
  returnLabel?: string;
  /** Path to the mark SVG. Defaults to /brand/vela-logo-mark.svg */
  markSrc?: string;
  /** Alt text for the mark (decorative if empty) */
  markAlt?: string;
}

const {
  returnHref = "/",
  returnLabel = "Back",
  markSrc = "/brand/vela-logo-mark.svg",
  markAlt = "",
} = Astro.props;
---

<footer class="imprint" role="contentinfo">
  <img
    src={markSrc}
    alt={markAlt}
    class="imprint__mark"
    width="36"
    height="36"
    loading="lazy"
    decoding="async"
  />
  <p class="imprint__return">
    <a href={returnHref}>{returnLabel}</a>
  </p>
</footer>

<style>
  .imprint {
    margin-top: clamp(4rem, 9vh, 6rem);
    padding-top: 1.6rem;
    border-top: 1px solid color-mix(in oklab, var(--rule-2) 80%, transparent);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    max-width: var(--measure);
  }

  .imprint__mark {
    width: 36px;
    height: 36px;
    opacity: 0.7;
    filter: drop-shadow(0 0 12px color-mix(in oklab, var(--gold) 18%, transparent));
  }

  .imprint__return {
    margin: 0;
    font-family: var(--font-mono);
    font-size: var(--size-imprint);
    letter-spacing: var(--track-imprint);
    text-transform: uppercase;
    color: color-mix(in oklab, var(--ink-3) 70%, transparent);
  }

  .imprint__return a {
    color: inherit;
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition:
      color var(--dur-2) var(--ease),
      border-bottom-color var(--dur-2) var(--ease);
  }

  .imprint__return a:hover,
  .imprint__return a:focus-visible {
    color: var(--gold-ink);
    border-bottom-color: color-mix(in oklab, var(--gold) 56%, transparent);
  }

  @media (max-width: 640px) {
    .imprint {
      flex-direction: column;
      align-items: flex-start;
      gap: 1.1rem;
    }
  }
</style>
