---
/*
  Federation view (v0.39).

  Renders the peer registry and the canonical sync / conflict log.
  Peers are declared awareness, not declared trust. Conflicts are
  recorded, not auto-resolved — each one is a concrete review item
  for whoever owns the relationship between this hub and that peer.

  v0.39.1 added the runtime; v0.40.2 fixed two real bugs surfaced by
  exercising it against the public mirror. Today's frontier carries
  the canonical event trail of that exercise.
*/

import Page from "../../layouts/Page.astro";
import {
  loadPeers,
  loadFederationEvents,
  type ConflictKind,
} from "../../lib/frontier";
import { FRONTIER, REPO_URL, VERSION } from "../../config";

const peers = loadPeers();
const { syncs, conflicts } = loadFederationEvents();
const totalSyncs = syncs.length;
const totalConflicts = conflicts.length;

// Group conflicts by kind for the summary, then show the most-recent
// sync's conflicts as a concrete divergence table.
const byKind = new Map<ConflictKind, number>();
for (const c of conflicts) {
  byKind.set(c.kind, (byKind.get(c.kind) ?? 0) + 1);
}

// The latest sync interaction defines the current divergence picture.
const latestSync = syncs[0];

const conflictKindLabel: Record<ConflictKind, string> = {
  missing_in_peer: "missing in peer",
  missing_locally: "missing locally",
  confidence_diverged: "confidence diverged",
  retracted_diverged: "retracted diverged",
  review_state_diverged: "review state diverged",
  superseded_diverged: "superseded diverged",
  assertion_text_diverged: "assertion text diverged",
};

function shortHash(h: string): string {
  return h.length > 16 ? h.slice(0, 16) + "…" : h;
}

function fmtTs(ts: string): string {
  if (!ts) return "—";
  return ts.replace("T", " ").replace(/\.\d+/, "").replace("+00:00", "Z");
}
---

<Page
  title={`Federation · ${FRONTIER.name}`}
  description="Peer registry and sync log. Adding a peer declares awareness, not trust. Conflicts are recorded, not auto-resolved."
  active=""
  eyebrow="Federation"
  pageTitle="Peers and divergence"
  subtitle="Peer registry, sync interactions, and the canonical conflict log."
>
  <div slot="aside">
    <a href="/" class="aside-link">frontier</a>
    <span>·</span>
    <a href={REPO_URL} class="aside-link">github</a>
    <span class="aside-version">v{VERSION}</span>
  </div>

  <!-- Doctrine -->
  <aside class="fed-doctrine">
    <div class="fed-doctrine__eyebrow">Doctrine</div>
    <p class="fed-doctrine__body">
      A peer is another hub this frontier knows about — id, HTTPS URL,
      Ed25519 pubkey. <strong>Adding a peer declares awareness, not trust.</strong>
      The kernel never auto-merges peer state. Each divergence becomes
      a canonical <code>frontier.conflict_detected</code> event a reviewer
      can act on.
    </p>
    <p class="fed-doctrine__body">
      Conflict taxonomy: <code>missing_in_peer</code>, <code>missing_locally</code>,
      <code>confidence_diverged</code> (|Δ| &gt; 0.05),
      <code>retracted_diverged</code>, <code>review_state_diverged</code>,
      <code>superseded_diverged</code>, <code>assertion_text_diverged</code>
      (the strongest signal — content-address collision).
    </p>
  </aside>

  <!-- Summary -->
  <section class="fed-summary">
    <div class="fed-stat">
      <div class="fed-stat__num">{peers.length}</div>
      <div class="fed-stat__lbl">peers registered</div>
    </div>
    <div class="fed-stat">
      <div class="fed-stat__num">{totalSyncs}</div>
      <div class="fed-stat__lbl">sync interactions</div>
    </div>
    <div class="fed-stat">
      <div class="fed-stat__num">{totalConflicts}</div>
      <div class="fed-stat__lbl">conflict events</div>
    </div>
    <div class="fed-stat">
      <div class="fed-stat__num">{latestSync?.divergence_count ?? "—"}</div>
      <div class="fed-stat__lbl">last divergence</div>
    </div>
  </section>

  <!-- Peers -->
  <section class="fed-section">
    <h2 class="fed-section__title">Peer registry</h2>
    {peers.length === 0 ? (
      <p class="fed-empty">
        No peers registered. Add one with{" "}
        <code>vela federation peer-add &lt;id&gt; --url ... --pubkey ...</code>.
      </p>
    ) : (
      <div class="fed-peers">
        {peers.map((p) => (
          <article class="fed-peer">
            <div class="fed-peer__head">
              <span class="fed-peer__id">{p.id}</span>
              <span class="fed-peer__pubkey">pubkey {shortHash(p.public_key)}</span>
            </div>
            <a href={p.url} class="fed-peer__url" target="_blank" rel="noopener">{p.url}</a>
            {p.note && <p class="fed-peer__note">{p.note}</p>}
            <div class="fed-peer__meta">added {fmtTs(p.added_at)}</div>
          </article>
        ))}
      </div>
    )}
  </section>

  <!-- Sync history -->
  <section class="fed-section">
    <h2 class="fed-section__title">Sync interactions</h2>
    {syncs.length === 0 ? (
      <p class="fed-empty">
        No sync events recorded yet. Run <code>vela federation sync &lt;peer_id&gt;</code> to interact.
      </p>
    ) : (
      <table class="fed-table">
        <thead>
          <tr>
            <th>When</th>
            <th>Peer</th>
            <th>Our snapshot</th>
            <th>Peer snapshot</th>
            <th class="fed-table__num">Divergence</th>
          </tr>
        </thead>
        <tbody>
          {syncs.map((s) => (
            <tr class={s.divergence_count === 0 ? "fed-row fed-row--clean" : "fed-row"}>
              <td class="fed-table__when">{fmtTs(s.timestamp)}</td>
              <td>{s.peer_id}</td>
              <td><code>{shortHash(s.our_snapshot_hash)}</code></td>
              <td><code>{shortHash(s.peer_snapshot_hash)}</code></td>
              <td class="fed-table__num">
                {s.divergence_count === 0 ? (
                  <span class="fed-clean">clean</span>
                ) : (
                  <span class="fed-divergent">{s.divergence_count}</span>
                )}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    )}
  </section>

  <!-- Conflict breakdown -->
  {byKind.size > 0 && (
    <section class="fed-section">
      <h2 class="fed-section__title">Conflict log by kind</h2>
      <p class="fed-section__sub">
        Each entry is one canonical <code>frontier.conflict_detected</code> event.
        Resolution lands as a separate proposal — the kernel never auto-merges
        peer state.
      </p>
      <div class="fed-kinds">
        {[...byKind.entries()].map(([kind, count]) => (
          <div class="fed-kind">
            <span class="fed-kind__count">{count}</span>
            <span class="fed-kind__label">{conflictKindLabel[kind]}</span>
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- Recent conflicts table -->
  {conflicts.length > 0 && (
    <section class="fed-section">
      <h2 class="fed-section__title">Recent conflicts</h2>
      <p class="fed-section__sub">
        Newest first. Showing up to 50.
      </p>
      <table class="fed-table fed-table--conflicts">
        <thead>
          <tr>
            <th>When</th>
            <th>Peer</th>
            <th>Finding</th>
            <th>Kind</th>
            <th>Detail</th>
          </tr>
        </thead>
        <tbody>
          {conflicts.slice(0, 50).map((c) => (
            <tr class="fed-row">
              <td class="fed-table__when">{fmtTs(c.timestamp)}</td>
              <td>{c.peer_id}</td>
              <td><code>{c.finding_id}</code></td>
              <td>
                <span class={`fed-kind-chip fed-kind-chip--${c.kind}`}>
                  {conflictKindLabel[c.kind] ?? c.kind}
                </span>
              </td>
              <td class="fed-table__detail">{c.detail}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>
  )}
</Page>

<style>
  .fed-doctrine {
    border: 1px solid var(--rule-2, #d8d4cc);
    background: var(--bg-2, #f5f2ec);
    padding: 1rem 1.25rem;
    margin: 0 0 1.5rem 0;
    font-size: 0.92rem;
    line-height: 1.55;
  }
  .fed-doctrine__eyebrow {
    font-size: 0.74rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-2, #6b665d);
    margin-bottom: 0.4rem;
  }
  .fed-doctrine__body {
    margin: 0 0 0.6rem 0;
  }
  .fed-doctrine__body:last-child { margin-bottom: 0; }
  .fed-doctrine code {
    background: var(--bg-3, #ebe6dd);
    padding: 0.05em 0.3em;
    border-radius: 2px;
    font-size: 0.88em;
  }

  .fed-summary {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.75rem;
    margin: 0 0 2rem 0;
  }
  .fed-stat {
    border: 1px solid var(--rule-2, #d8d4cc);
    padding: 0.85rem 1rem;
    background: var(--bg-1, #fafaf6);
  }
  .fed-stat__num {
    font-size: 2rem;
    font-weight: 300;
    line-height: 1;
    margin-bottom: 0.3rem;
  }
  .fed-stat__lbl {
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-2, #6b665d);
  }

  .fed-section {
    margin: 0 0 2.5rem 0;
  }
  .fed-section__title {
    font-size: 1rem;
    font-weight: 500;
    margin: 0 0 0.6rem 0;
  }
  .fed-section__sub {
    font-size: 0.88rem;
    color: var(--ink-2, #6b665d);
    margin: 0 0 1rem 0;
  }
  .fed-section__sub code {
    background: var(--bg-2, #f5f2ec);
    padding: 0.05em 0.3em;
    border-radius: 2px;
    font-size: 0.88em;
  }

  .fed-empty {
    color: var(--ink-2, #6b665d);
    font-size: 0.92rem;
  }
  .fed-empty code {
    background: var(--bg-2, #f5f2ec);
    padding: 0.05em 0.3em;
    border-radius: 2px;
  }

  .fed-peers {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .fed-peer {
    border: 1px solid var(--rule-2, #d8d4cc);
    padding: 0.8rem 1rem;
    background: var(--bg-1, #fafaf6);
  }
  .fed-peer__head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
  }
  .fed-peer__id {
    font-family: var(--font-mono, monospace);
    font-size: 0.92rem;
    font-weight: 500;
  }
  .fed-peer__pubkey {
    font-family: var(--font-mono, monospace);
    font-size: 0.78rem;
    color: var(--ink-2, #6b665d);
  }
  .fed-peer__url {
    display: block;
    font-family: var(--font-mono, monospace);
    font-size: 0.84rem;
    color: var(--ink-1, #2a2a2a);
    text-decoration: none;
    border-bottom: 1px solid var(--rule-3, #c8c2b5);
    margin-top: 0.4rem;
    word-break: break-all;
  }
  .fed-peer__url:hover { border-bottom-color: var(--ink-1, #2a2a2a); }
  .fed-peer__note {
    margin: 0.5rem 0 0 0;
    font-size: 0.88rem;
    color: var(--ink-2, #6b665d);
    line-height: 1.5;
  }
  .fed-peer__meta {
    margin-top: 0.5rem;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-3, #a09a8d);
  }

  .fed-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.88rem;
  }
  .fed-table th {
    text-align: left;
    border-bottom: 1px solid var(--rule-2, #d8d4cc);
    padding: 0.5rem 0.6rem;
    font-weight: 500;
    color: var(--ink-2, #6b665d);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .fed-table td {
    padding: 0.5rem 0.6rem;
    border-bottom: 1px solid var(--rule-2, #d8d4cc);
    vertical-align: top;
  }
  .fed-table__num { text-align: right; }
  .fed-table__when {
    font-family: var(--font-mono, monospace);
    font-size: 0.82rem;
    color: var(--ink-2, #6b665d);
    white-space: nowrap;
  }
  .fed-table__detail {
    font-size: 0.84rem;
    color: var(--ink-2, #6b665d);
  }
  .fed-row code {
    font-family: var(--font-mono, monospace);
    font-size: 0.82rem;
  }
  .fed-row--clean { background: rgba(220, 232, 220, 0.4); }
  .fed-clean {
    color: #2f5d3a;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .fed-divergent {
    color: #872c2c;
    font-weight: 500;
  }

  .fed-kinds {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }
  .fed-kind {
    border: 1px solid var(--rule-2, #d8d4cc);
    padding: 0.5rem 0.85rem;
    background: var(--bg-1, #fafaf6);
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
  }
  .fed-kind__count {
    font-size: 1.2rem;
    font-weight: 400;
    color: var(--ink-1, #2a2a2a);
  }
  .fed-kind__label {
    font-size: 0.84rem;
    color: var(--ink-2, #6b665d);
  }

  .fed-kind-chip {
    font-size: 0.74rem;
    padding: 0.15em 0.5em;
    border-radius: 2px;
    background: var(--bg-2, #f5f2ec);
    color: var(--ink-1, #2a2a2a);
  }
  .fed-kind-chip--missing_in_peer { background: #f0e7d0; color: #8a6d1f; }
  .fed-kind-chip--missing_locally { background: #d8e7d8; color: #2f5d3a; }
  .fed-kind-chip--confidence_diverged { background: #f0e7d0; color: #8a6d1f; }
  .fed-kind-chip--retracted_diverged { background: #f3dada; color: #872c2c; }
  .fed-kind-chip--review_state_diverged { background: #f0e7d0; color: #8a6d1f; }
  .fed-kind-chip--superseded_diverged { background: #f0e7d0; color: #8a6d1f; }
  .fed-kind-chip--assertion_text_diverged { background: #f3dada; color: #872c2c; }
</style>
