    letter-spacing: 0.04em;
  }
  .fr-side__dl dd {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--ink-1);
    margin: 0;
    overflow-wrap: anywhere;
  }
  .fr-side__dl dd a { color: var(--ink-1); border-bottom: 1px solid var(--rule-2); }
  .fr-side__dl dd a:hover { color: var(--signal); border-bottom-color: var(--signal); }

  .fr-side__cmd {
    background: var(--ink-0);
    color: #E6E1D4;
    font-family: var(--font-mono);
    font-size: 11px;
    line-height: 1.5;
    padding: 12px;
    border-radius: var(--radius-1);
    overflow-x: auto;
    margin: 0;
    white-space: pre;
