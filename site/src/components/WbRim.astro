---
import Mark from "./Mark.astro";
import { HUB_URL, VERSION } from "../config";

interface NavLink {
  id: string;
  href: string;
  label: string;
}
interface Props {
  active?: string;
  links?: NavLink[];
  version?: string;
}

const defaultLinks: NavLink[] = [
  /* The home route IS the live frontier (Alzheimer's Therapeutics)
     after the v0.31 topic-first redesign. The protocol substrate
     gets its own second-class entry. The lantern mark above this
     nav carries the Vela brand identity. v0.31 also adds /bench as
     the public agent leaderboard. */
  { id: "home", href: "/", label: "01 · Frontier" },
  { id: "bench", href: "/bench", label: "02 · Bench" },
  { id: "protocol", href: "/protocol", label: "03 · Protocol" },
  { id: "workbench", href: "/workbench", label: "04 · Workbench" },
  { id: "docs", href: "/docs/protocol", label: "05 · Docs" },
  { id: "essays", href: "/essays/science-needs-state", label: "06 · Essays" },
  { id: "publish", href: "/publish", label: "07 · Publish" },
  { id: "hub", href: HUB_URL, label: "08 · Hub" },
];

const { active = "home", links = defaultLinks, version = `v${VERSION}` } =
  Astro.props;
---
<aside class="wb-rim">
  <div class="wb-rim__mark" style="color: var(--vela-lantern-gold);">
    <a href="/" aria-label="Vela home">
      <Mark size={32} />
    </a>
  </div>
  <nav class="wb-rim__nav" aria-label="Site sections">
    {links.map((l) => (
      <a
        class={`wb-rim__link${l.id === active ? " wb-rim__link--on" : ""}`}
        href={l.href}
      >
        {l.label}
      </a>
    ))}
  </nav>
  <div class="wb-rim__index">{version}</div>
</aside>
