---
import Reading from "../layouts/Reading.astro";
import ClaimCard from "../components/ClaimCard.astro";
import {
  loadFrontier,
  frontierStats,
  contradictions,
  type ClaimView,
} from "../lib/frontier";
import { FRONTIER, REPO_URL, HUB_URL, VERSION } from "../config";

const claims = loadFrontier();
const stats = frontierStats();
const tensionList = contradictions();

const featured: ClaimView[] = claims
  .slice()
  .sort((a, b) => b.finding.confidence.score - a.finding.confidence.score)
  .slice(0, 9);

const lastUpdated = stats.lastUpdated
  ? new Date(stats.lastUpdated).toISOString().slice(0, 10)
  : "—";
---

<Reading
  title="Vela · open protocol for scientific findings"
  description="An open protocol where scientific findings, evidence, and corrections are first-class, signed, content-addressed objects."
  active="home"
  wide
  noFoot
>
  <!-- Hero — proof first, prose second. -->
  <header class="vh-hero">
    <p class="vh-hero__eyebrow">vela {VERSION} · open protocol for scientific findings</p>

    <div class="vh-try">
      <pre class="vh-code"><code><span class="vh-ps">$</span> <span class="vh-cmd">curl</span> <span class="vh-flag">-sSL</span> https://vela.science/try | <span class="vh-cmd">bash</span></code></pre>
      <p class="vh-try__note">
        Downloads a real signed proof packet and a stdlib-only Python verifier; recomputes
        every file's SHA-256 against the manifest; exits non-zero on any mismatch.
        <a class="vh-try__src" href="/try">view source</a>.
      </p>
    </div>

    <dl class="vh-stats">
      <a class="vh-stat" href={`${HUB_URL}/entries`}>
        <dt>{stats.claims}</dt>
        <dd>findings on the live frontier ↗</dd>
      </a>
      <a class="vh-stat" href="/spec#reducer">
        <dt>3</dt>
        <dd>reducer impls, byte-identical →</dd>
      </a>
      <a class="vh-stat" href="/try">
        <dt>35/35</dt>
        <dd>files verified by the proof script →</dd>
      </a>
      <div class="vh-stat">
        <dt>{lastUpdated}</dt>
        <dd>last signed</dd>
      </div>
    </dl>

    <h1 class="vh-hero__title">An open protocol for scientific findings.</h1>
    <p class="vh-hero__sub">
      Vela turns claims, evidence, uncertainty, provenance, and corrections into signed,
      versioned objects that humans and AI systems can read, verify, compose, and update.
      One Rust binary, three reducer implementations agreeing byte-for-byte, one open hub.
    </p>

    <div class="vh-hero__ctas">
      <a class="vh-btn vh-btn--primary" href="/quickstart">
        Quickstart <span aria-hidden="true">→</span>
      </a>
      <a class="vh-btn vh-btn--secondary" href="/spec">
        Read the spec <span aria-hidden="true">→</span>
      </a>
      <a class="vh-btn vh-btn--secondary" href="/workbench">
        Open workbench <span aria-hidden="true">→</span>
      </a>
    </div>
  </header>

  <!-- This is a Finding — the object, named once. -->
  <section class="vh-object" aria-label="The Finding object">
    <div class="vh-object__copy">
      <p class="vh-section__eyebrow">The object</p>
      <h2 class="vh-section__title">This is a Finding.</h2>
      <p class="vh-section__sub">
        A scientific claim, scoped, sourced, signed, and content-addressed. Carries its
        evidence, its confidence, its provenance, and a typed link graph to the findings
        that depend on it. When a Correction lands, every dependent finding knows.
      </p>
      <p class="vh-section__sub">
        Five primitives: <span class="vh-pill">Finding</span> ·
        <span class="vh-pill">EvidenceObject</span> ·
        <span class="vh-pill">Correction</span> ·
        <span class="vh-pill">Link</span> ·
        <span class="vh-pill">Frontier</span>. Defined in
        <a class="vh-link" href="/spec">/spec</a>; used in
        <a class="vh-link" href="/quickstart">/quickstart</a>.
      </p>
    </div>
    <pre class="vh-object__code"><code><span class="vh-tk">finding</span>:
  <span class="vh-tk">id</span>:        vf_83185611d673465b
  <span class="vh-tk">assertion</span>: <span class="vh-str">"Pericyte loss precedes cognitive decline in early Alzheimer's."</span>
  <span class="vh-tk">scope</span>:     [human, sporadic_AD, prodromal_stage]
  <span class="vh-tk">confidence</span>:
    <span class="vh-tk">score</span>: 0.62
    <span class="vh-tk">basis</span>: replication_count + study_design
  <span class="vh-tk">evidence</span>:
    - <span class="vh-tk">type</span>: postmortem_histology
      <span class="vh-tk">doi</span>:  10.1038/jcbfm.2015.44
  <span class="vh-tk">provenance</span>:
    <span class="vh-tk">extracted_from</span>: halliday-2016.pdf
    <span class="vh-tk">reviewed_by</span>:    reviewer:halliday-lab
  <span class="vh-tk">signature</span>:  ed25519:88ccb43144e9e228…
  <span class="vh-tk">links</span>:
    <span class="vh-tk">narrowed_by</span>: vrev_b0144a…   <span class="vh-cm"># Montagne 2020 → APOE4-positive only</span>
    <span class="vh-tk">depends</span>:     [vf_a91c…, vf_4d22…]</code></pre>
  </section>

  <!-- Three pillars — Rust-style. -->
  <section class="vh-pillars" aria-label="Three pillars">
    <div class="vh-pillar">
      <h3 class="vh-pillar__title">Structured.</h3>
      <p class="vh-pillar__body">
        Findings, evidence, corrections, and links are first-class objects with declared
        schemas. Not free-text papers, not metadata-on-PDFs. The substrate stores claims,
        not artifacts.
      </p>
    </div>
    <div class="vh-pillar">
      <h3 class="vh-pillar__title">Provenance-preserving.</h3>
      <p class="vh-pillar__body">
        Every event is content-addressed and signed with Ed25519 over canonical-JSON.
        The reducer is deterministic: same input bytes, same output bytes, in three
        independent implementations. No hidden state, no replay drift.
      </p>
    </div>
    <div class="vh-pillar">
      <h3 class="vh-pillar__title">Correctable.</h3>
      <p class="vh-pillar__body">
        A Correction is an event, not an erratum buried beside a paper. When a finding
        weakens or a scope narrows, every downstream finding, trial, and review article
        that depended on it is notified by the dependency graph.
      </p>
    </div>
  </section>

  <!-- What Vela is not — vendor-neutral substrate positioning (OpenTelemetry move). -->
  <section class="vh-not" aria-label="What Vela is not">
    <p class="vh-not__title">What Vela is not.</p>
    <p class="vh-not__body">
      Vela is not an electronic lab notebook, not a publisher, not a citation manager,
      not a knowledge graph, not an AI scientist, and not a journal replacement. It is
      the open shared-state layer those systems can write to, read from, and verify
      against. Apache Arrow for code, the Protein Data Bank for structures, OpenTelemetry
      for traces — Vela for findings.
    </p>
  </section>

  <!-- Live frontier — claim cards, no decorative viz. -->
  <section class="vh-section" aria-label="Live frontier">
    <div class="vh-section__head">
      <p class="vh-section__eyebrow">Live frontier · {FRONTIER.name}</p>
      <h2 class="vh-section__title">Strongest claims, by confidence.</h2>
      <p class="vh-section__sub">
        {stats.claims} signed findings, {stats.papers} papers, {stats.contradictions} open
        contradictions. Each card is content-addressed; click to read the evidence chain.
      </p>
    </div>

    <div class="vh-grid">
      {featured.map((c) => <ClaimCard claim={c} />)}
    </div>

    <div class="vh-section__foot">
      <a class="vh-link" href="/workbench">Open the workbench →</a>
      {tensionList.length > 0 && (
        <a class="vh-link" href="/workbench?contested=1">
          {tensionList.length} open contradictions →
        </a>
      )}
      <a class="vh-link" href="/quickstart">Deposit your first finding →</a>
    </div>
  </section>

  <!-- Build on this -->
  <section class="vh-section" aria-label="Build on this">
    <div class="vh-section__head">
      <p class="vh-section__eyebrow">Build on this</p>
      <h2 class="vh-section__title">One binary. One open hub. Query it now.</h2>
      <p class="vh-section__sub">
        Compile a frontier from a folder of papers, or pull signed manifests from the live hub.
      </p>
    </div>

    <div class="vh-build">
      <div class="vh-build__pane">
        <div class="vh-build__pane-head">
          <span class="vh-build__pane-tag">$ run locally</span>
          <span class="vh-build__pane-aside">~60 seconds</span>
        </div>
        <pre class="vh-code vh-code--block"><code><span class="vh-ps">$</span> <span class="vh-cmd">git clone</span> {REPO_URL}
<span class="vh-ps">$</span> <span class="vh-cmd">cd</span> vela <span class="vh-ps">&&</span> <span class="vh-cmd">cargo build</span> <span class="vh-flag">--release</span>
<span class="vh-ps">$</span> ./target/release/vela <span class="vh-cmd">frontier compile</span> ./papers
<span class="vh-ps">$</span> ./target/release/vela <span class="vh-cmd">serve --workbench</span></code></pre>
      </div>
      <div class="vh-build__pane">
        <div class="vh-build__pane-head">
          <span class="vh-build__pane-tag">$ query the live hub</span>
          <span class="vh-build__pane-aside">no auth · CORS open</span>
        </div>
        <pre class="vh-code vh-code--block"><code><span class="vh-ps">$</span> <span class="vh-cmd">curl</span> {HUB_URL}/entries \
    <span class="vh-flag">-H</span> <span class="vh-str">"accept: application/json"</span>
{`
# {"entries":[
#   {"vfr_id":"vfr_bd91…",
#    "name":"Alzheimer's Therapeutics",
#    "owner_actor_id":"reviewer:will-blair",
#    "snapshot_hash":"f23b4aba17…"}, …]}`}</code></pre>
      </div>
    </div>
  </section>

  <!-- Site directory -->
  <nav class="vh-directory" aria-label="Site directory">
    <div class="vh-directory__col">
      <p class="vh-directory__head">Docs</p>
      <a class="vh-directory__link" href="/docs">All docs</a>
      <a class="vh-directory__link" href="/spec">Protocol spec</a>
      <a class="vh-directory__link" href="/sdk">SDK reference</a>
      <a class="vh-directory__link" href="/quickstart">Quickstart</a>
      <a class="vh-directory__link" href="/examples">Examples</a>
      <a class="vh-directory__link" href="/faq">FAQ</a>
    </div>
    <div class="vh-directory__col">
      <p class="vh-directory__head">Try</p>
      <a class="vh-directory__link" href="/workbench">Workbench</a>
      <a class="vh-directory__link" href="/try">30-second proof</a>
      <a class="vh-directory__link" href={`${HUB_URL}/entries`} rel="noopener">Hub entries</a>
      <a class="vh-directory__link" href="/replay">Replay an event log</a>
      <a class="vh-directory__link" href="/frontiers/alzheimers-bbb">Alzheimer's BBB corridor</a>
    </div>
    <div class="vh-directory__col">
      <p class="vh-directory__head">Verify</p>
      <a class="vh-directory__link" href="/proof/pericyte-correction">Worked Correction</a>
      <a class="vh-directory__link" href="/proof/contradiction">Worked contradiction</a>
      <a class="vh-directory__link" href="/proof/packet">Signed proof packet</a>
      <a class="vh-directory__link" href="/counterfactual">Counterfactuals</a>
    </div>
    <div class="vh-directory__col">
      <p class="vh-directory__head">Project</p>
      <a class="vh-directory__link" href="/governance">Governance</a>
      <a class="vh-directory__link" href={REPO_URL} rel="noopener">github.com/vela-science/vela</a>
      <a class="vh-directory__link" href={HUB_URL} rel="noopener">vela-hub.fly.dev</a>
      <a class="vh-directory__link" href="/vela_reducer.py">vela_reducer.py</a>
      <a class="vh-directory__link" href="/vela_reducer.mjs">vela_reducer.mjs</a>
    </div>
  </nav>

  <footer class="vh-foot" role="contentinfo">
    <dl class="vh-foot__meta">
      <div class="vh-foot__cell">
        <dt>Spec version</dt>
        <dd><a class="vh-foot__link" href="/spec">v{VERSION}</a></dd>
      </div>
      <div class="vh-foot__cell">
        <dt>License</dt>
        <dd><a class="vh-foot__link" href={`${REPO_URL}/blob/main/LICENSE`} rel="noopener">Apache-2.0 / MIT</a></dd>
      </div>
      <div class="vh-foot__cell">
        <dt>Hub</dt>
        <dd><a class="vh-foot__link" href={`${HUB_URL}/.well-known/vela`} rel="noopener">vela-hub.fly.dev</a></dd>
      </div>
      <div class="vh-foot__cell">
        <dt>Last signed</dt>
        <dd><span class="vh-foot__mono">{lastUpdated}</span></dd>
      </div>
      <div class="vh-foot__cell">
        <dt>Source</dt>
        <dd><a class="vh-foot__link" href={REPO_URL} rel="noopener">github</a></dd>
      </div>
      <div class="vh-foot__cell">
        <dt>Security</dt>
        <dd><a class="vh-foot__link" href={`${REPO_URL}/security/policy`} rel="noopener">policy</a></dd>
      </div>
    </dl>
  </footer>
</Reading>

<style>
  /* ── Hero ─────────────────────────────────────────────────────── */
  .vh-hero {
    max-width: 64rem;
  }
  .vh-hero__eyebrow {
    margin: 0 0 1.6rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--ink-3);
    letter-spacing: 0.02em;
  }
  .vh-hero__title {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: clamp(2rem, 4.2vw, 2.8rem);
    line-height: 1.08;
    letter-spacing: -0.022em;
    color: var(--ink-0);
    margin: 2.6rem 0 1rem;
    text-wrap: balance;
    max-width: 36ch;
  }
  .vh-hero__sub {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: clamp(1rem, 1.3vw, 1.1rem);
    line-height: 1.55;
    letter-spacing: -0.005em;
    color: var(--ink-2);
    margin: 0 0 2rem;
    max-width: 60ch;
    text-wrap: pretty;
  }

  .vh-hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .vh-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 22px;
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.95rem;
    letter-spacing: -0.005em;
    text-decoration: none;
    border-radius: 8px;
    transition:
      background 160ms var(--ease),
      color 160ms var(--ease),
      border-color 160ms var(--ease),
      transform 160ms var(--ease);
  }
  .vh-btn--primary {
    background: var(--ink-0);
    color: var(--paper-0);
    border: 1px solid var(--ink-0);
  }
  .vh-btn--primary:hover {
    background: var(--ink-1);
    transform: translateY(-1px);
  }
  .vh-btn--secondary {
    background: transparent;
    color: var(--ink-1);
    border: 1px solid color-mix(in oklab, var(--ink-1) 28%, transparent);
  }
  .vh-btn--secondary:hover {
    border-color: var(--ink-1);
    background: var(--paper-1);
    transform: translateY(-1px);
  }
  .vh-btn span { transition: transform 160ms var(--ease); }
  .vh-btn:hover span { transform: translateX(2px); }

  /* Try-it block */
  .vh-try {
    background: var(--paper-1);
    border: 1px solid var(--rule-2);
    border-radius: 10px;
    margin-bottom: 2rem;
    overflow: hidden;
  }
  .vh-try__head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px 18px;
    border-bottom: 1px solid var(--rule-1);
    background: color-mix(in oklab, var(--paper-2) 35%, var(--paper-1));
  }
  .vh-try__tag {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: color-mix(in oklab, var(--gold) 76%, var(--ink-2));
  }
  .vh-try__src {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--ink-3);
    text-decoration: none;
    transition: color 160ms var(--ease);
  }
  .vh-try__src:hover { color: var(--gold); }

  .vh-code {
    margin: 0;
    padding: 14px 18px;
    font-family: var(--font-mono);
    font-size: 0.88rem;
    line-height: 1.6;
    color: var(--ink-1);
    background: transparent;
    overflow-x: auto;
    white-space: pre;
  }
  .vh-code code { background: transparent; border: 0; padding: 0; font: inherit; color: inherit; }
  .vh-ps { color: color-mix(in oklab, var(--gold) 60%, var(--ink-3)); }
  .vh-cmd { color: var(--ink-0); font-weight: 500; }
  .vh-flag { color: var(--ink-2); }
  .vh-str { color: color-mix(in oklab, var(--moss) 70%, var(--ink-1)); }

  .vh-try__note {
    margin: 0;
    padding: 0 18px 14px;
    font-family: var(--font-sans);
    font-size: 0.9rem;
    line-height: 1.5;
    color: var(--ink-3);
    text-wrap: pretty;
    max-width: 72ch;
  }

  /* Stats row */
  .vh-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    margin: 0;
    padding: 0;
    border-top: 1px solid var(--rule-2);
    border-bottom: 1px solid var(--rule-2);
  }
  .vh-stat {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 1.1rem 0 1rem;
    border-right: 1px solid var(--rule-1);
    text-decoration: none;
    color: inherit;
    transition: background 160ms var(--ease);
  }
  a.vh-stat:hover { background: var(--paper-1); }
  a.vh-stat:hover dt { color: var(--gold); }
  .vh-stat:first-child { padding-left: 0; }
  .vh-stat:not(:first-child) { padding-left: 1.4rem; }
  .vh-stat:last-child { border-right: 0; }
  .vh-stat dt {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 1.5rem;
    line-height: 1;
    color: var(--ink-0);
    letter-spacing: -0.02em;
    font-variant-numeric: tabular-nums;
    margin: 0;
  }
  .vh-stat dd {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-3);
    margin: 0;
  }

  /* ── Object panel: prose left, JSON right (Stripe code-panel move) */
  .vh-object {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.2fr);
    gap: 2rem;
    align-items: start;
    max-width: 76rem;
  }
  @media (max-width: 880px) {
    .vh-object { grid-template-columns: 1fr; }
  }
  .vh-object__copy { display: flex; flex-direction: column; gap: 0.85rem; }
  .vh-object__copy .vh-section__sub { margin: 0; }
  .vh-object__code {
    margin: 0;
    padding: 18px 20px 20px;
    background: var(--paper-1);
    border: 1px solid var(--rule-2);
    border-radius: 8px;
    font-family: var(--font-mono);
    font-size: 12px;
    line-height: 1.62;
    color: var(--ink-1);
    overflow-x: auto;
    white-space: pre;
  }
  .vh-object__code code { background: transparent; border: 0; padding: 0; font: inherit; color: inherit; }
  .vh-tk { color: color-mix(in oklab, var(--gold) 70%, var(--ink-3)); }
  .vh-str { color: color-mix(in oklab, var(--moss) 72%, var(--ink-1)); }
  .vh-cm { color: var(--ink-3); font-style: italic; }
  .vh-pill {
    display: inline-block;
    padding: 1px 7px;
    margin: 0 1px;
    font-family: var(--font-mono);
    font-size: 0.78em;
    color: var(--ink-1);
    background: var(--paper-1);
    border: 1px solid var(--rule-2);
    border-radius: 4px;
    white-space: nowrap;
  }

  /* ── Three pillars — Rust-style. */
  .vh-pillars {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    max-width: 76rem;
    padding-top: 2rem;
    border-top: 1px solid var(--rule-2);
  }
  @media (max-width: 880px) {
    .vh-pillars { grid-template-columns: 1fr; gap: 1.4rem; }
  }
  .vh-pillar { display: flex; flex-direction: column; gap: 0.5rem; }
  .vh-pillar__title {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 1.05rem;
    line-height: 1.3;
    letter-spacing: -0.018em;
    text-transform: none;
    color: var(--ink-0);
    margin: 0;
  }
  .vh-pillar__body {
    font-family: var(--font-sans);
    font-size: 0.94rem;
    line-height: 1.55;
    color: var(--ink-2);
    margin: 0;
    text-wrap: pretty;
  }

  /* ── What Vela is not — vendor-neutral disambiguation. */
  .vh-not {
    max-width: 64rem;
    padding: 1.4rem 1.6rem;
    background: var(--paper-1);
    border-left: 2px solid color-mix(in oklab, var(--gold) 56%, transparent);
    border-radius: 0 6px 6px 0;
  }
  .vh-not__title {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: color-mix(in oklab, var(--gold) 76%, var(--ink-2));
    margin: 0 0 0.6rem;
  }
  .vh-not__body {
    font-family: var(--font-sans);
    font-size: 0.96rem;
    line-height: 1.6;
    color: var(--ink-1);
    margin: 0;
    max-width: 70ch;
    text-wrap: pretty;
  }

  /* ── Section frame ───────────────────────────────────────────── */
  .vh-section {
    max-width: 76rem;
  }
  .vh-section__head { margin-bottom: 2.2rem; max-width: 64rem; }
  .vh-section__eyebrow {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: color-mix(in oklab, var(--gold) 78%, var(--ink-2));
    margin: 0 0 0.85rem;
  }
  .vh-section__title {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: clamp(1.5rem, 2.6vw, 2rem);
    line-height: 1.12;
    letter-spacing: -0.022em;
    color: var(--ink-0);
    margin: 0 0 0.8rem;
    text-wrap: balance;
    max-width: 36ch;
  }
  .vh-section__title--small {
    font-size: clamp(1.4rem, 2.4vw, 1.8rem);
    margin: 0;
  }
