---
import { getCollection, render } from "astro:content";
import Doc from "../../layouts/Doc.astro";

export async function getStaticPaths() {
  // Curated list of docs the public site publishes. Anything else in
  // docs/ stays unrendered until promoted here. Defined inside the
  // function so Astro's static-paths bundler picks it up.
  // (Inlined HUB_HOST literal to avoid pulling /config into this
  // bundler-detached function.)
  const HUB_HOST = "vela-hub.fly.dev";
  const PUBLIC: Record<string, { id: string; title: string; description: string }> = {
    architecture: {
      id: "architecture",
      title: "Architecture",
      description:
        "The mental model. Where Vela sits in the science stack, why the position is structurally available, and what becomes possible above it.",
    },
    protocol: {
      id: "protocol",
      title: "Protocol",
      description: "The on-disk shape: findings, frontiers, events, signatures.",
    },
    registry: {
      id: "registry",
      title: "Registry",
      description: "Verifiable distribution. Sign a manifest; anyone can pull and verify.",
    },
    hub: {
      id: "hub",
      title: "Hub",
      description: `HTTP transport over the registry. The public hub at ${HUB_HOST}.`,
    },
    publishing: {
      id: "publishing",
      title: "Publishing",
      description: "End-to-end first-publish: scaffold, sign, publish to the public hub.",
    },
    "core-doctrine": {
      id: "core_doctrine",
      title: "Core doctrine",
      description: "What Vela is and isn't. The lines that hold across versions.",
    },
    python: {
      id: "python",
      title: "Python SDK",
      description: "Programmatic access to a Vela frontier from Python.",
    },
    mcp: {
      id: "mcp",
      title: "MCP",
      description: "Tool surface for agents — read, propose, sign.",
    },
    workbench: {
      id: "workbench",
      title: "Workbench",
      description: "The browser-based review surface.",
    },
    tiers: {
      id: "tiers",
      title: "Trust tiers",
      description: "Trusted-bulk-extractor flow without a per-claim signing tax.",
    },
  };
  const docs = await getCollection("docs");
  return Object.entries(PUBLIC).map(([slug, meta]) => {
    const entry = docs.find((d) => d.id === meta.id);
    if (!entry) {
      throw new Error(
        `docs/${meta.id}.md not found for slug ${slug}; available: ${docs.map((d) => d.id).join(", ")}`,
      );
    }
    return { params: { slug }, props: { entry, meta } };
  });
}

const { entry, meta } = Astro.props;
const { Content } = await render(entry);
---
<Doc title={meta.title} description={meta.description}>
  <Content />
</Doc>
