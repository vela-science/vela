    .spec__pair--narrow { grid-template-columns: 1fr; }
    .spec__pair dt { margin-top: 0.6rem; }
    .spec__pair dt:first-of-type { margin-top: 0; }
  }
  .spec__list {
    margin: 0 0 var(--space-3);
    padding: 0 0 0 1.4rem;
  }
  .spec__list li {
    font-family: var(--font-sans);
    font-size: 0.96rem;
    line-height: 1.55;
    color: var(--ink-1);
    margin-bottom: 0.4rem;
    max-width: 70ch;
    text-wrap: pretty;
  }
  .spec__code {
