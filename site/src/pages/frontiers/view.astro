  :global(.fr-empty__body) {
    font-family: var(--font-serif);
    font-size: 15px;
    line-height: 1.55;
    color: var(--ink-2);
    margin: 0 0 14px;
    max-width: 60ch;
  }

  :global(.fr-empty__cmd) {
    font-family: var(--font-mono);
    font-size: 12.5px;
    line-height: 1.65;
    color: var(--ink-1);
    background: var(--paper-0);
    border: 1px solid var(--rule-2);
    border-radius: 4px;
    padding: 12px 14px;
    margin: 0 0 14px;
    overflow-x: auto;
    white-space: pre;
