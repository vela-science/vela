</style>

<script>
  type HubEntry = {
    vfr_id: string;
    name: string;
    owner_actor_id: string;
    owner_pubkey: string;
    network_locator: string;
    latest_snapshot_hash: string;
    latest_event_log_hash: string;
    signed_publish_at: string;
    signature: string;
    schema: string;
  };

  type Finding = {
    id: string;
    assertion?: { claim?: string; text?: string; type?: string };
    kind?: string;
    confidence?: { class?: string; tier?: string; kind?: string; score?: number };
    evidence?: unknown[];
    links?: unknown[];
    conditions?: unknown[];
    provenance?: { authors?: Array<{ id?: string }> };
    updated?: string;
    created?: string;
  };

  type FrontierFile = {
    vela_version?: string;
    schema?: string;
    frontier?: {
      name?: string;
      description?: string;
      compiled_at?: string;
      compiler?: string;
      papers_processed?: number;
      dependencies?: Array<{
        name?: string;
        vfr_id?: string;
        locator?: string;
        pinned_snapshot_hash?: string;
      }>;
    };
    findings?: Finding[];
    events?: StateEvent[];
    proposals?: StateProposal[];
    actors?: Array<{ id: string; pubkey?: string; tier?: string }>;
    stats?: Record<string, unknown>;
  };

  /** Mirror of vela_protocol::proposals::StateProposal */
  type StateProposal = {
    schema?: string;
    id: string;
    kind: string;
    target: { type: string; id: string };
    actor: { id: string; type: string };
    created_at: string;
    reason: string;
    payload?: { finding?: Finding };
    source_refs?: string[];
    status: string;
    reviewed_by?: string;
    reviewed_at?: string;
    decision_reason?: string;
    applied_event_id?: string;
    caveats?: string[];
    /** v0.22 agent provenance — present when the proposal came from
     *  Literature Scout / Notes Compiler / etc. Absent for human-
     *  authored proposals. */
    agent_run?: AgentRun;
  };

  type AgentRun = {
    agent: string;
    model?: string;
    run_id?: string;
    started_at?: string;
    finished_at?: string;
    context?: Record<string, string>;
  };

  /** Mirror of vela_protocol::events::StateEvent. */
  type StateEvent = {
    schema?: string;
    id: string;
    kind: string;
    target: { type: string; id: string };
    actor: { id: string; type: string };
    timestamp: string;
    reason: string;
    before_hash?: string;
    after_hash?: string;
    payload?: unknown;
    caveats?: string[];
    signature?: string;
  };

  function escapeHtml(s: string): string {
    return s.replace(/[&<>"']/g, (c) => ({
      "&": "&amp;",
      "<": "&lt;",
      ">": "&gt;",
      '"': "&quot;",
      "'": "&#39;",
    }[c]!));
  }

  function shortVfr(v: string, len = 16): string {
    return v.length <= len ? v : `${v.slice(0, len - 1)}…`;
  }
  function shortHash(h: string, len = 14): string {
    return h.length <= len ? h : `${h.slice(0, len - 1)}…`;
  }

  function relativeTime(iso?: string): string {
    if (!iso) return "—";
    const d = new Date(iso);
    if (Number.isNaN(d.getTime())) return iso.slice(0, 10);
    const diff = (Date.now() - d.getTime()) / 1000;
    if (diff < 60) return "just now";
    if (diff < 3600) return `${Math.floor(diff / 60)}m ago`;
    if (diff < 86400) return `${Math.floor(diff / 3600)}h ago`;
    if (diff < 604800) return `${Math.floor(diff / 86400)}d ago`;
    return d.toISOString().slice(0, 10);
  }

  function locatorHost(url?: string): string {
    if (!url) return "external";
    try { return new URL(url).hostname.replace(/^www\./, ""); }
    catch { return "external"; }
  }

  function findingKind(f: Finding): string {
    return (f.kind ?? f.assertion?.type ?? f.confidence?.class ?? "observation").toLowerCase();
  }
  function findingClaim(f: Finding): string {
    return f.assertion?.claim ?? f.assertion?.text ?? f.id ?? "(no claim)";
  }

  function setText(id: string, text: string): void {
    const el = document.getElementById(id);
    if (el) el.textContent = text;
  }

  /** Group proposals by `agent_run.run_id`. Proposals without an
   *  agent run (human-authored) collapse into a single "manual"
   *  bucket so the Inbox surface still surfaces them. Sort runs
   *  newest-first by started_at; sort proposals inside a run by
   *  created_at. */
  function groupProposalsByRun(
    proposals: StateProposal[],
  ): Array<{
    runKey: string;
    agent: string;
    model: string;
    runId: string;
    startedAt: string;
    proposals: StateProposal[];
  }> {
    const buckets = new Map<string, {
      runKey: string;
      agent: string;
      model: string;
      runId: string;
      startedAt: string;
      proposals: StateProposal[];
    }>();
    for (const p of proposals) {
      const r = p.agent_run;
      const key = r?.run_id ?? `manual:${p.actor.id}`;
      const existing = buckets.get(key);
      if (existing) {
        existing.proposals.push(p);
      } else {
        buckets.set(key, {
          runKey: key,
          agent: r?.agent ?? p.actor.id,
          model: r?.model ?? "",
          runId: r?.run_id ?? "",
          startedAt: r?.started_at ?? p.created_at,
          proposals: [p],
        });
      }
    }
    const out = Array.from(buckets.values());
    out.sort((a, b) => (a.startedAt < b.startedAt ? 1 : -1));
    for (const b of out) {
      b.proposals.sort((a, b) => (a.created_at < b.created_at ? 1 : -1));
    }
    return out;
  }

  /** Tracks browser-side staged decisions during a session. The
   *  source of truth is the queue file on the user's machine
   *  (vela serve appends; vela queue sign drains). This map only
   *  drives optimistic UI — proposal id → staged action kind. */
  const stagedState = new Map<string, "accept" | "reject">();

  /** Resolve where to POST `/api/queue` calls. Default: same-origin
   *  /api (works when the page is served by `vela serve --workbench`
   *  or behind an nginx that proxies /api/* to a local vela serve).
   *  Override via `?api=https://localhost:3848` so the deployed
   *  Astro site can also drive a local backend. */
  function apiBase(): string {
    const url = new URL(window.location.href);
    const explicit = url.searchParams.get("api");
    if (explicit) return explicit.replace(/\/+$/, "");
    return "";
  }

  /** Whether action buttons are wired. We *always* render them, but
   *  on the public deployed site they degrade to a single hint
   *  pointing the user at `?api=…` so the buttons aren't fake. */
  function actionsAreWired(): boolean {
    const url = new URL(window.location.href);
    if (url.searchParams.get("api")) return true;
    // Also wire on localhost — the page is presumably running off
    // the same vela serve as the API.
    return /^localhost(:|$)/.test(window.location.host);
  }

  async function postQueueAction(
    kind: "accept_proposal" | "reject_proposal",
    proposalId: string,
    reason: string,
  ): Promise<{ ok: boolean; error?: string; queueFile?: string }> {
    const base = apiBase();
    try {
      const r = await fetch(`${base}/api/queue`, {
        method: "POST",
        headers: { "content-type": "application/json", accept: "application/json" },
        body: JSON.stringify({
          kind,
          args: { proposal_id: proposalId, reason },
        }),
      });
      if (!r.ok) {
        const text = await r.text().catch(() => `${r.status}`);
        return { ok: false, error: `HTTP ${r.status}: ${text}` };
      }
      const body = (await r.json()) as { queue_file?: string };
      return { ok: true, queueFile: body.queue_file };
    } catch (err) {
      return {
        ok: false,
        error: err instanceof Error ? err.message : String(err),
      };
    }
  }

  function renderBanner(): void {
    const banner = document.getElementById("ib-banner");
    if (!banner) return;
    const acceptCount = Array.from(stagedState.values()).filter((v) => v === "accept").length;
    const rejectCount = Array.from(stagedState.values()).filter((v) => v === "reject").length;
    const total = acceptCount + rejectCount;
    if (total === 0) {
      banner.hidden = true;
      banner.innerHTML = "";
      return;
    }
    banner.hidden = false;
    const cmd = "vela queue sign --all";
    banner.innerHTML = `
      <span class="ib-banner__text">
        <strong>${total}</strong> action${total === 1 ? "" : "s"} staged in your local queue
        (${acceptCount} accept, ${rejectCount} reject). Sign and apply with the CLI:
      </span>
      <span class="ib-banner__cmd">${cmd}</span>
      <button class="ib-banner__copy" data-copy-cmd="${cmd}">Copy</button>
    `;
    banner.querySelector<HTMLButtonElement>("[data-copy-cmd]")?.addEventListener("click", async (e) => {
      const btn = e.currentTarget as HTMLButtonElement;
      const text = btn.dataset.copyCmd ?? "";
      try {
        await navigator.clipboard.writeText(text);
        const original = btn.textContent;
        btn.textContent = "Copied ✓";
        setTimeout(() => { btn.textContent = original; }, 1400);
      } catch {
        // ignore
      }
    });
  }

  /** Render the Inbox tab from a frontier's `proposals` array. */
  function renderInbox(proposals: StateProposal[]): void {
    const summaryHost = document.getElementById("ib-summary");
    const runsHost = document.getElementById("ib-runs");
    if (!summaryHost || !runsHost) return;

    const pending = proposals.filter((p) => p.status === "pending_review");
    const accepted = proposals.filter((p) => p.status === "accepted");
    const applied = proposals.filter((p) => p.status === "applied");
    const rejected = proposals.filter((p) => p.status === "rejected");

    if (proposals.length === 0) {
      summaryHost.textContent = "";
      runsHost.innerHTML = `<div class="fr-empty">No agent proposals yet. Run <code>vela scout &lt;folder&gt; --frontier &lt;path&gt;</code> against this frontier to populate the Inbox.</div>`;
      return;
    }

    summaryHost.innerHTML = `
      <strong>${pending.length}</strong> pending review
      · <strong>${accepted.length}</strong> accepted
      · <strong>${applied.length}</strong> applied
      · <strong>${rejected.length}</strong> rejected
      · <strong>${proposals.length}</strong> total
    `;

    const wired = actionsAreWired();
    const groups = groupProposalsByRun(proposals);
    runsHost.innerHTML = groups.map((g) => {
      const runIdShort = g.runId
        ? escapeHtml(g.runId.slice(0, 16) + (g.runId.length > 16 ? "…" : ""))
        : "(human)";
      const modelLabel = g.model ? escapeHtml(g.model) : "(env model)";
      const when = relativeTime(g.startedAt);
      const cards = g.proposals.map((p) => renderProposalCard(p, wired)).join("");
      return `<div class="ib-run">
  <header class="ib-run__head">
    <span class="ib-run__agent">${escapeHtml(g.agent)}</span>
    <span class="ib-run__id" title="${escapeHtml(g.runId)}">${runIdShort}</span>
    <span class="ib-run__model">${modelLabel}</span>
    <span class="ib-run__count">${g.proposals.length} proposal${g.proposals.length === 1 ? "" : "s"}</span>
    <span class="ib-run__when">${escapeHtml(when)}</span>
  </header>
  ${cards}
</div>`;
    }).join("");

    // Wire action buttons. Each card has accept / reject buttons
    // tagged with the proposal id; on click we POST to /api/queue
    // and switch the card to its staged visual state.
    runsHost.querySelectorAll<HTMLButtonElement>("[data-stage]").forEach((btn) => {
      btn.addEventListener("click", async (ev) => {
        ev.preventDefault();
        const action = btn.dataset.stage as "accept" | "reject";
        const proposalId = btn.dataset.proposalId ?? "";
        if (!proposalId) return;
        const card = btn.closest<HTMLElement>(".ib-card");
        if (!card) return;
        // Disable both buttons inside the card while in flight.
        card.querySelectorAll<HTMLButtonElement>(".ib-card__btn").forEach((b) => {
          b.disabled = true;
        });
        const reason = action === "accept"
          ? "Accepted from Inbox"
          : "Rejected from Inbox";
        const kind = action === "accept" ? "accept_proposal" : "reject_proposal";
        const result = await postQueueAction(kind, proposalId, reason);
        if (result.ok) {
          stagedState.set(proposalId, action);
          markCardStaged(card, action);
          renderBanner();
        } else {
          // Re-enable on failure and show the error inline.
          card.querySelectorAll<HTMLButtonElement>(".ib-card__btn").forEach((b) => {
            b.disabled = false;
          });
          const hint = card.querySelector<HTMLElement>(".ib-card__hint");
          if (hint) {
            hint.textContent = `staging failed: ${result.error ?? "unknown error"}`;
            hint.style.color = "var(--state-lost)";
            hint.style.fontStyle = "normal";
          }
        }
      });
    });

    renderBanner();
  }

  function markCardStaged(card: HTMLElement, action: "accept" | "reject"): void {
    card.classList.add(`is-staged-${action}`);
    card.classList.add("is-disabled-actions");
    const meta = card.querySelector<HTMLElement>(".ib-card__meta");
    if (meta) {
      const pillClass = action === "accept" ? "ib-card__staged-pill--accept" : "ib-card__staged-pill--reject";
      const word = action === "accept" ? "staged · accept" : "staged · reject";
      const pendingPill = meta.querySelector<HTMLElement>(".ib-card__pending");
      if (pendingPill) {
        pendingPill.className = `ib-card__staged-pill ${pillClass}`;
        pendingPill.textContent = word;
      }
    }
    // Buttons stay disabled (they are already from the click handler).
    // Hint line clarifies what happened.
    const hint = card.querySelector<HTMLElement>(".ib-card__hint");
    if (hint) {
      hint.textContent = action === "accept"
        ? "staged for accept · in queue"
        : "staged for reject · in queue";
      hint.style.color = "";
      hint.style.fontStyle = "italic";
    }
  }

  function renderProposalCard(p: StateProposal, wired: boolean): string {
    const finding = p.payload?.finding;
    const claim = finding ? findingClaim(finding) : `(no payload finding) ${p.id}`;
    const rationale = p.reason || "";
    const flags = p.caveats ?? [];
    const sources = p.source_refs ?? [];
    const status = p.status;
    const isPending = status === "pending_review";

    const sourceChips = sources
      .map((s) => `<span class="ib-card__chip ib-card__chip--source" title="${escapeHtml(s)}">${escapeHtml(shortenSource(s))}</span>`)
      .join("");
    const flagChips = flags
      .map((f) => {
        const variant = `ib-card__chip--flag--${f}`;
        return `<span class="ib-card__chip ib-card__chip--flag ${variant}">${escapeHtml(f)}</span>`;
      })
      .join("");

    // Action buttons: only render for pending proposals. When the
    // page isn't wired to a local backend (`?api=` missing on the
    // public site), buttons are disabled with an inline hint so
    // the surface stays honest.
    const actionsHtml = isPending ? `
    <div class="ib-card__actions">
      <button class="ib-card__btn ib-card__btn--reject" data-stage="reject" data-proposal-id="${escapeHtml(p.id)}" ${wired ? "" : "disabled"}>Reject</button>
      <button class="ib-card__btn ib-card__btn--accept" data-stage="accept" data-proposal-id="${escapeHtml(p.id)}" ${wired ? "" : "disabled"}>Accept</button>
    </div>
    <div class="ib-card__hint">${wired ? "" : "wire <code>?api=http://localhost:3848</code> to enable actions"}</div>` : "";

    return `<div class="ib-card">
  <div class="ib-card__main">
    <p class="ib-card__claim">${escapeHtml(claim)}</p>
    ${rationale ? `<p class="ib-card__rationale">${escapeHtml(rationale)}</p>` : ""}
    <div class="ib-card__sub">
      <span class="ib-card__chip ib-card__chip--id" title="${escapeHtml(p.id)}">${escapeHtml(p.id)}</span>
      ${sourceChips}
      ${flagChips}
    </div>
  </div>
  <div class="ib-card__meta">
    <span class="ib-card__pending">${escapeHtml(status)}</span>
    <div>${escapeHtml(relativeTime(p.created_at))}</div>
    ${actionsHtml}
  </div>
</div>`;
  }

  function shortenSource(s: string): string {
    // Pull just the filename out of /var/folders/.../paper.pdf or similar
    const slash = s.lastIndexOf("/");
    if (slash >= 0 && slash < s.length - 1) return s.slice(slash + 1);
    return s.length > 36 ? s.slice(0, 35) + "…" : s;
  }

  /** Map `events[i].kind` to a CSS variant for color-coding. The
   *  protocol's event kinds use dotted names like "finding.add" or
   *  "finding.review"; we read the second segment and group
   *  "review", "accept_review" → "review". Anything we don't
   *  recognize falls through to "unknown" (neutral grey). */
  function eventKindVariant(kind: string): string {
    const segs = kind.split(".");
    const tail = (segs[1] ?? segs[0] ?? "").toLowerCase();
    if (tail.startsWith("add") || tail.startsWith("assert")) return "add";
    if (tail.startsWith("review")) return "review";
    if (tail.startsWith("retract")) return "retract";
    if (tail.startsWith("note")) return "note";
    if (tail.startsWith("caveat")) return "caveat";
    if (tail.startsWith("revise") || tail.startsWith("revision")) return "revise";
    return "unknown";
  }

  /** Render the Diff tab — recent state events newest-first. The
   *  v0.22 view is intentionally lightweight: list-based, color-
   *  chip per kind, no ascii diff yet. The Inbox + sign loop is
   *  the primary action; this tab is the "what landed" record. */
  function renderDiff(events: StateEvent[]): void {
    const summaryHost = document.getElementById("df-summary");
    const eventsHost = document.getElementById("df-events");
    if (!summaryHost || !eventsHost) return;

    if (events.length === 0) {
      summaryHost.innerHTML = "";
      eventsHost.innerHTML = `<div class="fr-empty">No state events yet. After accepting proposals from the Inbox and running <code>vela queue sign --all</code>, signed events appear here.</div>`;
      return;
    }

    const sorted = events.slice().sort((a, b) => (a.timestamp < b.timestamp ? 1 : -1));

    // Summary chips by kind variant.
    const counts = new Map<string, number>();
    for (const e of sorted) {
      const v = eventKindVariant(e.kind);
      counts.set(v, (counts.get(v) ?? 0) + 1);
    }
    const order = ["add", "review", "revise", "retract", "note", "caveat", "unknown"];
    summaryHost.innerHTML = order
      .filter((v) => (counts.get(v) ?? 0) > 0)
      .map((v) => {
        const label = v === "add"
          ? "added"
          : v === "review"
          ? "reviewed"
          : v === "revise"
          ? "revised"
          : v === "retract"
          ? "retracted"
          : v === "note"
          ? "annotated"
          : v === "caveat"
          ? "caveats"
          : "other";
        return `<span class="df-summary__chip"><strong>${counts.get(v)}</strong> ${label}</span>`;
      })
      .join("");

    eventsHost.innerHTML = sorted.map((e) => {
      const variant = eventKindVariant(e.kind);
      const target = e.target?.id ?? "—";
      const actor = e.actor?.id ?? "—";
      const when = relativeTime(e.timestamp);
      const reason = e.reason ?? "";
      const sigBadge = e.signature ? "signed" : "unsigned";
      return `<div class="df-event">
  <span class="df-event__kind df-event__kind--${variant}">${escapeHtml(e.kind)}</span>
  <div class="df-event__main">
    <div class="df-event__target" title="${escapeHtml(target)}">${escapeHtml(target)}</div>
    ${reason ? `<p class="df-event__reason">${escapeHtml(reason)}</p>` : ""}
    <div class="df-event__sub">
      <span><strong>${escapeHtml(actor)}</strong></span>
      <span>${escapeHtml(sigBadge)}</span>
    </div>
  </div>
  <div class="df-event__when" title="${escapeHtml(e.timestamp)}">${escapeHtml(when)}</div>
</div>`;
    }).join("");
  }

  // Dev-only hook: lets browser-side smoke tests exercise the
  // renderers without a real backend. Safe in production — no
  // behavior change unless something deliberately calls into it.
  (window as unknown as { __vela?: Record<string, unknown> }).__vela = {
    ...((window as unknown as { __vela?: Record<string, unknown> }).__vela ?? {}),
    renderInbox,
    renderDiff,
    groupProposalsByRun,
  };

  function setHref(id: string, href: string): void {
    const el = document.getElementById(id) as HTMLAnchorElement | null;
    if (el) el.href = href;
  }

  (async function () {
    const root = document.querySelector("[data-fr]") as HTMLElement | null;
    if (!root) return;
    const hubUrl = root.dataset.hubUrl ?? "https://vela-hub.fly.dev";

    const url = new URL(window.location.href);
    const vfr = url.searchParams.get("vfr");
    // v0.29 local-mode: when the URL carries ?api=…, the page treats
    // the deployed Astro shell as a local Workbench client. The hub
    // is bypassed entirely; the frontier is fetched from the local
    // `vela serve --workbench` API and a HubEntry-equivalent is
    // synthesized from the Project metadata. This is what closes
    // Friction #1 from the v0.28 sim-user pass: a researcher with a
    // local frontier doesn't need to publish to the hub before they
    // can review proposals in a browser.
    const apiBaseStr = (url.searchParams.get("api") ?? "").replace(/\/$/, "");
    const localMode = !!apiBaseStr;

    if (!vfr && !localMode) {
      setText("fr-name", "No frontier specified");
      setText("fr-desc", "Add ?vfr=vfr_… to the URL, or pick one from the directory. Local mode: append ?api=http://localhost:3848 to point at a `vela serve --workbench` instance.");
      return;
    }

    // v0.29.2: mixed-content guard. Browsers silently block HTTPS →
    // HTTP fetches; the page would just hang on a stalled request
    // with "…" placeholders and no console error. Detect the scheme
    // mismatch up-front and tell the user exactly what to do
    // instead. Closes Friction #9 from sim-user pass #2.
    if (localMode && window.location.protocol === "https:" && apiBaseStr.startsWith("http://")) {
      setText("fr-name", "Mixed-content blocked");
      const descEl = document.getElementById("fr-desc");
      if (descEl) {
        descEl.innerHTML = `This page is served over <code>https</code>, but <code>${escapeHtml(apiBaseStr)}</code> is <code>http</code>. Browsers silently block this combination — your local API is reachable, the page just can't fetch it from here.<br><br>Two ways out:<br>&nbsp;1. Run the Astro site locally and use that origin instead:&nbsp; <code>cd site &amp;&amp; bun run dev</code>, then open<br>&nbsp;&nbsp;&nbsp;&nbsp;<code>http://localhost:4321/frontiers/view?api=${escapeHtml(apiBaseStr)}</code><br>&nbsp;2. Expose your <code>vela serve</code> via TLS (cloudflared, ngrok, tailscale-funnel) and pass that <code>https://</code> URL as <code>?api=</code>.`;
      }
      return;
    }

    // Page meta — title gets a better name once the project loads in
    // local mode (set below after the synthesis step).
    document.title = `${vfr ?? "local frontier"} · Vela`;
    if (!localMode && vfr) {
      setHref("fr-rawmanifest", `${hubUrl}/entries/${encodeURIComponent(vfr)}`);
    }

    // Tabs
    const tabs = Array.from(root.querySelectorAll<HTMLButtonElement>(".fr-tab"));
    const panes = Array.from(root.querySelectorAll<HTMLElement>(".fr-pane"));
    tabs.forEach((t) => {
      t.addEventListener("click", () => {
        tabs.forEach((x) => x.classList.toggle("fr-tab--on", x === t));
        const target = t.dataset.tab;
        panes.forEach((p) => {
          p.hidden = p.dataset.pane !== target;
        });
      });
    });

    // Fetch the entry. Two paths:
    //   • hub mode: GET ${hubUrl}/entries → pick by vfr_id
    //   • local mode (?api=): GET ${api}/api/frontier → synthesize
    let entry: HubEntry | null = null;
    let allEntries: HubEntry[] = [];
    let localFrontier: FrontierFile | null = null;
    if (localMode) {
      try {
        const r = await fetch(`${apiBaseStr}/api/frontier`, { headers: { accept: "application/json" } });
        if (!r.ok) throw new Error(`local api ${r.status}`);
        localFrontier = (await r.json()) as FrontierFile;
      } catch (err) {
        setText("fr-name", "Local API unreachable");
        setText("fr-desc", `${apiBaseStr}/api/frontier: ${String(err)}`);
        return;
      }
      // Synthesize a HubEntry-equivalent from the Project. We don't
      // have a real signed publish manifest in local mode, so we use
      // placeholder strings the rest of the renderer treats as
      // metadata-only — none of the cryptographic fields are needed
      // until the user publishes via `vela registry publish`.
      const projectName = localFrontier.frontier?.name ?? "Local frontier";
      const ownerActor = (localFrontier.actors ?? [])[0]?.id ?? "local:reviewer";
      const synthVfr = vfr ?? localFrontier.frontier_id ?? "local";
      entry = {
        vfr_id: synthVfr,
        name: projectName,
        owner_actor_id: ownerActor,
        owner_pubkey: "—",
        network_locator: `${apiBaseStr}/api/frontier`,
        latest_snapshot_hash: "local",
        latest_event_log_hash: "local",
        signed_publish_at: localFrontier.frontier?.compiled_at ?? new Date().toISOString(),
        signature: "—",
        schema: localFrontier.schema ?? "vela/local",
      };
      allEntries = [entry];
      document.title = `${projectName} (local) · Vela`;
    } else {
      try {
        const r = await fetch(`${hubUrl}/entries`, { headers: { accept: "application/json" } });
        if (!r.ok) throw new Error(`hub ${r.status}`);
        const data = (await r.json()) as { entries: HubEntry[] };
        allEntries = data.entries ?? [];
        // The hub returns latest-publish-wins per vfr_id; we still pick by vfr_id.
        entry = allEntries.find((e) => e.vfr_id === vfr) ?? null;
      } catch (err) {
        setText("fr-name", "Hub unreachable");
        setText("fr-desc", String(err));
        return;
      }
    }

    if (!entry) {
      setText("fr-name", "Frontier not found on hub");
      setText("fr-desc", `No entry for ${vfr}.`);
      return;
    }

    // Header from hub data
    const headEyebrow = document.querySelector(".wb-head__eyebrow");
    if (headEyebrow) headEyebrow.innerHTML = `Frontier · <span style="color:var(--ink-2);">${escapeHtml(entry.name)}</span>`;
    const headTitle = document.querySelector(".wb-head__title");
    if (headTitle) headTitle.textContent = entry.name;

    setText("fr-name", entry.name);
    const ownerEl = document.getElementById("fr-owner");
    if (ownerEl) {
      ownerEl.textContent = entry.owner_actor_id;
      (ownerEl as HTMLAnchorElement).href = `/?actor=${encodeURIComponent(entry.owner_actor_id)}`;
    }
    setText("fr-vfr", entry.vfr_id);
    setText("fr-snap", `snapshot ${shortHash(entry.latest_snapshot_hash, 18)}`);
    setText("fr-when", relativeTime(entry.signed_publish_at));

    // Sidebar from hub data (description filled in after the locator fetch)
    setText("fr-side-vfr", entry.vfr_id);
    setText("fr-side-schema", entry.schema);
    setText("fr-side-owner", entry.owner_actor_id);
    setText("fr-side-pubkey", shortHash(entry.owner_pubkey, 22));
    const pubkeyEl = document.getElementById("fr-side-pubkey");
    if (pubkeyEl) pubkeyEl.title = entry.owner_pubkey;
    setText("fr-side-signed", new Date(entry.signed_publish_at).toISOString().replace("T", " ").slice(0, 19) + "Z");

    const locDd = document.getElementById("fr-side-locator");
    if (locDd) {
      locDd.innerHTML = `<a href="${escapeHtml(entry.network_locator)}" rel="noopener" title="${escapeHtml(entry.network_locator)}">${escapeHtml(locatorHost(entry.network_locator))} ↗</a>`;
    }
    setHref("fr-locator", entry.network_locator);
    setHref("fr-open-wb", `/workbench?vfr=${encodeURIComponent(entry.vfr_id)}`);

    const cmd = `vela registry pull ${entry.vfr_id} \\\n  --from ${hubUrl}/entries \\\n  --out ./pulled.json`;
    setText("fr-side-cmd", cmd);

    // Copy-pull-command button
    const copyBtn = document.getElementById("fr-copy-pull");
    copyBtn?.addEventListener("click", async () => {
      try {
        await navigator.clipboard.writeText(cmd);
        const original = copyBtn.textContent;
        copyBtn.textContent = "Copied ✓";
        setTimeout(() => { copyBtn.textContent = original; }, 1400);
      } catch {
        // ignore
      }
    });

    // Snapshots: filter all entries with same name+owner.
    const snapshots = allEntries
      .filter((e) => e.name === entry!.name && e.owner_actor_id === entry!.owner_actor_id)
      .sort((a, b) => (a.signed_publish_at < b.signed_publish_at ? 1 : -1));
    setText("fr-tab-snapshots", String(snapshots.length));
    setText("fr-side-sc", String(snapshots.length));

    const snapsHost = document.getElementById("fr-snaps");
    if (snapsHost) {
      snapsHost.innerHTML = snapshots.map((s) => {
        const isCurrent = s.vfr_id === entry!.vfr_id;
        const href = `/frontiers/view?vfr=${encodeURIComponent(s.vfr_id)}`;
        return `<div class="fs">
  <span class="fs__hash" title="${escapeHtml(s.latest_snapshot_hash)}">${escapeHtml(s.latest_snapshot_hash.slice(0, 24))}…</span>
  <span class="fs__sig">signed</span>
  <span class="fs__when">${escapeHtml(relativeTime(s.signed_publish_at))}</span>
  ${isCurrent ? `<span class="frc">current</span>` : `<a class="fs__open" href="${href}">open →</a>`}
</div>`;
      }).join("");
    }

    // Now fetch the actual frontier file. In local mode we already
    // have it from the synthesis step above; in hub mode we go to
    // entry.network_locator (a GitHub raw URL or similar).
    let frontier: FrontierFile | null = localFrontier;
    if (!frontier) {
      try {
        const r = await fetch(entry.network_locator);
        if (r.ok) frontier = (await r.json()) as FrontierFile;
      } catch {
        // ignore — frontier may be unreachable; the hub-side metadata is enough.
      }
    }

    if (!frontier) {
      setText("fr-desc", `Manifest signed and verified by the hub. The frontier file at ${locatorHost(entry.network_locator)} is currently unreachable; metadata above is from the signed manifest.`);
      setText("fr-side-desc", "Frontier file unreachable.");
      setText("fr-tab-findings", "—");
      setText("fr-tab-deps", "—");
      setText("fr-tab-actors", "—");
      const fHost = document.getElementById("fr-findings");
      if (fHost) fHost.innerHTML = `<div class="fr-empty">Frontier file at ${escapeHtml(locatorHost(entry.network_locator))} not reachable. Try the raw locator link, or pull with the CLI.</div>`;
      return;
    }

    // Description — prose from frontier.description.
    const desc = frontier.frontier?.description ?? "";
    if (desc) {
      const short = desc.length > 320 ? desc.slice(0, 320).trim() + "…" : desc;
      setText("fr-desc", short);
      setText("fr-side-desc", desc.length > 220 ? desc.slice(0, 220) + "…" : desc);
    } else {
      setText("fr-desc", "No description in frontier file.");
      setText("fr-side-desc", "—");
    }

    setText("fr-side-schema", frontier.schema ?? entry.schema);
    setText("fr-side-compiler", frontier.frontier?.compiler ?? "—");
    setText("fr-side-compiled",
      frontier.frontier?.compiled_at
        ? new Date(frontier.frontier.compiled_at).toISOString().slice(0, 10)
        : "—");

    const findings = frontier.findings ?? [];
    const events = frontier.events ?? [];
    const proposals = frontier.proposals ?? [];
    const actors = frontier.actors ?? [];
    const deps = frontier.frontier?.dependencies ?? [];

    setText("fr-tab-findings", String(findings.length));
    setText("fr-tab-inbox", String(proposals.filter((p) => p.status === "pending_review").length));
    setText("fr-tab-diff", String(events.length));
    setText("fr-tab-deps", String(deps.length));
    setText("fr-tab-actors", String(actors.length));
    setText("fr-side-fc", String(findings.length));
    setText("fr-side-ec", String(events.length));
    setText("fr-side-pc", String(proposals.length));

    renderInbox(proposals);
    renderDiff(events as StateEvent[]);

    // === Findings ===
    const findingsHost = document.getElementById("fr-findings");
    const searchInput = document.getElementById("fr-find-q") as HTMLInputElement | null;
    const countEl = document.getElementById("fr-find-count");

    function renderFindings(filterText: string) {
      const q = filterText.trim().toLowerCase();
      const filtered = q
        ? findings.filter((f) =>
            (f.id ?? "").toLowerCase().includes(q) ||
            findingClaim(f).toLowerCase().includes(q) ||
            findingKind(f).includes(q),
          )
        : findings;
      if (countEl) countEl.textContent = `${filtered.length} / ${findings.length}`;
      if (!findingsHost) return;
      if (filtered.length === 0) {
        findingsHost.innerHTML = `<div class="fr-empty">No findings match.</div>`;
        return;
      }
      findingsHost.innerHTML = filtered.map((f) => {
        const claim = escapeHtml(findingClaim(f));
        const id = escapeHtml(f.id ?? "");
        const kind = findingKind(f);
        const kindStyleMap: Record<string, string> = {
          retraction: "ff__kind--retraction",
          revision: "ff__kind--revision",
          annotation: "ff__kind--annotation",
          observation: "ff__kind--observation",
          therapeutic: "ff__kind--therapeutic",
          mechanistic: "ff__kind--mechanistic",
          methodological: "ff__kind--methodological",
          // v0.23 Notes Compiler types
          open_question: "ff__kind--open_question",
          hypothesis: "ff__kind--hypothesis",
          candidate_finding: "ff__kind--candidate_finding",
          tension: "ff__kind--tension",
          // v0.28.x Contradiction Finder — distinct from notes
          // tension; same chip color, different label.
          cross_finding_tension: "ff__kind--cross_finding_tension",
          // v0.24 Code & Notebook Analyst types
          analysis_run: "ff__kind--analysis_run",
          code_derived: "ff__kind--code_derived",
          experiment_intent: "ff__kind--experiment_intent",
          // v0.25 Datasets types
          dataset_summary: "ff__kind--dataset_summary",
          dataset_supported_claim: "ff__kind--dataset_supported_claim",
        };
        const kindClass = kindStyleMap[kind] ?? "ff__kind--unknown";
        const ev = f.evidence?.length ?? 0;
        const links = f.links?.length ?? 0;
        const conds = f.conditions?.length ?? 0;
        const author = f.provenance?.authors?.[0]?.id ?? "—";
        const when = relativeTime(f.updated ?? f.created);
        const href = `/workbench/finding?id=${encodeURIComponent(f.id ?? "")}&vfr=${encodeURIComponent(entry!.vfr_id)}`;
        return `<a class="ff" href="${href}">
  <div class="ff__main">
    <div class="ff__claim">${claim}</div>
    <div class="ff__sub">
      <span><strong>${id}</strong></span>
      <span>${ev} evidence</span>
      <span>${links} links</span>
      <span>${conds} conditions</span>
      <span>${escapeHtml(author)}</span>
    </div>
  </div>
  <div class="ff__meta">
    <span class="ff__kind ${kindClass}">${escapeHtml(kind)}</span>
    <div style="margin-top: 6px;">${escapeHtml(when)}</div>
  </div>
</a>`;
      }).join("");
    }
    renderFindings("");
    searchInput?.addEventListener("input", () => renderFindings(searchInput.value));

    // === Cross-frontier deps ===
    const depsHost = document.getElementById("fr-deps");
    if (depsHost) {
      const cross = deps.filter((d) => d.vfr_id);
      if (cross.length === 0) {
        depsHost.innerHTML = `<div class="fr-empty">This frontier declares no cross-frontier dependencies. Findings here stand on their own.</div>`;
      } else {
        depsHost.innerHTML = cross.map((d) => {
          const href = d.vfr_id ? `/frontiers/view?vfr=${encodeURIComponent(d.vfr_id)}` : "#";
          return `<a class="fd" href="${href}">
  <span class="fd__name">${escapeHtml(d.name ?? d.vfr_id ?? "—")}</span>
  <span class="fd__sub">
    ${escapeHtml(d.vfr_id ?? "")} · pinned ${escapeHtml((d.pinned_snapshot_hash ?? "").slice(0, 18))}…
    · locator ${escapeHtml(locatorHost(d.locator))}
  </span>
</a>`;
        }).join("");
      }
    }

    // === Actors ===
    const actorsHost = document.getElementById("fr-actors");
    if (actorsHost) {
      if (actors.length === 0) {
        actorsHost.innerHTML = `<div class="fr-empty">No actors registered in the frontier.</div>`;
      } else {
        actorsHost.innerHTML = actors.map((a) => {
          return `<div class="fa">
  <span class="fa__handle">${escapeHtml(a.id)}</span>
  <span class="fa__pubkey" title="${escapeHtml(a.pubkey ?? "")}">${escapeHtml(shortHash(a.pubkey ?? "", 28))}</span>
  ${a.tier ? `<span class="fa__tier">${escapeHtml(a.tier)}</span>` : ""}
</div>`;
        }).join("");
      }
    }

    // === About ===
    const aboutHost = document.getElementById("fr-about");
    if (aboutHost) {
      aboutHost.innerHTML = `
<p>${escapeHtml(desc || "(no description)")}</p>
<p style="font-family:var(--font-mono); font-size:13px; color:var(--ink-2);">
  Compiled with <strong>${escapeHtml(frontier.frontier?.compiler ?? "—")}</strong>
  on ${escapeHtml(frontier.frontier?.compiled_at ?? "—")}.
  Schema <code>${escapeHtml(frontier.schema ?? "—")}</code>.
  Vela <code>${escapeHtml(frontier.vela_version ?? "—")}</code>.
</p>
<p>To pull this frontier and verify it locally:</p>
<pre>${escapeHtml(cmd)}</pre>
<p style="font-family:var(--font-serif); font-size:14px; color:var(--ink-2);">
  The pull verifies the manifest signature, fetches the frontier from its
  locator, and re-hashes both the snapshot and the event log. Any mismatch
  rejects.
</p>`;
    }
  })();
</script>
