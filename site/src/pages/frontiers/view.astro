  /* Empty-state placeholder is also injected at runtime. */
  :global(.fr-empty) {
    padding: 32px 8px;
    text-align: center;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--ink-3);
  }

  /* Guided empty state — for first-time visitors. Tells them
     what this surface is FOR, not just that it's empty. The
     terminal block is the actual command they run; the doctrine
     line is the thing that distinguishes Vela from "an AI tool". */
  :global(.fr-empty--guided) {
    text-align: left;
    padding: 28px 24px 24px;
    border: 1px solid var(--rule-2);
    background: var(--paper-1);
    border-radius: var(--radius-1);
