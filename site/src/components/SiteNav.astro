---
/*
  Vela masthead — adopted from Borrowed Light's SiteNav pattern.

    LEFT:  VELA wordmark in mono small caps, letter-spaced.
           Links to /. Anchors the publication.
    RIGHT: small nav line — docs · workbench · honest · github · hub
           plus the version badge. No dropdowns, no decoration.

  Hairline gold rule beneath separates the masthead from the page
  body. Vela is multi-page so the nav is real (BL's single-essay
  context warranted no nav at all). Skipped the BL reading-light
  toggle — Vela isn't reading-time sensitive and the toggle would
  read as decoration.
*/

import { REPO_URL, HUB_URL, VERSION } from "../config";

interface Props {
  active?: string;  // 'docs' | 'workbench' | 'honest' | 'github' | 'hub' | 'home' (or any custom value)
}

const { active = "home" } = Astro.props;
---

<header class="vl-mast">
  <div class="vl-mast-inner">
    <a href="/" class="vl-brand" aria-label="vela · home">
      <!-- Sailboat-and-star mark from the brand toolkit. Navy sail with
           gold four-point star at the peak. Sits left of the wordmark. -->
      <svg class="vl-brand__glyph" viewBox="0 0 24 28" aria-hidden="true" focusable="false">
        <path d="M12 4 L12 22 L4 22 Z" fill="currentColor" opacity="0.92" />
        <path d="M12 6 L12 22 L20 22 Z" fill="currentColor" opacity="0.5" />
        <line x1="2" y1="22.5" x2="22" y2="22.5" stroke="currentColor" stroke-width="0.6" opacity="0.32" />
        <path class="vl-brand__star" d="M16 4 L16.6 5.6 L18.2 6 L16.6 6.4 L16 8 L15.4 6.4 L13.8 6 L15.4 5.6 Z" />
      </svg>
      <span class="vl-brand__wordmark">vela</span>
    </a>

    <nav class="vl-nav" aria-label="Site navigation">
      <a href="/docs" class={`vl-nav__link${active === "docs" ? " vl-nav__link--active" : ""}`}>docs</a>
      <span class="vl-nav__sep" aria-hidden="true">·</span>
      <a href="/spec" class={`vl-nav__link${active === "spec" ? " vl-nav__link--active" : ""}`}>spec</a>
      <span class="vl-nav__sep" aria-hidden="true">·</span>
      <a href="/examples" class={`vl-nav__link${active === "examples" ? " vl-nav__link--active" : ""}`}>examples</a>
      <span class="vl-nav__sep" aria-hidden="true">·</span>
      <a href="/workbench" class={`vl-nav__link${active === "workbench" ? " vl-nav__link--active" : ""}`}>workbench</a>
      <span class="vl-nav__sep" aria-hidden="true">·</span>
      <a href="/governance" class={`vl-nav__link${active === "governance" ? " vl-nav__link--active" : ""}`}>governance</a>
      <span class="vl-nav__sep" aria-hidden="true">·</span>
      <a href={REPO_URL} class="vl-nav__link" rel="noopener">github</a>
    </nav>
  </div>

  <span class="vl-mast-rule" aria-hidden="true"></span>
</header>

<style>
  .vl-mast {
    position: relative;
    z-index: 50;
    background: transparent;
  }

  .vl-mast-inner {
    max-width: calc(var(--measure-page) + (var(--container-px) * 2));
    margin: 0 auto;
    padding: 1.4rem var(--container-px) 1.3rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  /* Sailboat glyph + Fraunces "vela" wordmark, per brand toolkit. */
  .vl-brand {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    text-decoration: none;
    color: var(--ink-0);
    transition: color 200ms var(--ease);
  }
  .vl-brand:hover { color: var(--gold-ink); }
  .vl-brand__glyph {
    color: var(--ink-0);
    width: 22px;
    height: auto;
    flex-shrink: 0;
    transition: color 200ms var(--ease);
  }
  .vl-brand__star {
    fill: var(--gold);
    filter: drop-shadow(0 0 2px var(--gold-glow));
  }
  .vl-brand:hover .vl-brand__glyph { color: var(--gold-ink); }

  .vl-brand__wordmark {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 1.05rem;
    letter-spacing: -0.018em;
    color: inherit;
    line-height: 1;
    text-transform: lowercase;
  }

  /* Nav line — quiet mono, gold on hover and active. */
  .vl-nav {
    display: inline-flex;
    align-items: baseline;
    gap: 0.6rem;
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.06em;
    color: var(--ink-3);
  }
  .vl-nav__link {
    color: inherit;
    text-decoration: none;
    transition: color 200ms var(--ease);
    text-transform: lowercase;
  }
  .vl-nav__link:hover { color: var(--gold-ink); }
  .vl-nav__link--active {
    color: var(--gold-ink);
    border-bottom: 1px solid color-mix(in oklab, var(--gold) 56%, transparent);
    padding-bottom: 1px;
  }
  .vl-nav__sep { color: var(--ink-4); }
  .vl-nav__version {
    margin-left: 0.5rem;
    color: var(--ink-4);
    letter-spacing: 0.04em;
  }

  /* Hairline gold rule beneath — same register as section headings.
     Width matches the masthead container so the seam aligns with content. */
  .vl-mast-rule {
    display: block;
    height: 1px;
    margin: 0 auto;
    max-width: calc(var(--measure-page) + (var(--container-px) * 2));
    background: linear-gradient(
      to right,
      transparent 0%,
      color-mix(in oklab, var(--gold) 32%, transparent) 18%,
      color-mix(in oklab, var(--gold) 28%, transparent) 82%,
      transparent 100%
    );
  }

  /* Mobile */
  @media (max-width: 720px) {
    .vl-mast-inner {
      padding: 1rem var(--container-px) 0.9rem;
      gap: 1rem;
      flex-wrap: wrap;
    }
    .vl-brand__wordmark {
      font-size: 0.64rem;
      letter-spacing: 0.26em;
    }
    .vl-nav {
      font-size: 0.6rem;
      gap: 0.4rem;
      flex-wrap: wrap;
    }
    .vl-nav__version { display: none; }
  }
</style>
