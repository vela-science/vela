---
import Reading from "../layouts/Reading.astro";
import ClaimCard from "../components/ClaimCard.astro";
import HeroConstellation from "../components/HeroConstellation.astro";
import {
  loadFrontier,
  frontierStats,
  contradictions,
  type ClaimView,
} from "../lib/frontier";
import { FRONTIER, REPO_URL, HUB_URL, VERSION } from "../config";

const claims = loadFrontier();
const stats = frontierStats();
const tensionList = contradictions();

const featured: ClaimView[] = claims
  .slice()
  .sort((a, b) => b.finding.confidence.score - a.finding.confidence.score)
  .slice(0, 9);

const constellationClaims = claims
  .slice()
  .sort((a, b) => b.finding.confidence.score - a.finding.confidence.score)
  .slice(0, 24);

const lastUpdated = stats.lastUpdated
  ? new Date(stats.lastUpdated).toISOString().slice(0, 10)
  : "—";
---

<Reading
  title="Vela · open protocol for scientific findings"
  description="An open protocol where scientific findings, evidence, and corrections are first-class, signed, content-addressed objects."
  active="home"
  wide
>
  <!-- Hero -->
  <header class="vh-hero">
    <div class="vh-hero__mark" aria-hidden="true">
      <svg viewBox="0 0 64 24" width="64" height="24" fill="none" stroke="currentColor" stroke-width="0.7">
        <circle cx="6" cy="12" r="1.4" fill="currentColor" />
        <circle cx="20" cy="6" r="1.1" fill="currentColor" />
        <circle cx="32" cy="14" r="1.6" fill="currentColor" />
        <circle cx="46" cy="9" r="1.2" fill="currentColor" />
        <circle cx="58" cy="17" r="1.3" fill="currentColor" />
        <path d="M6 12 L20 6 L32 14 L46 9 L58 17" opacity="0.5" />
      </svg>
      <span class="vh-hero__mark-label">Vela · v{VERSION}</span>
    </div>
    <h1 class="vh-hero__title">An open protocol for scientific findings.</h1>
    <p class="vh-hero__sub">
      When a finding weakens, the trials and target hypotheses that depended on it know —
      automatically. Findings, evidence, and corrections as signed, content-addressed events
      that propagate through a dependency graph.
    </p>
    <p class="vh-hero__byline">
      Built by <a href="/lineage" class="vh-hero__byline-link">Will Blair</a>, in the
      open at <a href="https://github.com/vela-science/vela" rel="noopener" class="vh-hero__byline-link">github.com/vela-science/vela</a>.
    </p>

    <div class="vh-hero__ctas">
      <a class="vh-btn vh-btn--primary" href="/protocol">
        Read the protocol <span aria-hidden="true">→</span>
      </a>
      <a class="vh-btn vh-btn--secondary" href="/workbench">
        Open the workbench <span aria-hidden="true">→</span>
      </a>
    </div>

    <div class="vh-try">
      <div class="vh-try__head">
        <span class="vh-try__tag">try it · 30s · no install</span>
        <a class="vh-try__src" href="/try">view source</a>
      </div>
      <pre class="vh-code"><code><span class="vh-ps">$</span> <span class="vh-cmd">curl</span> <span class="vh-flag">-sSL</span> https://vela.science/try | <span class="vh-cmd">bash</span></code></pre>
      <p class="vh-try__note">
        Downloads a real signed proof packet plus a stdlib-only Python verifier and recomputes
        every file's SHA-256 against the manifest. Runs locally, exits non-zero on any mismatch.
      </p>
    </div>

    <dl class="vh-stats">
      <div class="vh-stat">
        <dt>{stats.claims}</dt>
        <dd>findings on the live frontier</dd>
      </div>
      <div class="vh-stat">
        <dt>3</dt>
        <dd>reducer implementations</dd>
      </div>
      <div class="vh-stat">
        <dt>35/35</dt>
        <dd>files verified byte-identical</dd>
      </div>
      <div class="vh-stat">
        <dt>{lastUpdated}</dt>
        <dd>last signed</dd>
      </div>
    </dl>
  </header>

  <!-- Live frontier -->
  <section class="vh-section" aria-label="Live frontier">
    <div class="vh-section__head">
      <p class="vh-section__eyebrow">Live frontier · {FRONTIER.name}</p>
      <h2 class="vh-section__title">{FRONTIER.name}, mapped.</h2>
      <p class="vh-section__sub">
        {stats.claims} signed findings, {stats.papers} papers, {stats.contradictions} open contradictions.
        Hover any star to read its claim.
      </p>
    </div>

    <figure class="vh-constellation">
      <HeroConstellation claims={constellationClaims} />
      <figcaption class="vh-constellation__cap" data-hero-tip>
        {constellationClaims.length} top-confidence claims. Click any node to read the evidence.
      </figcaption>
    </figure>

    <div class="vh-section__head" style="margin-top: 2.4rem;">
      <h2 class="vh-section__title vh-section__title--small">Strongest claims, by confidence.</h2>
    </div>

    <div class="vh-grid">
      {featured.map((c) => <ClaimCard claim={c} />)}
    </div>

    <div class="vh-section__foot">
      <a class="vh-link" href="/workbench">Open the workbench →</a>
      {tensionList.length > 0 && (
        <a class="vh-link" href="/workbench?contested=1">
          {tensionList.length} open contradictions →
        </a>
      )}
      <a class="vh-link" href="/honest">What isn't true yet →</a>
      <a class="vh-link" href="/quickstart">Deposit your first finding →</a>
    </div>
  </section>

  <!-- Build on this -->
  <section class="vh-section" aria-label="Build on this">
    <div class="vh-section__head">
      <p class="vh-section__eyebrow">Build on this</p>
      <h2 class="vh-section__title">One binary. One open hub. Query it now.</h2>
      <p class="vh-section__sub">
        Compile a frontier from a folder of papers, or pull signed manifests from the live hub.
      </p>
    </div>

    <div class="vh-build">
      <div class="vh-build__pane">
        <div class="vh-build__pane-head">
          <span class="vh-build__pane-tag">$ run locally</span>
          <span class="vh-build__pane-aside">~60 seconds</span>
        </div>
        <pre class="vh-code vh-code--block"><code><span class="vh-ps">$</span> <span class="vh-cmd">git clone</span> {REPO_URL}
<span class="vh-ps">$</span> <span class="vh-cmd">cd</span> vela <span class="vh-ps">&&</span> <span class="vh-cmd">cargo build</span> <span class="vh-flag">--release</span>
<span class="vh-ps">$</span> ./target/release/vela <span class="vh-cmd">frontier compile</span> ./papers
<span class="vh-ps">$</span> ./target/release/vela <span class="vh-cmd">serve --workbench</span></code></pre>
      </div>
      <div class="vh-build__pane">
        <div class="vh-build__pane-head">
          <span class="vh-build__pane-tag">$ query the live hub</span>
          <span class="vh-build__pane-aside">no auth · CORS open</span>
        </div>
        <pre class="vh-code vh-code--block"><code><span class="vh-ps">$</span> <span class="vh-cmd">curl</span> {HUB_URL}/entries \
    <span class="vh-flag">-H</span> <span class="vh-str">"accept: application/json"</span>
{`
# {"entries":[
#   {"vfr_id":"vfr_bd91…",
#    "name":"Alzheimer's Therapeutics",
#    "owner_actor_id":"reviewer:will-blair",
#    "snapshot_hash":"f23b4aba17…"}, …]}`}</code></pre>
      </div>
    </div>
  </section>

  <script>
    (function () {
      var tip = document.querySelector("[data-hero-tip]");
      var nodes = document.querySelectorAll(".hc-node");
      if (!tip || nodes.length === 0) return;
      var original = tip.innerHTML;
      nodes.forEach(function (n) {
        var write = function () {
          var claim = n.getAttribute("data-claim") || "";
          tip.innerHTML = '<span class="vh-constellation__quote">' + claim + "</span>";
        };
        var reset = function () { tip.innerHTML = original; };
        n.addEventListener("mouseenter", write);
        n.addEventListener("mouseleave", reset);
        n.addEventListener("focus", write);
        n.addEventListener("blur", reset);
      });
    })();
  </script>

  <!-- Site directory -->
  <nav class="vh-directory" aria-label="Site directory">
    <div class="vh-directory__col">
      <p class="vh-directory__head">Read</p>
      <a class="vh-directory__link" href="https://borrowedlight.org" rel="noopener">The essay</a>
      <a class="vh-directory__link" href="/protocol">The protocol</a>
      <a class="vh-directory__link" href="/spec">Protocol specification</a>
      <a class="vh-directory__link" href="/protocol/agents">Agent integration</a>
    </div>
    <div class="vh-directory__col">
      <p class="vh-directory__head">Try</p>
      <a class="vh-directory__link" href="/quickstart">Five-minute quickstart</a>
      <a class="vh-directory__link" href="/sdk">SDK reference</a>
      <a class="vh-directory__link" href="/workbench">The workbench</a>
      <a class="vh-directory__link" href="/try">The 30-second proof</a>
    </div>
    <div class="vh-directory__col">
      <p class="vh-directory__head">Verify</p>
      <a class="vh-directory__link" href="/proof/pericyte-correction">A worked Correction</a>
      <a class="vh-directory__link" href="/proof/contradiction">A worked contradiction</a>
      <a class="vh-directory__link" href="/proof/packet">The signed proof packet</a>
      <a class="vh-directory__link" href="/honest">What isn't true yet</a>
    </div>
    <div class="vh-directory__col">
      <p class="vh-directory__head">Questions</p>
      <a class="vh-directory__link" href="/faq">Frequently questioned answers</a>
      <a class="vh-directory__link" href="/replay">Replay an event log</a>
      <a class="vh-directory__link" href="/lineage">Why this exists</a>
      <a class="vh-directory__link" href={REPO_URL} rel="noopener">Source on GitHub</a>
    </div>
  </nav>

  <!-- Imprint footer -->
  <footer class="vh-imprint" role="contentinfo">
    <p class="vh-imprint__lines">
      <a href="/lineage" class="vh-link">Why this exists, named once →</a>
      <span class="vh-imprint__sep" aria-hidden="true">·</span>
      <a href="https://borrowedlight.org" rel="noopener" class="vh-link">Borrowed Light, the essay →</a>
    </p>
    <p class="vh-imprint__mark">for M.</p>
  </footer>
</Reading>

<style>
  /* ── Hero ─────────────────────────────────────────────────────── */
  .vh-hero {
    max-width: 64rem;
  }
  .vh-hero__mark {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    color: color-mix(in oklab, var(--gold) 78%, var(--ink-2));
    margin: 0 0 1.6rem;
  }
  .vh-hero__mark svg { display: block; }
  .vh-hero__mark-label {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }
  .vh-hero__title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(2.6rem, 6vw, 4.4rem);
    line-height: 1.02;
    letter-spacing: -0.02em;
    color: var(--ink-0);
    margin: 0 0 1.5rem;
    text-wrap: balance;
    max-width: 18ch;
    font-variation-settings: "opsz" 144, "SOFT" 30;
  }
  .vh-hero__sub {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: clamp(1.05rem, 1.5vw, 1.2rem);
    line-height: 1.55;
    letter-spacing: -0.005em;
    color: var(--ink-2);
    margin: 0 0 1rem;
    max-width: 54ch;
    text-wrap: pretty;
  }
  .vh-hero__byline {
    margin: 0 0 2rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    color: var(--ink-3);
  }
  .vh-hero__byline-link {
    color: var(--ink-2);
    text-decoration: none;
    border-bottom: 1px solid color-mix(in oklab, var(--gold) 38%, transparent);
    padding-bottom: 1px;
    transition: color 160ms var(--ease), border-bottom-color 160ms var(--ease);
  }
  .vh-hero__byline-link:hover {
    color: var(--gold);
    border-bottom-color: var(--gold);
  }

  .vh-hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 2.4rem;
  }
  .vh-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 22px;
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.95rem;
    letter-spacing: -0.005em;
    text-decoration: none;
    border-radius: 8px;
    transition:
      background 160ms var(--ease),
      color 160ms var(--ease),
      border-color 160ms var(--ease),
      transform 160ms var(--ease);
  }
  .vh-btn--primary {
    background: var(--ink-0);
    color: var(--paper-0);
    border: 1px solid var(--ink-0);
  }
  .vh-btn--primary:hover {
    background: var(--ink-1);
    transform: translateY(-1px);
  }
  .vh-btn--secondary {
    background: transparent;
    color: var(--ink-1);
    border: 1px solid color-mix(in oklab, var(--ink-1) 28%, transparent);
  }
  .vh-btn--secondary:hover {
    border-color: var(--ink-1);
    background: var(--paper-1);
    transform: translateY(-1px);
  }
  .vh-btn span { transition: transform 160ms var(--ease); }
  .vh-btn:hover span { transform: translateX(2px); }

  /* Try-it block */
  .vh-try {
    background: var(--paper-1);
    border: 1px solid var(--rule-2);
    border-radius: 10px;
    margin-bottom: 2rem;
    overflow: hidden;
  }
  .vh-try__head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px 18px;
    border-bottom: 1px solid var(--rule-1);
    background: color-mix(in oklab, var(--paper-2) 35%, var(--paper-1));
  }
  .vh-try__tag {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: color-mix(in oklab, var(--gold) 76%, var(--ink-2));
  }
  .vh-try__src {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--ink-3);
    text-decoration: none;
    transition: color 160ms var(--ease);
  }
  .vh-try__src:hover { color: var(--gold); }

  .vh-code {
    margin: 0;
    padding: 14px 18px;
    font-family: var(--font-mono);
    font-size: 0.88rem;
    line-height: 1.6;
    color: var(--ink-1);
    background: transparent;
    overflow-x: auto;
    white-space: pre;
  }
  .vh-code code { background: transparent; border: 0; padding: 0; font: inherit; color: inherit; }
  .vh-ps { color: color-mix(in oklab, var(--gold) 60%, var(--ink-3)); }
  .vh-cmd { color: var(--ink-0); font-weight: 500; }
  .vh-flag { color: var(--ink-2); }
  .vh-str { color: color-mix(in oklab, var(--moss) 70%, var(--ink-1)); }

  .vh-try__note {
    margin: 0;
    padding: 0 18px 14px;
    font-family: var(--font-sans);
    font-size: 0.9rem;
    line-height: 1.5;
    color: var(--ink-3);
    text-wrap: pretty;
    max-width: 72ch;
  }

  /* Stats row */
  .vh-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    margin: 0;
    padding: 0;
    border-top: 1px solid var(--rule-2);
    border-bottom: 1px solid var(--rule-2);
  }
  .vh-stat {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 1.1rem 0 1rem;
    border-right: 1px solid var(--rule-1);
  }
  .vh-stat:first-child { padding-left: 0; }
  .vh-stat:not(:first-child) { padding-left: 1.4rem; }
  .vh-stat:last-child { border-right: 0; }
  .vh-stat dt {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 1.5rem;
    line-height: 1;
    color: var(--ink-0);
    letter-spacing: -0.02em;
    font-variant-numeric: tabular-nums;
    margin: 0;
  }
  .vh-stat dd {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-3);
    margin: 0;
  }

  /* ── Section frame ───────────────────────────────────────────── */
  .vh-section {
    max-width: 76rem;
  }
  .vh-section__head { margin-bottom: 2.2rem; max-width: 64rem; }
  .vh-section__eyebrow {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: color-mix(in oklab, var(--gold) 78%, var(--ink-2));
    margin: 0 0 0.85rem;
  }
  .vh-section__title {
    font-family: var(--font-display);
    font-weight: 450;
    font-size: clamp(1.9rem, 3.6vw, 2.8rem);
    line-height: 1.06;
    letter-spacing: -0.018em;
    color: var(--ink-0);
    margin: 0 0 0.9rem;
    text-wrap: balance;
    max-width: 22ch;
    font-variation-settings: "opsz" 144, "SOFT" 30;
  }
  .vh-section__title--small {
    font-size: clamp(1.4rem, 2.4vw, 1.8rem);
    margin: 0;
  }
  .vh-section__sub {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 1.02rem;
    line-height: 1.5;
    color: var(--ink-2);
    margin: 0;
    max-width: 56ch;
    text-wrap: pretty;
  }
  .vh-section__foot {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 1.6rem;
    margin-top: 1.8rem;
    padding-top: 1.4rem;
    border-top: 1px solid var(--rule-1);
  }
  .vh-link {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.92rem;
    color: var(--ink-1);
    text-decoration: none;
    border-bottom: 1px solid color-mix(in oklab, var(--gold) 48%, transparent);
    padding-bottom: 1px;
    transition: color 160ms var(--ease), border-bottom-color 160ms var(--ease);
  }
  .vh-link:hover {
    color: var(--gold);
    border-bottom-color: var(--gold);
  }

  /* ── Constellation figure — twilight substrate so stars actually
     read. Per brand boards, constellation viz sits on a deeper warm
     ground that lets gold + ink dots glow. Light-mode-friendly using
     a deeper sand + warm navy hint. */
  .vh-constellation {
    margin: 0 0 1.6rem;
    background:
      radial-gradient(
        ellipse at 50% 35%,
        color-mix(in oklab, var(--paper-2) 75%, var(--gold)) 0%,
        color-mix(in oklab, var(--paper-2) 95%, var(--ink-2)) 60%,
        color-mix(in oklab, var(--paper-2) 88%, var(--ink-1)) 100%
      );
    border: 1px solid color-mix(in oklab, var(--gold) 28%, var(--rule-3));
    border-radius: 12px;
    overflow: hidden;
    box-shadow: inset 0 1px 0 color-mix(in oklab, var(--gold) 18%, transparent), 0 2px 12px rgba(8, 19, 32, 0.06);
  }
  .vh-constellation :global(.hc) {
    background: transparent !important;
    max-height: 420px !important;
  }
  .vh-constellation :global(.hc-dot) {
    stroke: color-mix(in oklab, var(--ink-0) 55%, transparent) !important;
    stroke-width: 0.8 !important;
    filter: drop-shadow(0 0 2px var(--gold-glow));
  }
  .vh-constellation :global(.hc-ring) {
    stroke: color-mix(in oklab, var(--gold) 38%, transparent) !important;
  }
  .vh-constellation :global(.hc-core) {
    filter: drop-shadow(0 0 8px var(--gold)) !important;
  }
  .vh-constellation__cap {
    margin: 0;
    padding: 14px 20px;
    border-top: 1px solid color-mix(in oklab, var(--gold) 22%, transparent);
    background: color-mix(in oklab, var(--paper-2) 60%, var(--paper-1));
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    color: var(--ink-3);
    text-wrap: pretty;
    min-height: 1.4em;
  }
  .vh-constellation__quote {
    font-family: var(--font-display);
    font-size: 1.02rem;
    color: var(--ink-0);
    letter-spacing: 0;
    text-transform: none;
    font-weight: 400;
  }

  /* ── Claims grid ─────────────────────────────────────────────── */
  .vh-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
  }
  @media (max-width: 980px) {
    .vh-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 640px) {
    .vh-grid { grid-template-columns: 1fr; }
  }

  /* ── Build panes ─────────────────────────────────────────────── */
  .vh-build {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
  }
  @media (max-width: 980px) {
    .vh-build { grid-template-columns: 1fr; }
  }
  .vh-build__pane {
    background: var(--paper-1);
    border: 1px solid var(--rule-2);
    border-radius: 10px;
    overflow: hidden;
  }
  .vh-build__pane-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px 18px;
    border-bottom: 1px solid var(--rule-1);
    background: color-mix(in oklab, var(--paper-2) 35%, var(--paper-1));
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }
  .vh-build__pane-tag {
    color: color-mix(in oklab, var(--gold) 76%, var(--ink-2));
    font-weight: 500;
  }
  .vh-build__pane-aside { color: var(--ink-3); }
  .vh-code--block {
    padding: 16px 18px 18px;
    font-size: 0.82rem;
    line-height: 1.65;
  }

  /* ── Site directory — four-column footer of every page ────────── */
  .vh-directory {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    padding-top: 2.4rem;
    padding-bottom: 1.6rem;
    border-top: 1px solid var(--rule-2);
  }
  @media (max-width: 880px) {
    .vh-directory { grid-template-columns: repeat(2, 1fr); gap: 1.6rem 1.2rem; }
  }
  @media (max-width: 480px) {
    .vh-directory { grid-template-columns: 1fr; }
  }
  .vh-directory__col { display: flex; flex-direction: column; gap: 0.5rem; }
  .vh-directory__head {
    margin: 0 0 0.4rem;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
