---
import { getEntry, render } from "astro:content";
import Essay from "../../layouts/Essay.astro";

const entry = await getEntry("essays", "science-needs-state");
if (!entry) throw new Error("essay not found");

const { Content } = await render(entry);
---
<Essay
  title="Science Needs State"
  description="The substrate science is missing — and the smallest thing that actually composes."
  pubDate="2026-04-25"
>
  <Content />
</Essay>
