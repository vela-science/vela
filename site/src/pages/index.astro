---
import Reading from "../layouts/Reading.astro";
import ClaimCard from "../components/ClaimCard.astro";
import {
  loadFrontier,
  frontierStats,
  contradictions,
  type ClaimView,
} from "../lib/frontier";
import { FRONTIER, REPO_URL, HUB_URL, VERSION } from "../config";

const claims = loadFrontier();
const stats = frontierStats();
const tensionList = contradictions();

const featured: ClaimView[] = claims
  .slice()
  .sort((a, b) => b.finding.confidence.score - a.finding.confidence.score)
  .slice(0, 9);

const lastUpdated = stats.lastUpdated
  ? new Date(stats.lastUpdated).toISOString().slice(0, 10)
  : "—";
---

<Reading
  title="Vela · open protocol for scientific findings"
  description="An open protocol where scientific findings, evidence, and corrections are first-class, signed, content-addressed objects."
  active="home"
  wide
>
  <!-- Hero — proof first, prose second. -->
  <header class="vh-hero">
    <p class="vh-hero__eyebrow">vela {VERSION} · open protocol for scientific findings</p>

    <div class="vh-try">
      <div class="vh-try__head">
        <span class="vh-try__tag">try it · 30s · no install</span>
        <a class="vh-try__src" href="/try">view source</a>
      </div>
      <pre class="vh-code"><code><span class="vh-ps">$</span> <span class="vh-cmd">curl</span> <span class="vh-flag">-sSL</span> https://vela.science/try | <span class="vh-cmd">bash</span></code></pre>
      <p class="vh-try__note">
        Downloads a real signed proof packet, a stdlib-only Python verifier, and recomputes
        every file's SHA-256 against the manifest. Exits non-zero on any mismatch.
      </p>
    </div>

    <dl class="vh-stats">
      <div class="vh-stat">
        <dt>{stats.claims}</dt>
        <dd>findings on the live frontier</dd>
      </div>
      <div class="vh-stat">
        <dt>3</dt>
        <dd>reducer impls byte-identical</dd>
      </div>
      <div class="vh-stat">
        <dt>35/35</dt>
        <dd>files verified</dd>
      </div>
      <div class="vh-stat">
        <dt>{lastUpdated}</dt>
        <dd>last signed</dd>
      </div>
    </dl>

    <h1 class="vh-hero__title">Findings, signed. Corrections, addressable. State, replayable.</h1>
    <p class="vh-hero__sub">
      Findings, evidence, and corrections as content-addressed signed events. When a finding
      weakens, the trials and downstream claims that depended on it know — through the
      dependency graph, not by rumor.
    </p>

    <div class="vh-hero__ctas">
      <a class="vh-btn vh-btn--primary" href="/quickstart">
        Quickstart <span aria-hidden="true">→</span>
      </a>
      <a class="vh-btn vh-btn--secondary" href="/spec">
        Read the spec <span aria-hidden="true">→</span>
      </a>
      <a class="vh-btn vh-btn--secondary" href="/workbench">
        Open workbench <span aria-hidden="true">→</span>
      </a>
    </div>
  </header>

  <!-- Live frontier — claim cards, no decorative viz. -->
  <section class="vh-section" aria-label="Live frontier">
    <div class="vh-section__head">
      <p class="vh-section__eyebrow">Live frontier · {FRONTIER.name}</p>
      <h2 class="vh-section__title">Strongest claims, by confidence.</h2>
      <p class="vh-section__sub">
        {stats.claims} signed findings, {stats.papers} papers, {stats.contradictions} open
        contradictions. Each card is content-addressed; click to read the evidence chain.
      </p>
    </div>

    <div class="vh-grid">
      {featured.map((c) => <ClaimCard claim={c} />)}
    </div>

    <div class="vh-section__foot">
      <a class="vh-link" href="/workbench">Open the workbench →</a>
      {tensionList.length > 0 && (
        <a class="vh-link" href="/workbench?contested=1">
          {tensionList.length} open contradictions →
        </a>
      )}
      <a class="vh-link" href="/quickstart">Deposit your first finding →</a>
    </div>
  </section>

  <!-- Build on this -->
  <section class="vh-section" aria-label="Build on this">
    <div class="vh-section__head">
      <p class="vh-section__eyebrow">Build on this</p>
      <h2 class="vh-section__title">One binary. One open hub. Query it now.</h2>
      <p class="vh-section__sub">
        Compile a frontier from a folder of papers, or pull signed manifests from the live hub.
      </p>
    </div>

    <div class="vh-build">
      <div class="vh-build__pane">
        <div class="vh-build__pane-head">
          <span class="vh-build__pane-tag">$ run locally</span>
          <span class="vh-build__pane-aside">~60 seconds</span>
        </div>
        <pre class="vh-code vh-code--block"><code><span class="vh-ps">$</span> <span class="vh-cmd">git clone</span> {REPO_URL}
<span class="vh-ps">$</span> <span class="vh-cmd">cd</span> vela <span class="vh-ps">&&</span> <span class="vh-cmd">cargo build</span> <span class="vh-flag">--release</span>
<span class="vh-ps">$</span> ./target/release/vela <span class="vh-cmd">frontier compile</span> ./papers
<span class="vh-ps">$</span> ./target/release/vela <span class="vh-cmd">serve --workbench</span></code></pre>
      </div>
      <div class="vh-build__pane">
        <div class="vh-build__pane-head">
          <span class="vh-build__pane-tag">$ query the live hub</span>
          <span class="vh-build__pane-aside">no auth · CORS open</span>
        </div>
        <pre class="vh-code vh-code--block"><code><span class="vh-ps">$</span> <span class="vh-cmd">curl</span> {HUB_URL}/entries \
    <span class="vh-flag">-H</span> <span class="vh-str">"accept: application/json"</span>
{`
# {"entries":[
#   {"vfr_id":"vfr_bd91…",
#    "name":"Alzheimer's Therapeutics",
#    "owner_actor_id":"reviewer:will-blair",
#    "snapshot_hash":"f23b4aba17…"}, …]}`}</code></pre>
      </div>
    </div>
  </section>

  <!-- Site directory -->
  <nav class="vh-directory" aria-label="Site directory">
    <div class="vh-directory__col">
      <p class="vh-directory__head">Read</p>
      <a class="vh-directory__link" href="/spec">Protocol spec</a>
      <a class="vh-directory__link" href="/sdk">SDK reference</a>
      <a class="vh-directory__link" href="/quickstart">Quickstart</a>
      <a class="vh-directory__link" href="/faq">FAQ</a>
    </div>
    <div class="vh-directory__col">
      <p class="vh-directory__head">Try</p>
      <a class="vh-directory__link" href="/workbench">Workbench</a>
      <a class="vh-directory__link" href="/try">30-second proof</a>
      <a class="vh-directory__link" href={`${HUB_URL}/entries`} rel="noopener">Hub entries</a>
      <a class="vh-directory__link" href="/replay">Replay an event log</a>
    </div>
    <div class="vh-directory__col">
      <p class="vh-directory__head">Verify</p>
      <a class="vh-directory__link" href="/proof/pericyte-correction">Worked Correction</a>
      <a class="vh-directory__link" href="/proof/contradiction">Worked contradiction</a>
      <a class="vh-directory__link" href="/proof/packet">Signed proof packet</a>
      <a class="vh-directory__link" href="/counterfactual">Counterfactuals</a>
    </div>
    <div class="vh-directory__col">
      <p class="vh-directory__head">Source</p>
      <a class="vh-directory__link" href={REPO_URL} rel="noopener">github.com/vela-science/vela</a>
      <a class="vh-directory__link" href={HUB_URL} rel="noopener">vela-hub.fly.dev</a>
      <a class="vh-directory__link" href="/vela_reducer.py">vela_reducer.py</a>
      <a class="vh-directory__link" href="/vela_reducer.mjs">vela_reducer.mjs</a>
    </div>
  </nav>

  <footer class="vh-foot" role="contentinfo">
    <dl class="vh-foot__meta">
      <div class="vh-foot__cell">
        <dt>Spec version</dt>
        <dd><a class="vh-foot__link" href="/spec">v{VERSION}</a></dd>
      </div>
      <div class="vh-foot__cell">
        <dt>License</dt>
        <dd><a class="vh-foot__link" href={`${REPO_URL}/blob/main/LICENSE`} rel="noopener">Apache-2.0 / MIT</a></dd>
      </div>
      <div class="vh-foot__cell">
        <dt>Hub</dt>
        <dd><a class="vh-foot__link" href={`${HUB_URL}/.well-known/vela`} rel="noopener">vela-hub.fly.dev</a></dd>
      </div>
      <div class="vh-foot__cell">
        <dt>Last signed</dt>
        <dd><span class="vh-foot__mono">{lastUpdated}</span></dd>
      </div>
      <div class="vh-foot__cell">
        <dt>Source</dt>
        <dd><a class="vh-foot__link" href={REPO_URL} rel="noopener">github</a></dd>
      </div>
      <div class="vh-foot__cell">
        <dt>Security</dt>
        <dd><a class="vh-foot__link" href={`${REPO_URL}/security/policy`} rel="noopener">policy</a></dd>
      </div>
    </dl>
  </footer>
</Reading>

<style>
  /* ── Hero ─────────────────────────────────────────────────────── */
  .vh-hero {
    max-width: 64rem;
  }
  .vh-hero__eyebrow {
    margin: 0 0 1.6rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--ink-3);
    letter-spacing: 0.02em;
  }
  .vh-hero__title {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: clamp(2rem, 4.2vw, 2.8rem);
    line-height: 1.08;
    letter-spacing: -0.022em;
    color: var(--ink-0);
    margin: 2.6rem 0 1rem;
    text-wrap: balance;
    max-width: 36ch;
  }
  .vh-hero__sub {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: clamp(1rem, 1.3vw, 1.1rem);
    line-height: 1.55;
    letter-spacing: -0.005em;
    color: var(--ink-2);
    margin: 0 0 2rem;
    max-width: 60ch;
    text-wrap: pretty;
  }

  .vh-hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .vh-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 22px;
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.95rem;
    letter-spacing: -0.005em;
    text-decoration: none;
    border-radius: 8px;
    transition:
      background 160ms var(--ease),
      color 160ms var(--ease),
      border-color 160ms var(--ease),
      transform 160ms var(--ease);
  }
  .vh-btn--primary {
    background: var(--ink-0);
    color: var(--paper-0);
    border: 1px solid var(--ink-0);
  }
  .vh-btn--primary:hover {
    background: var(--ink-1);
    transform: translateY(-1px);
  }
  .vh-btn--secondary {
    background: transparent;
    color: var(--ink-1);
    border: 1px solid color-mix(in oklab, var(--ink-1) 28%, transparent);
  }
  .vh-btn--secondary:hover {
    border-color: var(--ink-1);
    background: var(--paper-1);
    transform: translateY(-1px);
  }
  .vh-btn span { transition: transform 160ms var(--ease); }
  .vh-btn:hover span { transform: translateX(2px); }

  /* Try-it block */
  .vh-try {
    background: var(--paper-1);
    border: 1px solid var(--rule-2);
    border-radius: 10px;
    margin-bottom: 2rem;
    overflow: hidden;
  }
  .vh-try__head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px 18px;
    border-bottom: 1px solid var(--rule-1);
    background: color-mix(in oklab, var(--paper-2) 35%, var(--paper-1));
  }
  .vh-try__tag {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: color-mix(in oklab, var(--gold) 76%, var(--ink-2));
  }
  .vh-try__src {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--ink-3);
    text-decoration: none;
    transition: color 160ms var(--ease);
  }
  .vh-try__src:hover { color: var(--gold); }

  .vh-code {
    margin: 0;
    padding: 14px 18px;
    font-family: var(--font-mono);
    font-size: 0.88rem;
    line-height: 1.6;
    color: var(--ink-1);
    background: transparent;
    overflow-x: auto;
    white-space: pre;
  }
  .vh-code code { background: transparent; border: 0; padding: 0; font: inherit; color: inherit; }
  .vh-ps { color: color-mix(in oklab, var(--gold) 60%, var(--ink-3)); }
  .vh-cmd { color: var(--ink-0); font-weight: 500; }
  .vh-flag { color: var(--ink-2); }
  .vh-str { color: color-mix(in oklab, var(--moss) 70%, var(--ink-1)); }

  .vh-try__note {
    margin: 0;
    padding: 0 18px 14px;
    font-family: var(--font-sans);
    font-size: 0.9rem;
    line-height: 1.5;
    color: var(--ink-3);
    text-wrap: pretty;
    max-width: 72ch;
  }

  /* Stats row */
  .vh-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    margin: 0;
    padding: 0;
    border-top: 1px solid var(--rule-2);
    border-bottom: 1px solid var(--rule-2);
  }
  .vh-stat {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 1.1rem 0 1rem;
    border-right: 1px solid var(--rule-1);
  }
  .vh-stat:first-child { padding-left: 0; }
  .vh-stat:not(:first-child) { padding-left: 1.4rem; }
  .vh-stat:last-child { border-right: 0; }
  .vh-stat dt {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 1.5rem;
    line-height: 1;
    color: var(--ink-0);
    letter-spacing: -0.02em;
    font-variant-numeric: tabular-nums;
    margin: 0;
  }
  .vh-stat dd {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-3);
    margin: 0;
  }

  /* ── Section frame ───────────────────────────────────────────── */
  .vh-section {
    max-width: 76rem;
  }
  .vh-section__head { margin-bottom: 2.2rem; max-width: 64rem; }
  .vh-section__eyebrow {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: color-mix(in oklab, var(--gold) 78%, var(--ink-2));
    margin: 0 0 0.85rem;
  }
  .vh-section__title {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: clamp(1.5rem, 2.6vw, 2rem);
    line-height: 1.12;
    letter-spacing: -0.022em;
    color: var(--ink-0);
    margin: 0 0 0.8rem;
    text-wrap: balance;
    max-width: 36ch;
  }
  .vh-section__title--small {
    font-size: clamp(1.4rem, 2.4vw, 1.8rem);
    margin: 0;
  }
  .vh-section__sub {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 1.02rem;
    line-height: 1.5;
    color: var(--ink-2);
    margin: 0;
    max-width: 56ch;
    text-wrap: pretty;
  }
  .vh-section__foot {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 1.6rem;
    margin-top: 1.8rem;
    padding-top: 1.4rem;
    border-top: 1px solid var(--rule-1);
  }
  .vh-link {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.92rem;
    color: var(--ink-1);
    text-decoration: none;
    border-bottom: 1px solid color-mix(in oklab, var(--gold) 48%, transparent);
    padding-bottom: 1px;
    transition: color 160ms var(--ease), border-bottom-color 160ms var(--ease);
  }
  .vh-link:hover {
    color: var(--gold);
    border-bottom-color: var(--gold);
  }

  /* ── Claims grid ─────────────────────────────────────────────── */
  .vh-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
  }
  @media (max-width: 980px) {
    .vh-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 640px) {
    .vh-grid { grid-template-columns: 1fr; }
  }

  /* ── Build panes ─────────────────────────────────────────────── */
  .vh-build {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
  }
  @media (max-width: 980px) {
    .vh-build { grid-template-columns: 1fr; }
  }
  .vh-build__pane {
    background: var(--paper-1);
    border: 1px solid var(--rule-2);
    border-radius: 10px;
    overflow: hidden;
  }
  .vh-build__pane-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px 18px;
    border-bottom: 1px solid var(--rule-1);
    background: color-mix(in oklab, var(--paper-2) 35%, var(--paper-1));
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }
  .vh-build__pane-tag {
    color: color-mix(in oklab, var(--gold) 76%, var(--ink-2));
    font-weight: 500;
  }
  .vh-build__pane-aside { color: var(--ink-3); }
  .vh-code--block {
    padding: 16px 18px 18px;
    font-size: 0.82rem;
    line-height: 1.65;
  }

  /* ── Site directory — four-column footer of every page ────────── */
  .vh-directory {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    padding-top: 2.4rem;
    padding-bottom: 1.6rem;
    border-top: 1px solid var(--rule-2);
  }
  @media (max-width: 880px) {
    .vh-directory { grid-template-columns: repeat(2, 1fr); gap: 1.6rem 1.2rem; }
  }
  @media (max-width: 480px) {
    .vh-directory { grid-template-columns: 1fr; }
  }
  .vh-directory__col { display: flex; flex-direction: column; gap: 0.5rem; }
  .vh-directory__head {
    margin: 0 0 0.4rem;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: color-mix(in oklab, var(--gold) 78%, var(--ink-2));
  }
  .vh-directory__link {
    font-family: var(--font-sans);
    font-size: 0.92rem;
    color: var(--ink-1);
    text-decoration: none;
    transition: color 160ms var(--ease);
  }
  .vh-directory__link:hover { color: var(--gold); }

  /* ── Institutional footer — License · Spec · Hub · Last signed
     · Source · Security. Six cells, mono, no preciousness. */
  .vh-foot {
    margin-top: var(--rhythm-section);
    padding: 1.6rem 0 2rem;
    border-top: 1px solid var(--rule-2);
  }
  .vh-foot__meta {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 0.85rem 1.6rem;
    margin: 0;
    padding: 0;
  }
  .vh-foot__cell { display: flex; flex-direction: column; gap: 4px; }
  .vh-foot__cell dt {
    font-family: var(--font-mono);
    font-size: 9.5px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-3);
    margin: 0;
  }
  .vh-foot__cell dd {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    color: var(--ink-1);
    margin: 0;
  }
  .vh-foot__link {
    color: var(--ink-1);
    text-decoration: none;
    border-bottom: 1px solid color-mix(in oklab, var(--gold) 38%, transparent);
    padding-bottom: 1px;
    transition: color 160ms var(--ease), border-bottom-color 160ms var(--ease);
  }
  .vh-foot__link:hover { color: var(--gold); border-bottom-color: var(--gold); }
  .vh-foot__mono { font-family: var(--font-mono); font-size: 0.85em; }
  @media (max-width: 720px) {
    .vh-foot__meta { grid-template-columns: repeat(2, 1fr); }
  }

  /* Mobile */
  @media (max-width: 640px) {
    .vh-hero__ctas { flex-direction: column; align-items: stretch; }
    .vh-btn { justify-content: center; }
    .vh-stats { grid-template-columns: repeat(2, 1fr); }
    .vh-stat:nth-child(2) { border-right: 0; }
    .vh-stat:nth-child(3), .vh-stat:nth-child(4) { padding-top: 1rem; border-top: 1px solid var(--rule-1); }
    .vh-stat:not(:first-child):not(:nth-child(3)) { padding-left: 1.4rem; }
    .vh-stat:nth-child(3) { padding-left: 0; }
  }
</style>
