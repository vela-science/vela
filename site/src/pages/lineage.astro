---
/*
  /lineage — the quiet imprint.

  The architecture IS the dedication, but saying it explicitly once on
  the site closes the loop with the Borrowed Light essay. Short. No
  preaching. The kind of page you find by accident and recognize.
*/
import Page from "../layouts/Page.astro";
import ImagePlate from "../components/ImagePlate.astro";
import { BORROWED_LIGHT_URL } from "../config";
---

<Page
  title="Lineage · Vela"
  description="Why this exists, named once."
  active="lineage"
  eyebrow="Lineage"
  pageTitle="Lineage"
  subtitle="Why this exists, named once."
>
  <a href="/" slot="aside" class="aside-link">← back</a>

  <article class="lineage">
    <ImagePlate
      fallback="/images/plates/finding.png"
      width={1916}
      height={821}
      alt="A quiet watercolor pinpoint — a single bright finding suspended in atmospheric warmth."
    />

    <p class="lineage__hook">
      <em>Everything you learn, you pass on.</em>
    </p>
    <p class="lineage__attr">— Misha</p>

    <div class="lineage__body">
      <p>
        When I was six a brain tumour took four months and twelve doctors to
        recognize. The pattern was thirty seconds of pattern-matching once a
        thirteenth doctor saw it. The papers that named it had existed for
        decades.
      </p>
      <p>
        Misha was my closest friend. He died in San Francisco in January 2025,
        at twenty-seven. The line above is his — the substrate thesis of the
        Borrowed Light essay rendered into one sentence, years before either
        of us understood we were building toward it.
      </p>
      <p>
        Vela is the working artifact for that essay. The companion read at
        <a href={BORROWED_LIGHT_URL} rel="noopener" class="lineage__link">borrowedlight.org</a>
        carries the argument; this site is the substrate the argument
        names. Every Finding, Constellation, and signed Correction in here
        is an attempt to make sure the next person does not have to wait
        twelve doctors.
      </p>
    </div>

    <div class="lineage__imprint" role="contentinfo">
      <span class="lineage__rule" aria-hidden="true"></span>
      <p class="lineage__mark">for M.</p>
    </div>
  </article>
</Page>

<style>
  .aside-link {
    font-family: var(--font-mono);
    font-size: var(--size-imprint);
    letter-spacing: var(--track-imprint);
    text-transform: uppercase;
    color: var(--ink-3);
    border-bottom: 1px solid transparent;
    transition: color var(--dur-1) var(--ease), border-bottom-color var(--dur-1) var(--ease);
  }
  .aside-link:hover {
    color: var(--gold);
    border-bottom-color: color-mix(in oklab, var(--gold) 56%, transparent);
  }

  .lineage {
    max-width: var(--measure);
    margin: 0 auto;
    padding: 0;
  }
  .lineage :global(.vela-image-plate) {
    margin-top: 0;
    margin-bottom: 1.8rem;
  }

  .lineage__hook {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: clamp(1.65rem, 3.4vw, 2.4rem);
    line-height: 1.18;
    letter-spacing: var(--track-display);
    color: var(--ink-0);
    margin: 0 0 0.5rem;
    max-width: 32ch;
    text-wrap: balance;
  }
  .lineage__attr {
    margin: 0 0 2.4rem;
    font-family: var(--font-mono);
    font-size: var(--size-imprint);
    letter-spacing: var(--track-imprint);
    text-transform: uppercase;
    color: color-mix(in oklab, var(--gold) 76%, var(--ink-2));
  }

  .lineage__body p {
    font-family: var(--font-body);
    font-size: 1.08rem;
    line-height: var(--leading-read);
    color: color-mix(in oklab, var(--ink-1) 88%, var(--ink-2));
    margin: 0 0 1.35rem;
    text-wrap: pretty;
  }
  .lineage__body p:last-child { margin-bottom: 0; }

  .lineage__link {
    color: var(--ink-1);
    text-decoration: none;
    border-bottom: 1px solid color-mix(in oklab, var(--gold) 38%, transparent);
    transition: color var(--dur-1) var(--ease), border-bottom-color var(--dur-1) var(--ease);
  }
  .lineage__link:hover,
  .lineage__link:focus-visible {
    color: var(--gold);
    border-bottom-color: var(--gold);
  }

  .lineage__imprint {
    margin-top: clamp(4rem, 9vh, 6rem);
    padding-top: 1.6rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.85rem;
    text-align: center;
  }
  .lineage__rule {
    display: block;
    width: 4rem;
    height: 1px;
    background: linear-gradient(
      to right,
      transparent 0%,
      color-mix(in oklab, var(--gold) 48%, transparent) 50%,
      transparent 100%
    );
  }
  .lineage__mark {
    margin: 0;
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: var(--size-imprint);
    letter-spacing: 0.34em;
    text-transform: uppercase;
    color: color-mix(in oklab, var(--gold) 72%, var(--ink-2));
  }
</style>
