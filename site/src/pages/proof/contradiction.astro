  }
  .wc__event-tag--accent { color: var(--cinnabar); }
  .wc__event-id {
    color: var(--ink-3);
    letter-spacing: 0.02em;
    text-transform: none;
    font-size: 11px;
  }

  .wc__deps {
    list-style: none;
    margin: 0;
    padding: 0;
    border-top: 1px solid var(--rule-2);
  }
  .wc__dep {
    padding: 1.1rem 0;
    border-bottom: 1px solid var(--rule-1);
  }
  .wc__dep:last-child { border-bottom: 0; }
  .wc__dep-head {
    display: flex;
    align-items: baseline;
    gap: 8px;
    margin-bottom: 0.55rem;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-3);
  }
  .wc__dep-when {
    color: color-mix(in oklab, var(--gold) 76%, var(--ink-2));
